lor: rgb(255, 255, 255); height: 100px;\" class=\"card-container1\">\n          <div><i class=\"el-icon-s-data\" /> 设备总数</div>\n          <div style=\"padding: 10px o; text-align: center; font-weight: bold;\">100</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: rgb(255, 255, 255);height: 100px;\" class=\"card-container2\">          \n          <div><i class=\"el-icon-success\" /> 安全设备</div>\n          <div style=\"padding: 10px o; text-align: center; font-weight: bold;\">100</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: rgb(255, 255, 255);height: 100px;\" class=\"card-container3\">\n          <div><i class=\"el-icon-warning\" /> 异常设备</div>\n          <div style=\"padding: 10px o; text-align: center; font-weight: bold;\">100</div>\n        </el-card>      \n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: rgb(255, 255, 255);height: 100px;\" class=\"card-container4\">\n          <div><i class=\"el-icon-remove\" /> 离线设备</div>\n          <div style=\"padding: 10px o; text-align: center; font-weight: bold;\">100</div>\n        </el-card>      \n      </el-col>\n    </el-row>\n    <el-row>\n      <el-col :span=\"12\">\n        <div id=\"bar\" style=\"width: 500px; height: 400px\"></div>\n      </el-col>\n      <el-col :span=\"12\">\n        <div id=\"line\" style=\"width: 500px; height: 400px\"></div>\n      </el-col>\n    </el-row>      \n  </div>\n</template>\n\n\n<script>\nimport * as echarts from 'echarts'\nexport default {\n  name: \"Home\",\n  \n  mounted(){//页面元素渲染后再触发\n    \n    var baroption = {\n      title:{\n        text:'各季度会员统计数量'\n      },\n      tooltip:{\n        trigger:'item'\n      },\n      xAxis: {\n          type: 'category',\n          data: ['第一季度', '第二季度', '第三季度', '第四季度']\n      },\n      yAxis: {\n          type: 'value'\n      },\n      series: [\n          {\n            data: [],\n            type: 'bar',\n            showBackground: true,\n            backgroundStyle: {\n                color: 'rgba(180, 180, 180, 0.2)'\n            }\n          }\n      ]\n    };\n    var mCharts = echarts.init(document.getElementById('bar'))\n    this.request.get(\"/echarts/members\").then(res => {\n      // baroption.xAxis.data = res.data.x\n      baroption.series[0].data = res.data\n      mCharts.setOption(baroption); \n    })\n  \n    var myCharts = echarts.init(document.getElementById('line'))\n    var lineoption = {\n      title:{\n        text:'各季度会员统计数量'\n      },\n      tooltip:{\n        trigger:'item'\n      },\n      xAxis: {\n        type: 'category',\n        data: ['第一季度', '第二季度', '第三季度', '第四季度']\n      },\n      yAxis: {\n        type: 'value'\n      },\n      series: [\n        {\n          data: [],\n          type: 'line',\n          smooth: true\n        }\n      ]\n    };\n    this.request.get(\"/echarts/members\").then(res => {\n      // baroption.xAxis.data = res.data.x\n      lineoption.series[0].data = res.data\n      myCharts.setOption(lineoption);\n    })\n  }\n  \n}\n</script>\n\n<style scoped>\n.card-container1 {\n  position: relative;\n  /* background-color: #409EFF;  */\n  background-image: linear-gradient(to bottom right,#409EFF,#2c44bd);/* 卡片的底层颜色 */\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container2 {\n  position: relative;\n  /* background-color: #409EFF;  */\n  background-image: linear-gradient(to bottom right,#67C23A,#204e09);/* 卡片的底层颜色 */\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container3 {\n  position: relative;\n  /* background-color: #409EFF;  */\n  background-image: linear-gradient(to bottom right,#F56C6C,#751111);/* 卡片的底层颜色 */\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container4 {\n  position: relative;\n  /* background-color: #409EFF;  */\n  background-image: linear-gradient(to bottom right,#909399,#424447);/* 卡片的底层颜色 */\n  border-radius: 8px;\n  overflow: hidden;\n}\n</style>\n"],"mappings":"AAyC