el-menu-item index=\"/recognition\">\r\n          <i class=\"el-icon-s-tools\"></i>\r\n          <span slot=\"title\">识别结果</span>\r\n        </el-menu-item>\r\n      </el-submenu>\r\n    </el-menu>\r\n\r\n    <!-- 当前页面标题显示区域 -->\r\n    <div\r\n        class=\"current-title-container\"\r\n        v-if=\"currentTitle\"\r\n        :style=\"{\r\n        padding: isCollapse ? '12px 10px' : '12px 20px',\r\n        borderTop: '1px solid #444',\r\n        textAlign: isCollapse ? 'center' : 'left'\r\n      }\"\r\n    >\r\n      <span style=\"font-size: 13px; color: #90CDF4;\">当前页面：</span>\r\n      <span style=\"font-size: 14px; color: #E2E8F0; font-weight: 500;\">{{ currentTitle }}</span>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Aside\",\r\n  props: {\r\n    isCollapse: {\r\n      type: Boolean,\r\n      required: true,\r\n      default: false\r\n    },\r\n    logoTextShow: {\r\n      type: Boolean,\r\n      required: false,\r\n      default: true\r\n    },\r\n    currentTitle: {\r\n      type: String,\r\n      required: false,\r\n      default: ''\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.aside-container {\r\n  height: 100%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: space-between;\r\n}\r\n\r\n/* 消除Element UI默认边框 */\r\n:deep(.el-menu) {\r\n  border-right: none;\r\n  height: 100%;\r\n}\r\n\r\n/* 标题容器样式 */\r\n.current-title-container {\r\n  margin-top: auto;\r\n}\r\n</style>"],"mappings":"AAoEA;EACAA,IAAA;EACAC,KAAA;IACAC,UAAA;MACAC,IAAA,EAAAC,OAAA;MACAC,QAAA;MACAC,OAAA;IACA;IACAC,YAAA;MACAJ,IAAA,EAAAC,OAAA;MACAC,QAAA;MACAC,OAAA;IACA;IACAE,YAAA;MACAL,IAAA,EAAAM,MAAA;MACAJ,QAAA;MACAC,OAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}