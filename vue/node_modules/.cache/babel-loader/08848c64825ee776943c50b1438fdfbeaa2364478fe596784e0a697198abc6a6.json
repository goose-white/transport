{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\nimport request from '@/utils/request';\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      // 任务列表数据\n      loading: false,\n      // 加载状态\n      dialogFormVisible: false,\n      // 弹窗显示状态\n      form: {},\n      // 表单数据\n      formRules: {\n        // 表单校验规则\n        name: [{\n          required: true,\n          message: '请输入任务名称',\n          trigger: 'blur'\n        }],\n        type: [{\n          required: true,\n          message: '请输入任务类型',\n          trigger: 'blur'\n        }],\n        device_id: [{\n          required: true,\n          message: '请输入无人机ID',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    // 页面初始化时加载数据\n    this.loadTaskData();\n  },\n  methods: {\n    // 重置表单\n    resetForm() {\n      this.form = {};\n      this.$refs.formRef?.resetFields();\n    },\n    // 加载任务数据（核心修复：强制映射数据库字段，避免数据丢失）\n    async loadTaskData() {\n      try {\n        this.loading = true;\n        // 调用后端接口获取数据\n        const res = await request.get(\"/task/getAllData\", {});\n\n        // 调试日志：打印后端返回的原始数据，方便定位字段名问题\n        console.log('后端返回完整数据：', res);\n        if (res.data.data && res.data.data.length > 0) {\n          console.log('第一个任务的所有字段：', Object.keys(res.data.data[0]));\n          console.log('第一个任务的原始值：', res.data.data[0]);\n        }\n\n        // 提取后端返回的数组数据，强制映射数据库字段\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data.map(item => ({\n          // 严格匹配数据库字段，确保每个字段都被正确赋值\n          id: item.id || '',\n          name: item.name || '',\n          type: item.type || '',\n          device_id: item.device_id || '',\n          // 执行无人机字段\n          start_time: item.start_time || '',\n          // 创建时间字段\n          end_time: item.end_time || '',\n          // 任务结束时间字段\n          status: item.status || ''\n        })) : [];\n      } catch (error) {\n        console.error('数据加载失败：', error);\n        this.taskList = [];\n        this.$message.error('数据加载失败，请重试');\n      } finally {\n        this.loading = false;\n      }\n    },\n    // 打开新增任务弹窗\n    handleAdd() {\n      this.form = {};\n      this.dialogFormVisible = true;\n    },\n    // 打开编辑任务弹窗\n    handleEdit(row) {\n      // 深拷贝行数据，避免修改表单时影响表格原始数据\n      this.form = JSON.parse(JSON.stringify(row));\n      this.dialogFormVisible = true;\n    },\n    // 保存任务（新增/编辑）\n    async saveTask() {\n      try {\n        // 表单校验\n        await this.$refs.formRef.validate();\n        // 根据是否有id判断是新增还是编辑\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\";\n        const res = await request.post(apiUrl, this.form);\n        if (res?.code === 200) {\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功');\n          this.dialogFormVisible = false;\n          // 保存成功后刷新数据\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '保存失败');\n        }\n      } catch (error) {\n        this.$message.error('保存失败，请检查输入内容');\n      }\n    },\n    // 删除任务\n    async handleDelete(row) {\n      try {\n        // 确认删除\n        await this.$confirm('确定删除该任务？', '提示', {\n          type: 'warning'\n        });\n        const res = await request.post(\"/task/delete\", {\n          id: row.id\n        });\n        if (res?.code === 200) {\n          this.$message.success('删除成功');\n          // 删除成功后刷新数据\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '删除失败');\n        }\n      } catch (error) {\n        // 取消删除时提示\n        if (error !== 'cancel') {\n          this.$message.error('删除操作取消');\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","formRules","required","message","trigger","type","device_id","created","loadTaskData","methods","resetForm","$refs","formRef","resetFields","res","get","console","log","length","Object","keys","Array","isArray","map","item","id","start_time","end_time","status","error","$message","handleAdd","handleEdit","row","JSON","parse","stringify","saveTask","validate","apiUrl","post","code","success","msg","handleDelete","$confirm"],"sources":["src/views/task.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 新增/编辑弹窗 -->\r\n    <el-dialog title=\"任务信息\" v-model=\"dialogFormVisible\" width=\"500px\" @close=\"resetForm\">\r\n      <el-form ref=\"formRef\" :model=\"form\" label-width=\"100px\" size=\"small\" :rules=\"formRules\">\r\n        <el-form-item label=\"任务名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"type\">\r\n          <el-input v-model=\"form.type\" placeholder=\"请输入任务类型（数据库原始值）\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"device_id\">\r\n          <el-input v-model=\"form.device_id\" placeholder=\"请输入无人机ID\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTask\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 新增按钮 -->\r\n    <el-button type=\"primary\" style=\"margin-bottom: 20px;\" @click=\"handleAdd\">新增任务</el-button>\r\n\r\n    <!-- 任务表格：绑定数据库原始字段，确保数据不丢失 -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column prop=\"id\" label=\"任务ID\" width=\"120\" />\r\n      <el-table-column prop=\"name\" label=\"任务名称\" width=\"180\" />\r\n      <el-table-column prop=\"type\" label=\"任务类型\" width=\"120\" />\r\n      <el-table-column prop=\"device_id\" label=\"执行无人机\" width=\"120\" />\r\n      <el-table-column prop=\"start_time\" label=\"创建时间\" width=\"180\" />\r\n      <el-table-column prop=\"end_time\" label=\"任务结束时间\" width=\"180\" />\r\n      <el-table-column prop=\"status\" label=\"任务状态\" width=\"120\" />\r\n      <el-table-column label=\"操作\" width=\"150\">\r\n        <template #default=\"scope\">\r\n          <el-button type=\"primary\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click=\"handleDelete(scope.row)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [], // 任务列表数据\r\n      loading: false, // 加载状态\r\n      dialogFormVisible: false, // 弹窗显示状态\r\n      form: {}, // 表单数据\r\n      formRules: { // 表单校验规则\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请输入任务类型', trigger: 'blur' }],\r\n        device_id: [{ required: true, message: '请输入无人机ID', trigger: 'blur' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    // 页面初始化时加载数据\r\n    this.loadTaskData()\r\n  },\r\n  methods: {\r\n    // 重置表单\r\n    resetForm() {\r\n      this.form = {}\r\n      this.$refs.formRef?.resetFields()\r\n    },\r\n\r\n    // 加载任务数据（核心修复：强制映射数据库字段，避免数据丢失）\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true\r\n        // 调用后端接口获取数据\r\n        const res = await request.get(\"/task/getAllData\", {})\r\n\r\n        // 调试日志：打印后端返回的原始数据，方便定位字段名问题\r\n        console.log('后端返回完整数据：', res)\r\n        if (res.data.data && res.data.data.length > 0) {\r\n          console.log('第一个任务的所有字段：', Object.keys(res.data.data[0]))\r\n          console.log('第一个任务的原始值：', res.data.data[0])\r\n        }\r\n\r\n        // 提取后端返回的数组数据，强制映射数据库字段\r\n        this.taskList = res.data.data && Array.isArray(res.data.data)\r\n            ? res.data.data.map(item => ({\r\n              // 严格匹配数据库字段，确保每个字段都被正确赋值\r\n              id: item.id || '',\r\n              name: item.name || '',\r\n              type: item.type || '',\r\n              device_id: item.device_id || '', // 执行无人机字段\r\n              start_time: item.start_time || '', // 创建时间字段\r\n              end_time: item.end_time || '', // 任务结束时间字段\r\n              status: item.status || ''\r\n            }))\r\n            : []\r\n      } catch (error) {\r\n        console.error('数据加载失败：', error)\r\n        this.taskList = []\r\n        this.$message.error('数据加载失败，请重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    // 打开新增任务弹窗\r\n    handleAdd() {\r\n      this.form = {}\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    // 打开编辑任务弹窗\r\n    handleEdit(row) {\r\n      // 深拷贝行数据，避免修改表单时影响表格原始数据\r\n      this.form = JSON.parse(JSON.stringify(row))\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    // 保存任务（新增/编辑）\r\n    async saveTask() {\r\n      try {\r\n        // 表单校验\r\n        await this.$refs.formRef.validate()\r\n        // 根据是否有id判断是新增还是编辑\r\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\"\r\n        const res = await request.post(apiUrl, this.form)\r\n\r\n        if (res?.code === 200) {\r\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功')\r\n          this.dialogFormVisible = false\r\n          // 保存成功后刷新数据\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '保存失败')\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('保存失败，请检查输入内容')\r\n      }\r\n    },\r\n\r\n    // 删除任务\r\n    async handleDelete(row) {\r\n      try {\r\n        // 确认删除\r\n        await this.$confirm('确定删除该任务？', '提示', { type: 'warning' })\r\n        const res = await request.post(\"/task/delete\", { id: row.id })\r\n\r\n        if (res?.code === 200) {\r\n          this.$message.success('删除成功')\r\n          // 删除成功后刷新数据\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        // 取消删除时提示\r\n        if (error !== 'cancel') {\r\n          this.$message.error('删除操作取消')\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 样式微调，提升界面美观度 */\r\n:deep(.el-button) { margin: 0 4px; }\r\n:deep(.el-form-item) { margin-bottom: 15px; }\r\n/* 表格单元格垂直居中 */\r\n:deep(.el-table-cell) { vertical-align: middle; }\r\n</style>"],"mappings":";;;;AAkDA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MAAA;MACAC,OAAA;MAAA;MACAC,iBAAA;MAAA;MACAC,IAAA;MAAA;MACAC,SAAA;QAAA;QACAN,IAAA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,IAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAE,SAAA;UAAAJ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAG,QAAA;IACA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACA;IACAC,UAAA;MACA,KAAAV,IAAA;MACA,KAAAW,KAAA,CAAAC,OAAA,EAAAC,WAAA;IACA;IAEA;IACA,MAAAL,aAAA;MACA;QACA,KAAAV,OAAA;QACA;QACA,MAAAgB,GAAA,SAAApB,OAAA,CAAAqB,GAAA;;QAEA;QACAC,OAAA,CAAAC,GAAA,cAAAH,GAAA;QACA,IAAAA,GAAA,CAAAlB,IAAA,CAAAA,IAAA,IAAAkB,GAAA,CAAAlB,IAAA,CAAAA,IAAA,CAAAsB,MAAA;UACAF,OAAA,CAAAC,GAAA,gBAAAE,MAAA,CAAAC,IAAA,CAAAN,GAAA,CAAAlB,IAAA,CAAAA,IAAA;UACAoB,OAAA,CAAAC,GAAA,eAAAH,GAAA,CAAAlB,IAAA,CAAAA,IAAA;QACA;;QAEA;QACA,KAAAC,QAAA,GAAAiB,GAAA,CAAAlB,IAAA,CAAAA,IAAA,IAAAyB,KAAA,CAAAC,OAAA,CAAAR,GAAA,CAAAlB,IAAA,CAAAA,IAAA,IACAkB,GAAA,CAAAlB,IAAA,CAAAA,IAAA,CAAA2B,GAAA,CAAAC,IAAA;UACA;UACAC,EAAA,EAAAD,IAAA,CAAAC,EAAA;UACA9B,IAAA,EAAA6B,IAAA,CAAA7B,IAAA;UACAU,IAAA,EAAAmB,IAAA,CAAAnB,IAAA;UACAC,SAAA,EAAAkB,IAAA,CAAAlB,SAAA;UAAA;UACAoB,UAAA,EAAAF,IAAA,CAAAE,UAAA;UAAA;UACAC,QAAA,EAAAH,IAAA,CAAAG,QAAA;UAAA;UACAC,MAAA,EAAAJ,IAAA,CAAAI,MAAA;QACA,MACA;MACA,SAAAC,KAAA;QACAb,OAAA,CAAAa,KAAA,YAAAA,KAAA;QACA,KAAAhC,QAAA;QACA,KAAAiC,QAAA,CAAAD,KAAA;MACA;QACA,KAAA/B,OAAA;MACA;IACA;IAEA;IACAiC,UAAA;MACA,KAAA/B,IAAA;MACA,KAAAD,iBAAA;IACA;IAEA;IACAiC,WAAAC,GAAA;MACA;MACA,KAAAjC,IAAA,GAAAkC,IAAA,CAAAC,KAAA,CAAAD,IAAA,CAAAE,SAAA,CAAAH,GAAA;MACA,KAAAlC,iBAAA;IACA;IAEA;IACA,MAAAsC,SAAA;MACA;QACA;QACA,WAAA1B,KAAA,CAAAC,OAAA,CAAA0B,QAAA;QACA;QACA,MAAAC,MAAA,QAAAvC,IAAA,CAAAyB,EAAA;QACA,MAAAX,GAAA,SAAApB,OAAA,CAAA8C,IAAA,CAAAD,MAAA,OAAAvC,IAAA;QAEA,IAAAc,GAAA,EAAA2B,IAAA;UACA,KAAAX,QAAA,CAAAY,OAAA,MAAA1C,IAAA,CAAAyB,EAAA;UACA,KAAA1B,iBAAA;UACA;UACA,KAAAS,YAAA;QACA;UACA,KAAAsB,QAAA,CAAAD,KAAA,CAAAf,GAAA,EAAA6B,GAAA;QACA;MACA,SAAAd,KAAA;QACA,KAAAC,QAAA,CAAAD,KAAA;MACA;IACA;IAEA;IACA,MAAAe,aAAAX,GAAA;MACA;QACA;QACA,WAAAY,QAAA;UAAAxC,IAAA;QAAA;QACA,MAAAS,GAAA,SAAApB,OAAA,CAAA8C,IAAA;UAAAf,EAAA,EAAAQ,GAAA,CAAAR;QAAA;QAEA,IAAAX,GAAA,EAAA2B,IAAA;UACA,KAAAX,QAAA,CAAAY,OAAA;UACA;UACA,KAAAlC,YAAA;QACA;UACA,KAAAsB,QAAA,CAAAD,KAAA,CAAAf,GAAA,EAAA6B,GAAA;QACA;MACA,SAAAd,KAAA;QACA;QACA,IAAAA,KAAA;UACA,KAAAC,QAAA,CAAAD,KAAA;QACA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}