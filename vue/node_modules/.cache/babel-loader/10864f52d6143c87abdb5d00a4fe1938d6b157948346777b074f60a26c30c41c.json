{"ast":null,"code":"// 假设 request 是你封装的请求工具，需确保已引入\n// import request from '@/utils/request'\n\nexport default {\n  name: \"recognition\",\n  data() {\n    return {\n      recognition: [],\n      // 表格数据源，初始值为空数组（关键）\n      form: {},\n      // 编辑表单数据\n      dialogFormVisible: false,\n      // 弹窗显示状态\n      loading: false,\n      // 加载状态\n      // 表单校验规则\n      formRules: {\n        time: [{\n          required: true,\n          message: '请输入识别时间',\n          trigger: 'blur'\n        }],\n        content: [{\n          required: true,\n          message: '请输入识别结果详情',\n          trigger: 'blur'\n        }],\n        url: [{\n          required: true,\n          message: '请输入存储路径',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.load(); // 页面创建时加载数据\n  },\n  methods: {\n    // 重置表单\n    resetForm() {\n      this.form = {};\n      if (this.$refs.formRef) {\n        this.$refs.formRef.resetFields();\n      }\n    },\n    // 保存编辑\n    async save() {\n      try {\n        // 先校验表单\n        await this.$refs.formRef.validate();\n        const res = await this.request.post(\"/recognition/save\", this.form);\n        if (res && res.code === 200) {\n          // 适配常见的接口返回格式\n          this.$message.success(\"保存成功!\");\n          this.dialogFormVisible = false;\n          this.load(); // 重新加载数据\n        } else {\n          this.$message.error(res?.msg || '保存失败，请重试');\n        }\n      } catch (error) {\n        console.error('保存失败：', error);\n        this.$message.error('保存失败，请检查数据格式');\n      }\n    },\n    // 加载表格数据（核心修复）\n    async load() {\n      try {\n        this.loading = true; // 显示加载中\n        const res = await this.request.get(\"/recognition/getAllData\", {});\n\n        // 核心修复：提取接口中的数组数据，兜底为空数组\n        // 适配常见接口格式：{code:200, data: [...]} 或直接返回数组\n        const tableData = res?.data?.data || res?.data || [];\n\n        // 强制确保是数组（最终兜底）\n        this.recognition = Array.isArray(tableData) ? tableData : [];\n      } catch (error) {\n        console.error('加载识别数据失败：', error);\n        this.recognition = []; // 失败时重置为空数组（关键）\n        this.$message.error('数据加载失败，请刷新页面重试');\n      } finally {\n        this.loading = false; // 关闭加载状态\n      }\n    },\n    // 编辑行数据\n    handleEdit(row) {\n      // 深拷贝，避免修改表单时直接联动表格数据\n      this.form = {\n        ...row\n      };\n      this.dialogFormVisible = true;\n    }\n  }\n};","map":{"version":3,"names":["name","data","recognition","form","dialogFormVisible","loading","formRules","time","required","message","trigger","content","url","created","load","methods","resetForm","$refs","formRef","resetFields","save","validate","res","request","post","code","$message","success","error","msg","console","get","tableData","Array","isArray","handleEdit","row"],"sources":["src/views/recognition.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <el-dialog\r\n        title=\"设备信息\"\r\n        v-model=\"dialogFormVisible\"\r\n        width=\"500px\"\r\n        @close=\"resetForm\" // 关闭弹窗时重置表单\r\n    >\r\n    <el-form\r\n        ref=\"formRef\"\r\n        :model=\"form\"\r\n        label-width=\"100px\"\r\n        size=\"small\"\r\n        :rules=\"formRules\" // 添加表单校验\r\n    >\r\n    <el-form-item label=\"识别时间\" prop=\"time\">\r\n      <el-input v-model=\"form.time\" autocomplete=\"off\" placeholder=\"请输入识别时间\"></el-input>\r\n    </el-form-item>\r\n    <el-form-item label=\"识别结果详情\" prop=\"content\">\r\n      <el-input v-model=\"form.content\" autocomplete=\"off\" placeholder=\"请输入识别结果详情\"></el-input>\r\n    </el-form-item>\r\n    <el-form-item label=\"存储路径\" prop=\"url\">\r\n      <el-input v-model=\"form.url\" autocomplete=\"off\" placeholder=\"请输入存储路径\"></el-input>\r\n    </el-form-item>\r\n    </el-form>\r\n    <div slot=\"footer\" class=\"dialog-footer\">\r\n      <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\r\n      <el-button type=\"primary\" @click=\"save\">确 定</el-button>\r\n    </div>\r\n    </el-dialog>\r\n\r\n    <el-table\r\n        :data=\"recognition\"\r\n        stripe\r\n        border // 增加边框，提升可读性\r\n    style=\"width: 100%;\"\r\n    v-loading=\"loading\" // 添加加载状态\r\n    >\r\n    <el-table-column\r\n        prop=\"id\"\r\n        label=\"识别记录标识\"\r\n        width=\"120\"\r\n    />\r\n    <el-table-column\r\n        prop=\"time\"\r\n        label=\"识别时间\"\r\n        width=\"180\"\r\n    />\r\n    <el-table-column\r\n        prop=\"deviceId\"\r\n        label=\"采集设备\"\r\n        width=\"120\"\r\n    />\r\n    <el-table-column\r\n        prop=\"taskId\"\r\n        label=\"所属任务\"\r\n        width=\"120\"\r\n    />\r\n    <el-table-column\r\n        prop=\"content\"\r\n        label=\"识别结果详情\"\r\n        min-width=\"200\" // 自适应宽度\r\n    />\r\n    <el-table-column\r\n        prop=\"url\"\r\n        label=\"存储路径\"\r\n        min-width=\"200\"\r\n    />\r\n    <el-table-column label=\"操作\" width=\"120\">\r\n      <template #default=\"scope\">\r\n        <el-button\r\n            type=\"primary\"\r\n            size=\"small\"\r\n            @click=\"handleEdit(scope.row)\"\r\n        >\r\n          编辑 <i class=\"el-icon-edit\"></i>\r\n        </el-button>\r\n      </template>\r\n    </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\n// 假设 request 是你封装的请求工具，需确保已引入\r\n// import request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"recognition\",\r\n  data() {\r\n    return {\r\n      recognition: [], // 表格数据源，初始值为空数组（关键）\r\n      form: {}, // 编辑表单数据\r\n      dialogFormVisible: false, // 弹窗显示状态\r\n      loading: false, // 加载状态\r\n      // 表单校验规则\r\n      formRules: {\r\n        time: [{ required: true, message: '请输入识别时间', trigger: 'blur' }],\r\n        content: [{ required: true, message: '请输入识别结果详情', trigger: 'blur' }],\r\n        url: [{ required: true, message: '请输入存储路径', trigger: 'blur' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.load() // 页面创建时加载数据\r\n  },\r\n  methods: {\r\n    // 重置表单\r\n    resetForm() {\r\n      this.form = {}\r\n      if (this.$refs.formRef) {\r\n        this.$refs.formRef.resetFields()\r\n      }\r\n    },\r\n    // 保存编辑\r\n    async save() {\r\n      try {\r\n        // 先校验表单\r\n        await this.$refs.formRef.validate()\r\n        const res = await this.request.post(\"/recognition/save\", this.form)\r\n        if (res && res.code === 200) { // 适配常见的接口返回格式\r\n          this.$message.success(\"保存成功!\")\r\n          this.dialogFormVisible = false\r\n          this.load() // 重新加载数据\r\n        } else {\r\n          this.$message.error(res?.msg || '保存失败，请重试')\r\n        }\r\n      } catch (error) {\r\n        console.error('保存失败：', error)\r\n        this.$message.error('保存失败，请检查数据格式')\r\n      }\r\n    },\r\n    // 加载表格数据（核心修复）\r\n    async load() {\r\n      try {\r\n        this.loading = true // 显示加载中\r\n        const res = await this.request.get(\"/recognition/getAllData\", {})\r\n\r\n        // 核心修复：提取接口中的数组数据，兜底为空数组\r\n        // 适配常见接口格式：{code:200, data: [...]} 或直接返回数组\r\n        const tableData = res?.data?.data || res?.data || []\r\n\r\n        // 强制确保是数组（最终兜底）\r\n        this.recognition = Array.isArray(tableData) ? tableData : []\r\n      } catch (error) {\r\n        console.error('加载识别数据失败：', error)\r\n        this.recognition = [] // 失败时重置为空数组（关键）\r\n        this.$message.error('数据加载失败，请刷新页面重试')\r\n      } finally {\r\n        this.loading = false // 关闭加载状态\r\n      }\r\n    },\r\n    // 编辑行数据\r\n    handleEdit(row) {\r\n      // 深拷贝，避免修改表单时直接联动表格数据\r\n      this.form = { ...row }\r\n      this.dialogFormVisible = true\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 优化按钮样式 */\r\n:deep(.el-button) {\r\n  margin: 0 2px;\r\n}\r\n/* 弹窗表单间距优化 */\r\n:deep(.el-form-item) {\r\n  margin-bottom: 15px;\r\n}\r\n</style>"],"mappings":"AAoFA;AACA;;AAEA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,WAAA;MAAA;MACAC,IAAA;MAAA;MACAC,iBAAA;MAAA;MACAC,OAAA;MAAA;MACA;MACAC,SAAA;QACAC,IAAA;UAAAC,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,OAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAE,GAAA;UAAAJ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAG,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACA;IACAC,UAAA;MACA,KAAAb,IAAA;MACA,SAAAc,KAAA,CAAAC,OAAA;QACA,KAAAD,KAAA,CAAAC,OAAA,CAAAC,WAAA;MACA;IACA;IACA;IACA,MAAAC,KAAA;MACA;QACA;QACA,WAAAH,KAAA,CAAAC,OAAA,CAAAG,QAAA;QACA,MAAAC,GAAA,cAAAC,OAAA,CAAAC,IAAA,2BAAArB,IAAA;QACA,IAAAmB,GAAA,IAAAA,GAAA,CAAAG,IAAA;UAAA;UACA,KAAAC,QAAA,CAAAC,OAAA;UACA,KAAAvB,iBAAA;UACA,KAAAU,IAAA;QACA;UACA,KAAAY,QAAA,CAAAE,KAAA,CAAAN,GAAA,EAAAO,GAAA;QACA;MACA,SAAAD,KAAA;QACAE,OAAA,CAAAF,KAAA,UAAAA,KAAA;QACA,KAAAF,QAAA,CAAAE,KAAA;MACA;IACA;IACA;IACA,MAAAd,KAAA;MACA;QACA,KAAAT,OAAA;QACA,MAAAiB,GAAA,cAAAC,OAAA,CAAAQ,GAAA;;QAEA;QACA;QACA,MAAAC,SAAA,GAAAV,GAAA,EAAArB,IAAA,EAAAA,IAAA,IAAAqB,GAAA,EAAArB,IAAA;;QAEA;QACA,KAAAC,WAAA,GAAA+B,KAAA,CAAAC,OAAA,CAAAF,SAAA,IAAAA,SAAA;MACA,SAAAJ,KAAA;QACAE,OAAA,CAAAF,KAAA,cAAAA,KAAA;QACA,KAAA1B,WAAA;QACA,KAAAwB,QAAA,CAAAE,KAAA;MACA;QACA,KAAAvB,OAAA;MACA;IACA;IACA;IACA8B,WAAAC,GAAA;MACA;MACA,KAAAjC,IAAA;QAAA,GAAAiC;MAAA;MACA,KAAAhC,iBAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}