{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport { ElMessage } from 'element-ui'; // 引入Element提示组件\n\nexport default {\n  name: 'Photography',\n  data() {\n    return {\n      isCameraOpen: false,\n      // 摄像头开关状态\n      videoStream: null // 保存视频流（用于关闭摄像头）\n    };\n  },\n  methods: {\n    // 开关切换时触发：打开/关闭摄像头\n    async toggleCamera(open) {\n      if (open) {\n        await this.openCamera();\n      } else {\n        this.closeCamera();\n      }\n    },\n    // 打开摄像头（调用浏览器Media API）\n    async openCamera() {\n      try {\n        // 请求摄像头权限，获取视频流（仅请求视频轨道）\n        const stream = await navigator.mediaDevices.getUserMedia({\n          video: {\n            facingMode: 'user'\n          } // 优先前置摄像头（移动设备可用environment后置）\n        });\n        this.videoStream = stream;\n        // 将视频流绑定到video标签\n        const videoDom = this.$refs.videoRef;\n        videoDom.srcObject = stream;\n        await videoDom.play(); // 自动播放视频\n      } catch (err) {\n        this.isCameraOpen = false; // 开关切回关闭\n        ElMessage.error(`摄像头启动失败：${err.message}`);\n        console.error('摄像头错误：', err);\n      }\n    },\n    // 关闭摄像头（停止视频流）\n    closeCamera() {\n      if (this.videoStream) {\n        // 停止所有视频轨道\n        this.videoStream.getTracks().forEach(track => track.stop());\n        this.videoStream = null;\n        // 清空video的视频源\n        this.$refs.videoRef.srcObject = null;\n      }\n    }\n  },\n  // 组件销毁前：确保关闭摄像头\n  beforeUnmount() {\n    if (this.isCameraOpen) {\n      this.closeCamera();\n    }\n  }\n};","map":{"version":3,"names":["ElMessage","name","data","isCameraOpen","videoStream","methods","toggleCamera","open","openCamera","closeCamera","stream","navigator","mediaDevices","getUserMedia","video","facingMode","videoDom","$refs","videoRef","srcObject","play","err","error","message","console","getTracks","forEach","track","stop","beforeUnmount"],"sources":["src/views/Photography.vue"],"sourcesContent":["<script>\r\nexport default {\r\n  name: \"Photography\"\r\n}\r\n</script>\r\n\r\n<template>\r\n  <div class=\"photography-page\">\r\n    <!-- 卡片容器 -->\r\n    <el-card shadow=\"hover\" class=\"camera-card\">\r\n      <!-- 卡片头部：标题+开关 -->\r\n      <div slot=\"header\" class=\"card-header\">\r\n        <span>摄影管理</span>\r\n        <el-switch\r\n            v-model=\"isCameraOpen\"\r\n            active-color=\"#13ce66\"\r\n            inactive-color=\"#ff4949\"\r\n            @change=\"toggleCamera\"\r\n        />\r\n      </div>\r\n      <!-- 摄像头预览区域 -->\r\n      <div class=\"camera-preview\">\r\n        <video\r\n            ref=\"videoRef\"\r\n            autoplay\r\n            playsinline\r\n            class=\"camera-video\"\r\n        />\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ElMessage } from 'element-ui'; // 引入Element提示组件\r\n\r\nexport default {\r\n  name: 'Photography',\r\n  data() {\r\n    return {\r\n      isCameraOpen: false, // 摄像头开关状态\r\n      videoStream: null // 保存视频流（用于关闭摄像头）\r\n    };\r\n  },\r\n  methods: {\r\n    // 开关切换时触发：打开/关闭摄像头\r\n    async toggleCamera(open) {\r\n      if (open) {\r\n        await this.openCamera();\r\n      } else {\r\n        this.closeCamera();\r\n      }\r\n    },\r\n\r\n    // 打开摄像头（调用浏览器Media API）\r\n    async openCamera() {\r\n      try {\r\n        // 请求摄像头权限，获取视频流（仅请求视频轨道）\r\n        const stream = await navigator.mediaDevices.getUserMedia({\r\n          video: { facingMode: 'user' } // 优先前置摄像头（移动设备可用environment后置）\r\n        });\r\n        this.videoStream = stream;\r\n        // 将视频流绑定到video标签\r\n        const videoDom = this.$refs.videoRef;\r\n        videoDom.srcObject = stream;\r\n        await videoDom.play(); // 自动播放视频\r\n      } catch (err) {\r\n        this.isCameraOpen = false; // 开关切回关闭\r\n        ElMessage.error(`摄像头启动失败：${err.message}`);\r\n        console.error('摄像头错误：', err);\r\n      }\r\n    },\r\n\r\n    // 关闭摄像头（停止视频流）\r\n    closeCamera() {\r\n      if (this.videoStream) {\r\n        // 停止所有视频轨道\r\n        this.videoStream.getTracks().forEach(track => track.stop());\r\n        this.videoStream = null;\r\n        // 清空video的视频源\r\n        this.$refs.videoRef.srcObject = null;\r\n      }\r\n    }\r\n  },\r\n  // 组件销毁前：确保关闭摄像头\r\n  beforeUnmount() {\r\n    if (this.isCameraOpen) {\r\n      this.closeCamera();\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.photography-page {\r\n  padding: 20px;\r\n}\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n.camera-preview {\r\n  margin-top: 20px;\r\n  display: flex;\r\n  justify-content: center;\r\n}\r\n.camera-video {\r\n  width: 640px;\r\n  height: 480px;\r\n  border: 1px solid #e6e6e6;\r\n  border-radius: 4px;\r\n}\r\n</style>"],"mappings":";;AAkCA,SAAAA,SAAA;;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,YAAA;MAAA;MACAC,WAAA;IACA;EACA;EACAC,OAAA;IACA;IACA,MAAAC,aAAAC,IAAA;MACA,IAAAA,IAAA;QACA,WAAAC,UAAA;MACA;QACA,KAAAC,WAAA;MACA;IACA;IAEA;IACA,MAAAD,WAAA;MACA;QACA;QACA,MAAAE,MAAA,SAAAC,SAAA,CAAAC,YAAA,CAAAC,YAAA;UACAC,KAAA;YAAAC,UAAA;UAAA;QACA;QACA,KAAAX,WAAA,GAAAM,MAAA;QACA;QACA,MAAAM,QAAA,QAAAC,KAAA,CAAAC,QAAA;QACAF,QAAA,CAAAG,SAAA,GAAAT,MAAA;QACA,MAAAM,QAAA,CAAAI,IAAA;MACA,SAAAC,GAAA;QACA,KAAAlB,YAAA;QACAH,SAAA,CAAAsB,KAAA,YAAAD,GAAA,CAAAE,OAAA;QACAC,OAAA,CAAAF,KAAA,WAAAD,GAAA;MACA;IACA;IAEA;IACAZ,YAAA;MACA,SAAAL,WAAA;QACA;QACA,KAAAA,WAAA,CAAAqB,SAAA,GAAAC,OAAA,CAAAC,KAAA,IAAAA,KAAA,CAAAC,IAAA;QACA,KAAAxB,WAAA;QACA;QACA,KAAAa,KAAA,CAAAC,QAAA,CAAAC,SAAA;MACA;IACA;EACA;EACA;EACAU,cAAA;IACA,SAAA1B,YAAA;MACA,KAAAM,WAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}