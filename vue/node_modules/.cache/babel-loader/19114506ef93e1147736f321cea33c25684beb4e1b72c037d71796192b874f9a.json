{"ast":null,"code":"export default {\n  name: \"drone\",\n  created() {\n    this.load();\n  },\n  data() {\n    return {\n      drone: [],\n      form: {},\n      dialogFormVisible: false,\n      // 新增：列查询相关数据\n      queryForm: {\n        // 各列查询条件\n        id: \"\",\n        model: \"\",\n        status: \"\",\n        battery: \"\"\n      },\n      showQuery: {\n        // 控制各列查询框的显示/隐藏\n        id: false,\n        model: false,\n        status: false,\n        battery: false\n      }\n    };\n  },\n  methods: {\n    // 原有：保存\n    save() {\n      this.request.post(\"/drone/save\", this.form).then(res => {\n        if (res.data) {\n          this.$message.success(\"保存成功!\");\n          this.dialogFormVisible = false;\n          this.load();\n        }\n      });\n    },\n    // 原有：加载全部数据\n    load() {\n      this.request.get(\"/drone/getAllData\").then(res => {\n        this.drone = res.data;\n      });\n    },\n    // 新增：按列查询数据\n    loadByColumn() {\n      // 将查询条件传给后端（若后端支持多条件查询）\n      this.request.get(\"/drone/getByCondition\", {\n        params: this.queryForm\n      }).then(res => {\n        this.drone = res.data;\n      });\n    },\n    // 新增：切换列查询框的显示/隐藏\n    toggleQuery(column) {\n      this.showQuery[column] = !this.showQuery[column];\n    },\n    // 新增：重置列查询条件\n    resetQuery() {\n      this.queryForm = {\n        id: \"\",\n        model: \"\",\n        status: \"\",\n        battery: \"\"\n      };\n      this.load(); // 重置后加载全部数据\n    },\n    // 原有：编辑\n    handleEdit(row) {\n      this.dialogFormVisible = true;\n      this.form = row;\n    },\n    // 原有：行样式\n    tableRowClassName({\n      row,\n      rowIndex\n    }) {\n      if (rowIndex === 1) {\n        return 'warning-row';\n      } else if (rowIndex === 3) {\n        return 'success-row';\n      }\n      return '';\n    }\n  }\n};","map":{"version":3,"names":["name","created","load","data","drone","form","dialogFormVisible","queryForm","id","model","status","battery","showQuery","methods","save","request","post","then","res","$message","success","get","loadByColumn","params","toggleQuery","column","resetQuery","handleEdit","row","tableRowClassName","rowIndex"],"sources":["src/views/drone.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <!-- 新增：列内查询区域（默认隐藏，点击列标题图标显示） -->\r\n    <el-form inline style=\"margin-bottom: 15px; padding: 8px; background: #f8f9fa; border-radius: 4px;\">\r\n      <!-- 唯一标识列查询 -->\r\n      <el-form-item v-if=\"showQuery.id\" label=\"唯一标识：\">\r\n        <el-input v-model=\"queryForm.id\" placeholder=\"输入唯一标识\" style=\"width: 180px;\" />\r\n      </el-form-item>\r\n      <!-- 设备类型列查询 -->\r\n      <el-form-item v-if=\"showQuery.model\" label=\"设备类型：\">\r\n        <el-input v-model=\"queryForm.model\" placeholder=\"输入设备类型\" style=\"width: 180px;\" />\r\n      </el-form-item>\r\n      <!-- 设备状态列查询 -->\r\n      <el-form-item v-if=\"showQuery.status\" label=\"设备状态：\">\r\n        <el-select v-model=\"queryForm.status\" placeholder=\"选择设备状态\" style=\"width: 180px;\">\r\n          <el-option label=\"待命\" value=\"0\" />\r\n          <el-option label=\"飞行\" value=\"1\" />\r\n          <el-option label=\"维修\" value=\"2\" />\r\n        </el-select>\r\n      </el-form-item>\r\n      <!-- 电池电量列查询 -->\r\n      <el-form-item v-if=\"showQuery.battery\" label=\"电池电量：\">\r\n        <el-input v-model=\"queryForm.battery\" placeholder=\"输入电池电量\" style=\"width: 180px;\" />\r\n      </el-form-item>\r\n      <!-- 查询/重置按钮 -->\r\n      <el-form-item>\r\n        <el-button type=\"primary\" @click=\"loadByColumn\">查询</el-button>\r\n        <el-button @click=\"resetQuery\">重置</el-button>\r\n      </el-form-item>\r\n    </el-form>\r\n\r\n    <el-table\r\n        :data=\"drone\"\r\n        style=\"width: 100%\"\r\n        :row-class-name=\"tableRowClassName\">\r\n      <!-- 1. 唯一标识列：添加查询图标 -->\r\n      <el-table-column\r\n          prop=\"id\"\r\n          label=\"唯一标识（主键）\"\r\n          width=\"180\">\r\n        <template #header>\r\n          <span>\r\n            唯一标识（主键）\r\n            <i class=\"el-icon-search\" style=\"color: #4299E1; cursor: pointer;\" @click=\"toggleQuery('id')\"></i>\r\n          </span>\r\n        </template>\r\n      </el-table-column>\r\n      <!-- 2. 设备类型列：添加查询图标 -->\r\n      <el-table-column\r\n          prop=\"model\"\r\n          label=\"设备类型\"\r\n          width=\"180\">\r\n        <template #header>\r\n          <span>\r\n            设备类型\r\n            <i class=\"el-icon-search\" style=\"color: #4299E1; cursor: pointer;\" @click=\"toggleQuery('model')\"></i>\r\n          </span>\r\n        </template>\r\n      </el-table-column>\r\n      <!-- 3. 设备状态列：添加查询图标 -->\r\n      <el-table-column\r\n          prop=\"status\"\r\n          label=\"设备状态 (0 - 待命，1 - 飞行，2 - 维修)\"\r\n          width=\"180\">\r\n        <template #header>\r\n          <span>\r\n            设备状态 (0 - 待命，1 - 飞行，2 - 维修)\r\n            <i class=\"el-icon-search\" style=\"color: #4299E1; cursor: pointer;\" @click=\"toggleQuery('status')\"></i>\r\n          </span>\r\n        </template>\r\n      </el-table-column>\r\n      <!-- 4. 电池电量列：添加查询图标 -->\r\n      <el-table-column\r\n          prop=\"battery\"\r\n          label=\"电池电量\"\r\n          width=\"180\">\r\n        <template #header>\r\n          <span>\r\n            电池电量\r\n            <i class=\"el-icon-search\" style=\"color: #4299E1; cursor: pointer;\" @click=\"toggleQuery('battery')\"></i>\r\n          </span>\r\n        </template>\r\n      </el-table-column>\r\n      <!-- 原有列 -->\r\n      <el-table-column\r\n          prop=\"maxSpeed\"\r\n          label=\"最快飞行速度\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"maxFlightTime\"\r\n          label=\"最大续航时间（分钟）\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column label = \"操作\">\r\n        <template v-slot = \"scope\">\r\n          <el-button type = \"success\" @click = \"handleEdit(scope.row)\"> 编辑 <<i class = \"el-icon-edit\"></i></el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n\r\n    <!-- 编辑弹窗（原有） -->\r\n    <el-dialog title=\"设备信息\" :visible.sync=\"dialogFormVisible\" width=\"30%\">\r\n      <el-form label-width=\"80px\" size=\"small\">\r\n        <el-form-item label=\"设备状态\" >\r\n          <el-input v-model=\"form.status\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"电池电量\" >\r\n          <el-input v-model=\"form.battery\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"设备类型\" >\r\n          <el-input v-model=\"form.model\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"drone\",\r\n  created() {\r\n    this.load()\r\n  },\r\n  data() {\r\n    return {\r\n      drone: [],\r\n      form: {},\r\n      dialogFormVisible: false,\r\n      // 新增：列查询相关数据\r\n      queryForm: { // 各列查询条件\r\n        id: \"\",\r\n        model: \"\",\r\n        status: \"\",\r\n        battery: \"\"\r\n      },\r\n      showQuery: { // 控制各列查询框的显示/隐藏\r\n        id: false,\r\n        model: false,\r\n        status: false,\r\n        battery: false\r\n      }\r\n    }\r\n  },\r\n  methods: {\r\n    // 原有：保存\r\n    save() {\r\n      this.request.post(\"/drone/save\", this.form).then(res => {\r\n        if (res.data) {\r\n          this.$message.success(\"保存成功!\")\r\n          this.dialogFormVisible = false\r\n          this.load()\r\n        }\r\n      })\r\n    },\r\n    // 原有：加载全部数据\r\n    load() {\r\n      this.request.get(\"/drone/getAllData\").then(res => {\r\n        this.drone = res.data\r\n      })\r\n    },\r\n    // 新增：按列查询数据\r\n    loadByColumn() {\r\n      // 将查询条件传给后端（若后端支持多条件查询）\r\n      this.request.get(\"/drone/getByCondition\", {\r\n        params: this.queryForm\r\n      }).then(res => {\r\n        this.drone = res.data\r\n      })\r\n    },\r\n    // 新增：切换列查询框的显示/隐藏\r\n    toggleQuery(column) {\r\n      this.showQuery[column] = !this.showQuery[column]\r\n    },\r\n    // 新增：重置列查询条件\r\n    resetQuery() {\r\n      this.queryForm = {\r\n        id: \"\",\r\n        model: \"\",\r\n        status: \"\",\r\n        battery: \"\"\r\n      }\r\n      this.load() // 重置后加载全部数据\r\n    },\r\n    // 原有：编辑\r\n    handleEdit(row) {\r\n      this.dialogFormVisible = true\r\n      this.form = row\r\n    },\r\n    // 原有：行样式\r\n    tableRowClassName({ row, rowIndex }) {\r\n      if (rowIndex === 1) {\r\n        return 'warning-row';\r\n      } else if (rowIndex === 3) {\r\n        return 'success-row';\r\n      }\r\n      return '';\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 列查询区域样式优化 */\r\n.el-form-item {\r\n  margin-bottom: 10px !important;\r\n}\r\n</style>"],"mappings":"AA2HA;EACAA,IAAA;EACAC,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,KAAA;IACA;MACAC,KAAA;MACAC,IAAA;MACAC,iBAAA;MACA;MACAC,SAAA;QAAA;QACAC,EAAA;QACAC,KAAA;QACAC,MAAA;QACAC,OAAA;MACA;MACAC,SAAA;QAAA;QACAJ,EAAA;QACAC,KAAA;QACAC,MAAA;QACAC,OAAA;MACA;IACA;EACA;EACAE,OAAA;IACA;IACAC,KAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,qBAAAX,IAAA,EAAAY,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAf,IAAA;UACA,KAAAgB,QAAA,CAAAC,OAAA;UACA,KAAAd,iBAAA;UACA,KAAAJ,IAAA;QACA;MACA;IACA;IACA;IACAA,KAAA;MACA,KAAAa,OAAA,CAAAM,GAAA,sBAAAJ,IAAA,CAAAC,GAAA;QACA,KAAAd,KAAA,GAAAc,GAAA,CAAAf,IAAA;MACA;IACA;IACA;IACAmB,aAAA;MACA;MACA,KAAAP,OAAA,CAAAM,GAAA;QACAE,MAAA,OAAAhB;MACA,GAAAU,IAAA,CAAAC,GAAA;QACA,KAAAd,KAAA,GAAAc,GAAA,CAAAf,IAAA;MACA;IACA;IACA;IACAqB,YAAAC,MAAA;MACA,KAAAb,SAAA,CAAAa,MAAA,UAAAb,SAAA,CAAAa,MAAA;IACA;IACA;IACAC,WAAA;MACA,KAAAnB,SAAA;QACAC,EAAA;QACAC,KAAA;QACAC,MAAA;QACAC,OAAA;MACA;MACA,KAAAT,IAAA;IACA;IACA;IACAyB,WAAAC,GAAA;MACA,KAAAtB,iBAAA;MACA,KAAAD,IAAA,GAAAuB,GAAA;IACA;IACA;IACAC,kBAAA;MAAAD,GAAA;MAAAE;IAAA;MACA,IAAAA,QAAA;QACA;MACA,WAAAA,QAAA;QACA;MACA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}