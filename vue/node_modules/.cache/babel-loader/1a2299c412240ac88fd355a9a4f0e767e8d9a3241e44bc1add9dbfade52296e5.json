{"ast":null,"code":"export default {\n  name: \"drone\",\n  created() {\n    this.load();\n  },\n  methods: {\n    save() {\n      this.request.post(\"/drone/save\", this.form).then(res => {\n        if (res.data) {\n          this.$message.success(\"保存成功!\");\n          this.dialogFormVisible = false;\n          this.load();\n        }\n      });\n    },\n    load() {\n      this.request.get(\"/drone/getAllData\", {\n        params: {\n          queryKey: this.queryKey\n        } // 把查询关键词传给后端\n      }).then(res => {\n        this.drone = res.data;\n      });\n    },\n    handleEdit(row) {\n      this.dialogFormVisible = true;\n      this.form = row;\n    },\n    tableRowClassName({\n      row,\n      rowIndex\n    }) {\n      if (rowIndex === 1) {\n        return 'warning-row';\n      } else if (rowIndex === 3) {\n        return 'success-row';\n      }\n      return '';\n    }\n  },\n  data() {\n    return {\n      drone: [],\n      form: {},\n      dialogFormVisible: false,\n      queryKey: \"\" // 新增：存储查询关键词\n    };\n  }\n};","map":{"version":3,"names":["name","created","load","methods","save","request","post","form","then","res","data","$message","success","dialogFormVisible","get","params","queryKey","drone","handleEdit","row","tableRowClassName","rowIndex"],"sources":["src/views/drone.vue"],"sourcesContent":["<script>\r\nexport default {\r\n  name: \"drone\",\r\n  created() {\r\n    this.load()\r\n  },\r\n  methods: {\r\n    save(){\r\n      this.request.post(\"/drone/save\", this.form).then(res=>{\r\n        if (res.data){\r\n          this.$message.success(\"保存成功!\")\r\n          this.dialogFormVisible = false\r\n          this.load()\r\n        }\r\n      })\r\n    },\r\n    load(){\r\n      this.request.get(\"/drone/getAllData\", {\r\n            params: { queryKey: this.queryKey } // 把查询关键词传给后端\r\n          }).then(res=>{\r\n        this.drone = res.data\r\n      })\r\n    },\r\n    handleEdit(row){\r\n      this.dialogFormVisible = true\r\n      this.form = row\r\n    },\r\n\r\n    tableRowClassName({row, rowIndex}) {\r\n      if (rowIndex === 1) {\r\n        return 'warning-row';\r\n      } else if (rowIndex === 3) {\r\n        return 'success-row';\r\n      }\r\n      return '';\r\n    }\r\n  },\r\n  data() {\r\n    return {\r\n      drone: [],\r\n      form:{},\r\n      dialogFormVisible:false,\r\n      queryKey: \"\" // 新增：存储查询关键词\r\n    }\r\n  }\r\n}\r\n\r\n</script>\r\n\r\n<template>\r\n  <div>\r\n    <!-- 新增：查询区域 -->\r\n    <el-form inline style=\"margin-bottom: 15px;\">\r\n      <el-form-item label=\"快速查询\">\r\n        <el-input\r\n            v-model=\"queryKey\"\r\n            placeholder=\"输入查询信息\"\r\n            style=\"width: 220px;\"\r\n        ></el-input>\r\n      </el-form-item>\r\n      <el-form-item>\r\n        <el-button type=\"primary\" @click=\"load\">查询</el-button>\r\n      </el-form-item>\r\n    </el-form>\r\n    <el-dialog title=\"设备信息\" :visible.sync=\"dialogFormVisible\" width=\"30%\">\r\n      <el-form label-width=\"80px\" size=\"small\">\r\n        <el-form-item label=\"设备状态\" >\r\n          <el-input v-model=\"form.status\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"电池电量\" >\r\n          <el-input v-model=\"form.battery\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"设备类型\" >\r\n          <el-input v-model=\"form.model\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <el-table\r\n        :data=\"drone\"\r\n        style=\"width: 100%\"\r\n        :row-class-name=\"tableRowClassName\">\r\n      <el-table-column\r\n          prop=\"id\"\r\n          label=\"唯一标识（主键）\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"model\"\r\n          label=\"设备类型\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"status\"\r\n          label=\"设备状态 (0 - 待命，1 - 飞行，2 - 维修)\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"battery\"\r\n          label=\"电池电量\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"maxSpeed\"\r\n          label=\"最快飞行速度\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"maxFlightTime\"\r\n          label=\"最大续航时间（分钟）\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column label = \"操作\">\r\n        <template v-slot = \"scope\">\r\n          <el-button type = \"success\" @click = \"handleEdit(scope.row)\"> 编辑 <i class = \"el-icon-edit\"></i></el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":"AACA;EACAA,IAAA;EACAC,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACAC,KAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,qBAAAC,IAAA,EAAAC,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAC,IAAA;UACA,KAAAC,QAAA,CAAAC,OAAA;UACA,KAAAC,iBAAA;UACA,KAAAX,IAAA;QACA;MACA;IACA;IACAA,KAAA;MACA,KAAAG,OAAA,CAAAS,GAAA;QACAC,MAAA;UAAAC,QAAA,OAAAA;QAAA;MACA,GAAAR,IAAA,CAAAC,GAAA;QACA,KAAAQ,KAAA,GAAAR,GAAA,CAAAC,IAAA;MACA;IACA;IACAQ,WAAAC,GAAA;MACA,KAAAN,iBAAA;MACA,KAAAN,IAAA,GAAAY,GAAA;IACA;IAEAC,kBAAA;MAAAD,GAAA;MAAAE;IAAA;MACA,IAAAA,QAAA;QACA;MACA,WAAAA,QAAA;QACA;MACA;MACA;IACA;EACA;EACAX,KAAA;IACA;MACAO,KAAA;MACAV,IAAA;MACAM,iBAAA;MACAG,QAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}