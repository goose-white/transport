{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      currentTime: \"\"\n    };\n  },\n  methods: {\n    // 实时更新时间\n    updateTime() {\n      const date = new Date();\n      const year = date.getFullYear();\n      const month = String(date.getMonth() + 1).padStart(2, '0');\n      const day = String(date.getDate()).padStart(2, '0');\n      const hour = String(date.getHours()).padStart(2, '0');\n      const minute = String(date.getMinutes()).padStart(2, '0');\n      const second = String(date.getSeconds()).padStart(2, '0');\n      const weekArr = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];\n      const week = weekArr[date.getDay()];\n      this.currentTime = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\n    },\n    // 初始化图表\n    initCharts() {\n      const taskData = [30, 37, 33, 42];\n      const errorData = [3, 2, 4, 1];\n      const weeks = ['12月第1周', '12月第2周', '12月第3周', '12月第4周'];\n\n      // 执行任务数柱状图\n      const barChart = echarts.init(document.getElementById('bar'));\n      barChart.setOption({\n        title: {\n          text: '12月各周无人机执行任务数',\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        xAxis: {\n          type: 'category',\n          data: weeks,\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: '任务数（次）',\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              type: 'dashed',\n              color: '#eee'\n            }\n          }\n        },\n        series: [{\n          name: '执行任务数',\n          data: taskData,\n          type: 'bar',\n          itemStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n              offset: 0,\n              color: '#4299E1'\n            }, {\n              offset: 1,\n              color: '#2B6CB0'\n            }])\n          }\n        }]\n      });\n\n      // 异常次数折线图\n      const lineChart = echarts.init(document.getElementById('line'));\n      lineChart.setOption({\n        title: {\n          text: '12月各周无人机异常次数',\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        xAxis: {\n          type: 'category',\n          data: weeks,\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: '次数（次）',\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              type: 'dashed',\n              color: '#eee'\n            }\n          }\n        },\n        series: [{\n          name: '异常次数',\n          data: errorData,\n          type: 'line',\n          smooth: true,\n          lineStyle: {\n            width: 3,\n            color: '#4299E1'\n          },\n          areaStyle: {\n            color: 'rgba(66, 153, 225, 0.1)'\n          }\n        }]\n      });\n\n      // 窗口自适应\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n      });\n    },\n    // 退出登录\n    logout() {\n      localStorage.removeItem('token');\n      alert('已退出登录');\n    }\n  },\n  mounted() {\n    // 启动时间更新\n    this.updateTime();\n    setInterval(() => this.updateTime(), 1000);\n    // 初始化图表\n    this.initCharts();\n  }\n};","map":{"version":3,"names":["echarts","name","data","currentTime","methods","updateTime","date","Date","year","getFullYear","month","String","getMonth","padStart","day","getDate","hour","getHours","minute","getMinutes","second","getSeconds","weekArr","week","getDay","initCharts","taskData","errorData","weeks","barChart","init","document","getElementById","setOption","title","text","textStyle","fontSize","xAxis","type","axisLine","lineStyle","color","yAxis","splitLine","series","itemStyle","graphic","LinearGradient","offset","lineChart","smooth","width","areaStyle","window","addEventListener","resize","logout","localStorage","removeItem","alert","mounted","setInterval"],"sources":["src/views/Home.vue"],"sourcesContent":["<template>\n  <!-- 唯一根容器 -->\n  <div id=\"app-container\">\n    <!-- 顶部主导航栏（仅保留这一个导航） -->\n    <div style=\"background: #2D2D2D; color: #fff; padding: 0 20px; height: 60px; line-height: 60px; display: flex; justify-content: space-between; align-items: center;\">\n      <!-- 系统名称 -->\n      <div>\n        <span style=\"font-size: 18px; font-weight: 800; color: #4299E1;\">无人机管理系统</span>\n        <span style=\"font-size: 12px; margin-left: 10px; color: #90CDF4; display: block; margin-top: -5px;\">Drone Management System</span>\n      </div>\n\n      <!-- 右侧功能区 -->\n      <div style=\"display: flex; align-items: center; gap: 20px;\">\n        <!-- 通知图标（带角标） -->\n        <div style=\"position: relative; cursor: pointer;\">\n          <i class=\"el-icon-bell\" style=\"font-size: 18px;\"></i>\n          <span style=\"position: absolute; top: -5px; right: -8px; background: #F56C6C; color: #fff; font-size: 12px; width: 18px; height: 18px; line-height: 18px; text-align: center; border-radius: 50%;\">3</span>\n        </div>\n\n        <!-- 搜索框 -->\n        <el-input placeholder=\"请输入搜索内容\" style=\"width: 200px; background: rgba(255,255,255,0.1); border: none; color: #fff;\" prefix-icon=\"el-icon-search\"></el-input>\n\n        <!-- 实时时间（日期+时分秒） -->\n        <span style=\"font-size: 14px;\">{{ currentTime }}</span>\n\n        <!-- 退出登录 -->\n        <div style=\"cursor: pointer; display: flex; align-items: center; gap: 5px;\" @click=\"logout\">\n          <<i class=\"el-icon-switch-button\"></i>\n          <span>退出登录</span>\n        </div>\n\n        <!-- 人员信息（悬浮显示详情） -->\n        <el-tooltip\n            effect=\"dark\"\n            placement=\"bottom\"\n            :content=\"`电话号码：13800001234\n工号：20230001\n性别：男`\"\n            class=\"user-tooltip\"\n        >\n          <div style=\"display: flex; align-items: center; gap: 8px; cursor: pointer;\">\n            <el-avatar icon=\"el-icon-user\" size=\"medium\" style=\"background: #4299E1; color: #fff;\"></el-avatar>\n            <span>贾舒凯</span>\n          </div>\n        </el-tooltip>\n      </div>\n    </div>\n\n    <!-- 主内容区（侧边栏+数据展示） -->\n    <div style=\"display: flex;\">\n      <!-- 侧边栏 -->\n      <div style=\"width: 180px; background: #33393B; color: #fff; min-height: calc(100vh - 60px); padding-top: 20px;\">\n        <div style=\"padding: 10px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px; color: #4299E1;\">\n          <i class=\"el-icon-menu\"></i>\n          <span>主页</span>\n        </div>\n        <div style=\"padding: 10px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px;\">\n          <i class=\"el-icon-setting\"></i>\n          <span>系统管理</span>\n        </div>\n        <div style=\"padding: 10px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px;\">\n          <i class=\"el-icon-document\"></i>\n          <span>记录管理</span>\n        </div>\n      </div>\n\n      <!-- 内容展示区 -->\n      <div style=\"flex: 1; padding: 20px; background: #fff; min-height: calc(100vh - 60px);\">\n        <!-- 数据卡片 -->\n        <el-row :gutter=\"10\" style=\"margin-bottom: 20px;\">\n          <el-col :span=\"6\">\n            <el-card style=\"color: #fff; height: 100px; background-image: linear-gradient(to bottom right,#401EFF,#2c44bd); border-radius: 8px; overflow: hidden;\">\n              <div><<i class=\"el-icon-s-data\" /> 执勤无人机</div>\n              <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">5</div>\n            </el-card>\n          </el-col>\n          <el-col :span=\"6\">\n            <el-card style=\"color: #fff; height: 100px; background-image: linear-gradient(to bottom right,#67C21A,#204e09); border-radius: 8px; overflow: hidden;\">\n              <div><<i class=\"el-icon-success\" /> 待办任务</div>\n              <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">57</div>\n            </el-card>\n          </el-col>\n          <el-col :span=\"6\">\n            <el-card style=\"color: #fff; height: 100px; background-image: linear-gradient(to bottom right,#901669,#424997); border-radius: 8px; overflow: hidden;\">\n              <div><<i class=\"el-icon-remove\" /> 日志记录</div>\n              <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">1000</div>\n            </el-card>\n          </el-col>\n          <el-col :span=\"6\">\n            <el-card style=\"color: #fff; height: 100px; background-image: linear-gradient(to bottom right,#F16C6C,#751111); border-radius: 8px; overflow: hidden;\">\n              <div><<i class=\"el-icon-warning\" /> 异常运行无人机</div>\n              <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">2</div>\n            </el-card>\n          </el-col>\n        </el-row>\n\n        <!-- 图表区域 -->\n        <el-row :gutter=\"20\">\n          <el-col :span=\"12\">\n            <div id=\"bar\" style=\"width: 100%; height: 300px;\"></div>\n          </el-col>\n          <el-col :span=\"12\">\n            <div id=\"line\" style=\"width: 100%; height: 300px;\"></div>\n          </el-col>\n        </el-row>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\n\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      currentTime: \"\"\n    }\n  },\n  methods: {\n    // 实时更新时间\n    updateTime() {\n      const date = new Date()\n      const year = date.getFullYear()\n      const month = String(date.getMonth() + 1).padStart(2, '0')\n      const day = String(date.getDate()).padStart(2, '0')\n      const hour = String(date.getHours()).padStart(2, '0')\n      const minute = String(date.getMinutes()).padStart(2, '0')\n      const second = String(date.getSeconds()).padStart(2, '0')\n      const weekArr = ['周日', '周一', '周二', '周三', '周四', '周五', '周六']\n      const week = weekArr[date.getDay()]\n      this.currentTime = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`\n    },\n\n    // 初始化图表\n    initCharts() {\n      const taskData = [30, 37, 33, 42];\n      const errorData = [3, 2, 4, 1];\n      const weeks = ['12月第1周', '12月第2周', '12月第3周', '12月第4周'];\n\n      // 执行任务数柱状图\n      const barChart = echarts.init(document.getElementById('bar'));\n      barChart.setOption({\n        title: { text: '12月各周无人机执行任务数', textStyle: { fontSize: 16 } },\n        xAxis: { type: 'category', data: weeks, axisLine: { lineStyle: { color: '#999' } } },\n        yAxis: { type: 'value', name: '任务数（次）', axisLine: { lineStyle: { color: '#999' } }, splitLine: { lineStyle: { type: 'dashed', color: '#eee' } } },\n        series: [{\n          name: '执行任务数',\n          data: taskData,\n          type: 'bar',\n          itemStyle: { color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{ offset: 0, color: '#4299E1' }, { offset: 1, color: '#2B6CB0' }]) }\n        }]\n      });\n\n      // 异常次数折线图\n      const lineChart = echarts.init(document.getElementById('line'));\n      lineChart.setOption({\n        title: { text: '12月各周无人机异常次数', textStyle: { fontSize: 16 } },\n        xAxis: { type: 'category', data: weeks, axisLine: { lineStyle: { color: '#999' } } },\n        yAxis: { type: 'value', name: '次数（次）', axisLine: { lineStyle: { color: '#999' } }, splitLine: { lineStyle: { type: 'dashed', color: '#eee' } } },\n        series: [{\n          name: '异常次数',\n          data: errorData,\n          type: 'line',\n          smooth: true,\n          lineStyle: { width: 3, color: '#4299E1' },\n          areaStyle: { color: 'rgba(66, 153, 225, 0.1)' }\n        }]\n      });\n\n      // 窗口自适应\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n      });\n    },\n\n    // 退出登录\n    logout() {\n      localStorage.removeItem('token');\n      alert('已退出登录');\n    }\n  },\n  mounted() {\n    // 启动时间更新\n    this.updateTime();\n    setInterval(() => this.updateTime(), 1000);\n    // 初始化图表\n    this.initCharts();\n  }\n}\n</script>\n\n<style scoped>\n#app-container {\n  width: 100%;\n  height: 100%;\n  overflow: hidden;\n}\n\n/* 悬浮框换行样式 */\n::v-deep .user-tooltip .el-tooltip__popper {\n  white-space: pre-line !important;\n  padding: 10px;\n}\n\n/* 图表容器 */\n#bar, #line {\n  width: 100% !important;\n  height: 300px !important;\n}\n</style>"],"mappings":"AA+GA,YAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,WAAA;IACA;EACA;EACAC,OAAA;IACA;IACAC,WAAA;MACA,MAAAC,IAAA,OAAAC,IAAA;MACA,MAAAC,IAAA,GAAAF,IAAA,CAAAG,WAAA;MACA,MAAAC,KAAA,GAAAC,MAAA,CAAAL,IAAA,CAAAM,QAAA,QAAAC,QAAA;MACA,MAAAC,GAAA,GAAAH,MAAA,CAAAL,IAAA,CAAAS,OAAA,IAAAF,QAAA;MACA,MAAAG,IAAA,GAAAL,MAAA,CAAAL,IAAA,CAAAW,QAAA,IAAAJ,QAAA;MACA,MAAAK,MAAA,GAAAP,MAAA,CAAAL,IAAA,CAAAa,UAAA,IAAAN,QAAA;MACA,MAAAO,MAAA,GAAAT,MAAA,CAAAL,IAAA,CAAAe,UAAA,IAAAR,QAAA;MACA,MAAAS,OAAA;MACA,MAAAC,IAAA,GAAAD,OAAA,CAAAhB,IAAA,CAAAkB,MAAA;MACA,KAAArB,WAAA,MAAAK,IAAA,IAAAE,KAAA,IAAAI,GAAA,IAAAS,IAAA,IAAAP,IAAA,IAAAE,MAAA,IAAAE,MAAA;IACA;IAEA;IACAK,WAAA;MACA,MAAAC,QAAA;MACA,MAAAC,SAAA;MACA,MAAAC,KAAA;;MAEA;MACA,MAAAC,QAAA,GAAA7B,OAAA,CAAA8B,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACAH,QAAA,CAAAI,SAAA;QACAC,KAAA;UAAAC,IAAA;UAAAC,SAAA;YAAAC,QAAA;UAAA;QAAA;QACAC,KAAA;UAAAC,IAAA;UAAArC,IAAA,EAAA0B,KAAA;UAAAY,QAAA;YAAAC,SAAA;cAAAC,KAAA;YAAA;UAAA;QAAA;QACAC,KAAA;UAAAJ,IAAA;UAAAtC,IAAA;UAAAuC,QAAA;YAAAC,SAAA;cAAAC,KAAA;YAAA;UAAA;UAAAE,SAAA;YAAAH,SAAA;cAAAF,IAAA;cAAAG,KAAA;YAAA;UAAA;QAAA;QACAG,MAAA;UACA5C,IAAA;UACAC,IAAA,EAAAwB,QAAA;UACAa,IAAA;UACAO,SAAA;YAAAJ,KAAA,MAAA1C,OAAA,CAAA+C,OAAA,CAAAC,cAAA;cAAAC,MAAA;cAAAP,KAAA;YAAA;cAAAO,MAAA;cAAAP,KAAA;YAAA;UAAA;QACA;MACA;;MAEA;MACA,MAAAQ,SAAA,GAAAlD,OAAA,CAAA8B,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACAkB,SAAA,CAAAjB,SAAA;QACAC,KAAA;UAAAC,IAAA;UAAAC,SAAA;YAAAC,QAAA;UAAA;QAAA;Q