{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport Aside from \"@/components/Aside\";\nexport default {\n  components: {\n    Aside\n  },\n  data() {\n    return {\n      isCollapse: false,\n      sideWidth: 300,\n      logoTextShow: true\n    };\n  },\n  methods: {\n    collapse() {\n      this.isCollapse = !this.isCollapse;\n      this.sideWidth = this.isCollapse ? 64 : 300;\n      this.logoTextShow = !this.isCollapse;\n    },\n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    },\n    getCurrentDate() {\n      const date = new Date();\n      const year = date.getFullYear();\n      const month = (date.getMonth() + 1).toString().padStart(2, '0');\n      const day = date.getDate().toString().padStart(2, '0');\n      const week = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'][date.getDay()];\n      document.getElementById('current-date').innerText = `${year}-${month}-${day} ${week}`;\n    }\n  },\n  mounted() {\n    this.getCurrentDate();\n  }\n};","map":{"version":3,"names":["Aside","components","data","isCollapse","sideWidth","logoTextShow","methods","collapse","logout","localStorage","removeItem","$router","push","getCurrentDate","date","Date","year","getFullYear","month","getMonth","toString","padStart","day","getDate","week","getDay","document","getElementById","innerText","mounted"],"sources":["src/views/Manage.vue"],"sourcesContent":["<template>\r\n  <el-container style=\"min-height:100vh\">\r\n    <!-- 顶部标题栏：新增通知框 -->\r\n    <el-header style=\"\r\n      background-color: #2D2D2D;\r\n      padding: 0 20px;\r\n      height: auto;\r\n      min-height: 70px;\r\n      display: flex;\r\n      justify-content: space-between;\r\n      align-items: center;\r\n    \">\r\n      <!-- 左侧标题（原有） -->\r\n      <div style=\"display: block; text-align: left;\">\r\n        <div style=\"font-size: 22px; font-weight: 800; color: #4299E1;\">无人机管理系统</div>\r\n        <div style=\"font-size: 16px; font-weight: 500; margin-top: 4px; color: #90CDF4;\">Drone Management System</div>\r\n      </div>\r\n\r\n      <!-- 右侧：通知框 + 搜索框 + 日期 + 退出按钮 -->\r\n      <div style=\"display: flex; align-items: center; gap: 20px; color: #E2E8F0;\">\r\n        <!-- 新增：通知下拉框 -->\r\n        <el-dropdown placement=\"bottom-end\">\r\n          <span class=\"el-dropdown-link\" style=\"position: relative; cursor: pointer;\">\r\n            <<i class=\"el-icon-bell\" style=\"font-size: 18px;\"></i>\r\n            <!-- 未读数字角标 -->\r\n            <span style=\"\r\n              position: absolute;\r\n              top: -5px;\r\n              right: -8px;\r\n              background: #F56C6C;\r\n              color: #fff;\r\n              font-size: 12px;\r\n              width: 18px;\r\n              height: 18px;\r\n              line-height: 18px;\r\n              text-align: center;\r\n              border-radius: 50%;\r\n            \">0</span>\r\n          </span>\r\n          <!-- 通知下拉面板 -->\r\n          <el-dropdown-menu slot=\"dropdown\" style=\"width: 300px; padding: 10px;\">\r\n            <!-- 通知头部（标题+更多） -->\r\n            <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;\">\r\n              <span style=\"font-weight: bold;\">通知</span>\r\n              <el-button type=\"text\" size=\"mini\" style=\"color: #4299E1;\">更多</el-button>\r\n            </div>\r\n            <!-- 通知列表 -->\r\n            <el-dropdown-item style=\"padding: 10px 0; border-bottom: 1px solid #eee;\">\r\n              <div style=\"display: flex; align-items: center; gap: 10px;\">\r\n                <span style=\"background: #E6A23C; color: #fff; font-size: 12px; padding: 2px 6px; border-radius: 4px;\">通知</span>\r\n                <div>\r\n                  <div style=\"font-size: 14px;\">停开通知</div>\r\n                  <div style=\"font-size: 12px; color: #999;\">2025-02-24 08:37:11</div>\r\n                </div>\r\n              </div>\r\n            </el-dropdown-item>\r\n          </el-dropdown-menu>\r\n        </el-dropdown>\r\n\r\n        <!-- 原有：搜索框、日期、退出按钮 -->\r\n        <el-input\r\n            placeholder=\"请输入搜索内容\"\r\n            style=\"width: 200px; background: rgba(255,255,255,0.1); border: none; color: #E2E8F0;\"\r\n            prefix-icon=\"el-icon-search\"\r\n        ></el-input>\r\n        <span style=\"font-size: 14px;\" id=\"current-date\"></span>\r\n        <el-button\r\n            type=\"text\"\r\n            icon=\"el-icon-switch-button\"\r\n            style=\"color: #E2E8F0; font-size: 16px;\"\r\n            @click=\"logout\"\r\n        >\r\n          退出登录\r\n        </el-button>\r\n      </div>\r\n    </el-header>\r\n\r\n    <!-- 主体区域（原有） -->\r\n    <el-container>\r\n      <el-aside :width=\"sideWidth + 'px'\" style=\"background-color: #33393B; border-right: 1px solid #ccc;\">\r\n        <Aside :is-collapse=\"isCollapse\" :logoTextShow=\"logoTextShow\" />\r\n      </el-aside>\r\n      <el-container>\r\n        <el-main>\r\n          <router-view />\r\n        </el-main>\r\n      </el-container>\r\n    </el-container>\r\n  </el-container>\r\n</template>\r\n\r\n<script>\r\nimport Aside from \"@/components/Aside\";\r\n\r\nexport default {\r\n  components: { Aside },\r\n  data() {\r\n    return {\r\n      isCollapse: false,\r\n      sideWidth: 300,\r\n      logoTextShow: true\r\n    }\r\n  },\r\n  methods: {\r\n    collapse() {\r\n      this.isCollapse = !this.isCollapse\r\n      this.sideWidth = this.isCollapse ? 64 : 300\r\n      this.logoTextShow = !this.isCollapse\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      this.$router.push('/login')\r\n    },\r\n    getCurrentDate() {\r\n      const date = new Date()\r\n      const year = date.getFullYear()\r\n      const month = (date.getMonth() + 1).toString().padStart(2, '0')\r\n      const day = date.getDate().toString().padStart(2, '0')\r\n      const week = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'][date.getDay()]\r\n      document.getElementById('current-date').innerText = `${year}-${month}-${day} ${week}`\r\n    }\r\n  },\r\n  mounted() {\r\n    this.getCurrentDate()\r\n  }\r\n}\r\n</script>"],"mappings":";AA4FA,OAAAA,KAAA;AAEA;EACAC,UAAA;IAAAD;EAAA;EACAE,KAAA;IACA;MACAC,UAAA;MACAC,SAAA;MACAC,YAAA;IACA;EACA;EACAC,OAAA;IACAC,SAAA;MACA,KAAAJ,UAAA,SAAAA,UAAA;MACA,KAAAC,SAAA,QAAAD,UAAA;MACA,KAAAE,YAAA,SAAAF,UAAA;IACA;IACAK,OAAA;MACAC,YAAA,CAAAC,UAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;IACAC,eAAA;MACA,MAAAC,IAAA,OAAAC,IAAA;MACA,MAAAC,IAAA,GAAAF,IAAA,CAAAG,WAAA;MACA,MAAAC,KAAA,IAAAJ,IAAA,CAAAK,QAAA,QAAAC,QAAA,GAAAC,QAAA;MACA,MAAAC,GAAA,GAAAR,IAAA,CAAAS,OAAA,GAAAH,QAAA,GAAAC,QAAA;MACA,MAAAG,IAAA,8CAAAV,IAAA,CAAAW,MAAA;MACAC,QAAA,CAAAC,cAAA,iBAAAC,SAAA,MAAAZ,IAAA,IAAAE,KAAA,IAAAI,GAAA,IAAAE,IAAA;IACA;EACA;EACAK,QAAA;IACA,KAAAhB,cAAA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}