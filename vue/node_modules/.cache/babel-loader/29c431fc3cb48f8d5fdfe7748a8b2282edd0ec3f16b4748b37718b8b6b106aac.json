{"ast":null,"code":"import * as echarts from 'echarts';\nimport request from '@/utils/request';\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      // 系统配置模拟数据\n      config: {\n        systemName: \"无人机管理系统V1.0\",\n        inspectFreq: 30,\n        logRetention: 90,\n        maxHeight: 120,\n        maxBattery: 45,\n        alertThreshold: 5\n      }\n    };\n  },\n  methods: {\n    async initCharts() {\n      // 无人机业务模拟数据\n      const taskData = [85, 128, 96, 145];\n      const errorData = [12, 8, 15, 7];\n\n      // 柱状图（执行任务数）\n      const barChart = echarts.init(document.getElementById('bar'));\n      barChart.setOption({\n        title: {\n          text: '各季度无人机执行任务数',\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis'\n        },\n        xAxis: {\n          type: 'category',\n          data: ['第一季度', '第二季度', '第三季度', '第四季度'],\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: '任务数（次）',\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              type: 'dashed',\n              color: '#eee'\n            }\n          }\n        },\n        series: [{\n          name: '执行任务数',\n          data: taskData,\n          type: 'bar',\n          itemStyle: {\n            color: '#4299E1'\n          },\n          emphasis: {\n            itemStyle: {\n              color: '#2B6CB0'\n            }\n          }\n        }]\n      });\n\n      // 折线图（异常次数）\n      const lineChart = echarts.init(document.getElementById('line'));\n      lineChart.setOption({\n        title: {\n          text: '各季度无人机异常次数',\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis'\n        },\n        xAxis: {\n          type: 'category',\n          data: ['第一季度', '第二季度', '第三季度', '第四季度'],\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: '异常次数（次）',\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              type: 'dashed',\n              color: '#eee'\n            }\n          }\n        },\n        series: [{\n          name: '异常次数',\n          data: errorData,\n          type: 'line',\n          smooth: true,\n          lineStyle: {\n            color: '#4299E1'\n          },\n          areaStyle: {\n            color: 'rgba(66, 153, 225, 0.1)'\n          }\n        }]\n      });\n\n      // 窗口自适应\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n      });\n    }\n  },\n  mounted() {\n    this.initCharts();\n  }\n};","map":{"version":3,"names":["echarts","request","name","data","config","systemName","inspectFreq","logRetention","maxHeight","maxBattery","alertThreshold","methods","initCharts","taskData","errorData","barChart","init","document","getElementById","setOption","title","text","textStyle","fontSize","tooltip","trigger","xAxis","type","axisLine","lineStyle","color","yAxis","splitLine","series","itemStyle","emphasis","lineChart","smooth","areaStyle","window","addEventListener","resize","mounted"],"sources":["src/views/Home.vue"],"sourcesContent":["<template>\n  <div style=\"padding: 20px;\">\n    <!-- 顶部数据卡片（原有） -->\n    <el-row :gutter=\"10\" style=\"margin-bottom: 20px;\">\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container1\">\n          <div><<i class=\"el-icon-s-data\" /> 执勤无人机</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">5</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container2\">\n          <div><<i class=\"el-icon-success\" /> 待办任务</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">57</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container4\">\n          <div><<i class=\"el-icon-remove\" /> 日志记录</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">1000</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container3\">\n          <div><<i class=\"el-icon-warning\" /> 异常运行无人机</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">2</div>\n        </el-card>\n      </el-col>\n    </el-row>\n\n    <!-- 图表：改为上下布局（适配页面空间） -->\n    <el-row style=\"margin-bottom: 20px;\">\n      <el-col :span=\"24\">\n        <div id=\"bar\" style=\"width: 100%; height: 300px;\"></div>\n      </el-col>\n    </el-row>\n    <el-row style=\"margin-bottom: 20px;\">\n      <el-col :span=\"24\">\n        <div id=\"line\" style=\"width: 100%; height: 300px;\"></div>\n      </el-col>\n    </el-row>\n\n    <!-- 新增：无人机系统配置模块（仿照示例样式） -->\n    <el-row>\n      <el-col :span=\"24\">\n        <el-card style=\"border-radius: 8px;\">\n          <div style=\"font-size: 16px; font-weight: bold; margin-bottom: 15px;\">无人机系统配置</div>\n\n          <!-- 基础配置 -->\n          <el-form label-width=\"120px\" size=\"small\">\n            <el-form-item label=\"系统名称\">\n              <el-input v-model=\"config.systemName\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"巡检频率\">\n              <el-input v-model=\"config.inspectFreq\" suffix=\"分钟\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"日志保留天数\">\n              <el-input v-model=\"config.logRetention\" suffix=\"天\" style=\"width: 300px;\" />\n            </el-form-item>\n          </el-form>\n\n          <!-- 无人机参数配置 -->\n          <div style=\"font-size: 14px; font-weight: bold; margin: 15px 0 10px;\">无人机参数</div>\n          <el-form label-width=\"120px\" size=\"small\">\n            <el-form-item label=\"最大飞行高度\">\n              <el-input v-model=\"config.maxHeight\" suffix=\"米\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"单次续航时长\">\n              <el-input v-model=\"config.maxBattery\" suffix=\"分钟\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"异常预警阈值\">\n              <el-input v-model=\"config.alertThreshold\" suffix=\"次/小时\" style=\"width: 300px;\" />\n            </el-form-item>\n          </el-form>\n\n          <!-- 操作按钮 -->\n          <div style=\"margin-top: 20px;\">\n            <el-button type=\"primary\" icon=\"el-icon-check\">保存配置</el-button>\n            <el-button type=\"default\" icon=\"el-icon-refresh\" style=\"margin-left: 10px;\">重置</el-button>\n            <el-button type=\"default\" icon=\"el-icon-upload\" style=\"margin-left: 10px;\">导入配置</el-button>\n            <el-button type=\"default\" icon=\"el-icon-download\" style=\"margin-left: 10px;\">导出配置</el-button>\n          </div>\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\nimport request from '@/utils/request'\n\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      // 系统配置模拟数据\n      config: {\n        systemName: \"无人机管理系统V1.0\",\n        inspectFreq: 30,\n        logRetention: 90,\n        maxHeight: 120,\n        maxBattery: 45,\n        alertThreshold: 5\n      }\n    }\n  },\n  methods: {\n    async initCharts() {\n      // 无人机业务模拟数据\n      const taskData = [85, 128, 96, 145];\n      const errorData = [12, 8, 15, 7];\n\n      // 柱状图（执行任务数）\n      const barChart = echarts.init(document.getElementById('bar'));\n      barChart.setOption({\n        title: { text: '各季度无人机执行任务数', textStyle: { fontSize: 16 } },\n        tooltip: { trigger: 'axis' },\n        xAxis: {\n          type: 'category',\n          data: ['第一季度', '第二季度', '第三季度', '第四季度'],\n          axisLine: { lineStyle: { color: '#999' } }\n        },\n        yAxis: {\n          type: 'value',\n          name: '任务数（次）',\n          axisLine: { lineStyle: { color: '#999' } },\n          splitLine: { lineStyle: { type: 'dashed', color: '#eee' } }\n        },\n        series: [{\n          name: '执行任务数',\n          data: taskData,\n          type: 'bar',\n          itemStyle: { color: '#4299E1' },\n          emphasis: { itemStyle: { color: '#2B6CB0' } }\n        }]\n      });\n\n      // 折线图（异常次数）\n      const lineChart = echarts.init(document.getElementById('line'));\n      lineChart.setOption({\n        title: { text: '各季度无人机异常次数', textStyle: { fontSize: 16 } },\n        tooltip: { trigger: 'axis' },\n        xAxis: {\n          type: 'category',\n          data: ['第一季度', '第二季度', '第三季度', '第四季度'],\n          axisLine: { lineStyle: { color: '#999' } }\n        },\n        yAxis: {\n          type: 'value',\n          name: '异常次数（次）',\n          axisLine: { lineStyle: { color: '#999' } },\n          splitLine: { lineStyle: { type: 'dashed', color: '#eee' } }\n        },\n        series: [{\n          name: '异常次数',\n          data: errorData,\n          type: 'line',\n          smooth: true,\n          lineStyle: { color: '#4299E1' },\n          areaStyle: { color: 'rgba(66, 153, 225, 0.1)' }\n        }]\n      });\n\n      // 窗口自适应\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n      });\n    }\n  },\n  mounted() {\n    this.initCharts();\n  }\n}\n</script>\n\n<style scoped>\n/* 卡片样式（原有） */\n.card-container1 {\n  background-image: linear-gradient(to bottom right,#401EFF,#2c44bd);\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container2 {\n  background-image: linear-gradient(to bottom right,#67C21A,#204e09);\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container4 {\n  background-image: linear-gradient(to bottom right,#901669,#424997);\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container3 {\n  background-image: linear-gradient(to bottom right,#F16C6C,#751111);\n  border-radius: 8px;\n  overflow: hidden;\n}\n\n/* 表单样式优化 */\n.el-form-item {\n  margin-bottom: 10px;\n}\n</style>"],"mappings":"AAyFA,YAAAA,OAAA;AACA,OAAAC,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACA;MACAC,MAAA;QACAC,UAAA;QACAC,WAAA;QACAC,YAAA;QACAC,SAAA;QACAC,UAAA;QACAC,cAAA;MACA;IACA;EACA;EACAC,OAAA;IACA,MAAAC,WAAA;MACA;MACA,MAAAC,QAAA;MACA,MAAAC,SAAA;;MAEA;MACA,MAAAC,QAAA,GAAAf,OAAA,CAAAgB,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACAH,QAAA,CAAAI,SAAA;QACAC,KAAA;UAAAC,IAAA;UAAAC,SAAA;YAAAC,QAAA;UAAA;QAAA;QACAC,OAAA;UAAAC,OAAA;QAAA;QACAC,KAAA;UACAC,IAAA;UACAxB,IAAA;UACAyB,QAAA;YAAAC,SAAA;cAAAC,KAAA;YAAA;UAAA;QACA;QACAC,KAAA;UACAJ,IAAA;UACAzB,IAAA;UACA0B,QAAA;YAAAC,SAAA;cAAAC,KAAA;YAAA;UAAA;UACAE,SAAA;YAAAH,SAAA;cAAAF,IAAA;cAAAG,KAAA;YAAA;UAAA;QACA;QACAG,MAAA;UACA/B,IAAA;UACAC,IAAA,EAAAU,QAAA;UACAc,IAAA;UACAO,SAAA;YAAAJ,KAAA;UAAA;UACAK,QAAA;YAAAD,SAAA;cAAAJ,KAAA;YAAA;UAAA;QACA;MACA;;MAEA;MACA,MAAAM,SAAA,GAAApC,OAAA,CAAAgB,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACAkB,SAAA,CAAAjB,SAAA;QACAC,KAAA;UAAAC,IAAA;UAAAC,SAAA;YAAAC,QAAA;UAAA;QAAA;QACAC,OAAA;UAAAC,OAAA;QAAA;QACAC,KAAA;UACAC,IAAA;UACAxB,IAAA;UACAyB,QAAA;YAAAC,SAAA;cAAAC,KAAA;YAAA;UAAA;QACA;QACAC,KAAA;UACAJ,IAAA;UACAzB,IAAA;UACA0B,QAAA;YAAAC,SAAA;cAAAC,KAAA;YAAA;UAAA;UACAE,SAAA;YAAAH,SAAA;cAAAF,IAAA;cAAAG,KAAA;YAAA;UAAA;QACA;QACAG,MAAA;UACA/B,IAAA;UACAC,IAAA,EAAAW,SAAA;UACAa,IAAA;UACAU,MAAA;UACAR,SAAA;YAAAC,KAAA;UAAA;UACAQ,SAAA;YAAAR,KAAA;UAAA;QACA;MACA;;MAEA;MACAS,MAAA,CAAAC,gBAAA;QACAzB,QAAA,CAAA0B,MAAA;QACAL,SAAA,CAAAK,MAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAA9B,UAAA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}