{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"Login\",\n  data() {\n    return {\n      activeTab: \"login\",\n      // 默认显示登录\n      loginForm: {\n        username: \"\",\n        password: \"\"\n      },\n      registerForm: {\n        username: \"\",\n        password: \"\",\n        confirmPassword: \"\"\n      }\n    };\n  },\n  methods: {\n    // 重置表单\n    resetForm() {\n      if (this.activeTab === \"login\") {\n        this.$refs.loginForm?.resetFields();\n      } else {\n        this.$refs.registerForm?.resetFields();\n      }\n    },\n    // 登录\n    handleLogin() {\n      this.request.post(\"/user/login\", this.loginForm).then(res => {\n        if (res.data.token) {\n          // 存储token\n          localStorage.setItem(\"token\", res.data.token);\n          // 跳转主页\n          this.$router.push(\"/home\");\n          this.$message.success(\"登录成功！\");\n        } else {\n          this.$message.error(\"账号或密码错误！\");\n        }\n      }).catch(() => {\n        this.$message.error(\"登录失败，请重试！\");\n      });\n    },\n    // 注册\n    handleRegister() {\n      if (this.registerForm.password !== this.registerForm.confirmPassword) {\n        this.$message.error(\"两次密码不一致！\");\n        return;\n      }\n      this.request.post(\"/user/register\", {\n        username: this.registerForm.username,\n        password: this.registerForm.password\n      }).then(res => {\n        if (res.data) {\n          this.$message.success(\"注册成功！请登录\");\n          this.activeTab = \"login\"; // 切换到登录\n          this.resetForm();\n        }\n      }).catch(() => {\n        this.$message.error(\"注册失败，请重试！\");\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","activeTab","loginForm","username","password","registerForm","confirmPassword","methods","resetForm","$refs","resetFields","handleLogin","request","post","then","res","token","localStorage","setItem","$router","push","$message","success","error","catch","handleRegister"],"sources":["src/views/login/Login.vue"],"sourcesContent":["<template>\r\n  <div class=\"login-container\">\r\n    <!-- 登录/注册切换卡片 -->\r\n    <el-card class=\"login-card\" shadow=\"hover\">\r\n      <div class=\"tab-container\">\r\n        <el-tabs v-model=\"activeTab\" type=\"border-card\" @tab-click=\"resetForm\">\r\n          <!-- 登录标签 -->\r\n          <el-tab-pane label=\"登录\" name=\"login\">\r\n            <el-form ref=\"loginForm\" :model=\"loginForm\" label-width=\"80px\" class=\"login-form\">\r\n              <el-form-item label=\"账号\" prop=\"username\">\r\n                <el-input v-model=\"loginForm.username\" placeholder=\"请输入账号\"></el-input>\r\n              </el-form-item>\r\n              <el-form-item label=\"密码\" prop=\"password\">\r\n                <el-input v-model=\"loginForm.password\" type=\"password\" placeholder=\"请输入密码\"></el-input>\r\n              </el-form-item>\r\n              <el-form-item>\r\n                <el-button type=\"primary\" @click=\"handleLogin\" style=\"width: 100%;\">登录</el-button>\r\n              </el-form-item>\r\n            </el-form>\r\n          </el-tab-pane>\r\n\r\n          <!-- 注册标签 -->\r\n          <el-tab-pane label=\"注册\" name=\"register\">\r\n            <el-form ref=\"registerForm\" :model=\"registerForm\" label-width=\"80px\" class=\"login-form\">\r\n              <el-form-item label=\"账号\" prop=\"username\">\r\n                <el-input v-model=\"registerForm.username\" placeholder=\"请输入账号\"></el-input>\r\n              </el-form-item>\r\n              <el-form-item label=\"密码\" prop=\"password\">\r\n                <el-input v-model=\"registerForm.password\" type=\"password\" placeholder=\"请输入密码\"></el-input>\r\n              </el-form-item>\r\n              <el-form-item label=\"确认密码\" prop=\"confirmPassword\">\r\n                <el-input v-model=\"registerForm.confirmPassword\" type=\"password\" placeholder=\"请确认密码\"></el-input>\r\n              </el-form-item>\r\n              <el-form-item>\r\n                <el-button type=\"primary\" @click=\"handleRegister\" style=\"width: 100%;\">注册</el-button>\r\n              </el-form-item>\r\n            </el-form>\r\n          </el-tab-pane>\r\n        </el-tabs>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Login\",\r\n  data() {\r\n    return {\r\n      activeTab: \"login\", // 默认显示登录\r\n      loginForm: {\r\n        username: \"\",\r\n        password: \"\"\r\n      },\r\n      registerForm: {\r\n        username: \"\",\r\n        password: \"\",\r\n        confirmPassword: \"\"\r\n      }\r\n    };\r\n  },\r\n  methods: {\r\n    // 重置表单\r\n    resetForm() {\r\n      if (this.activeTab === \"login\") {\r\n        this.$refs.loginForm?.resetFields();\r\n      } else {\r\n        this.$refs.registerForm?.resetFields();\r\n      }\r\n    },\r\n    // 登录\r\n    handleLogin() {\r\n      this.request.post(\"/user/login\", this.loginForm).then(res => {\r\n        if (res.data.token) {\r\n          // 存储token\r\n          localStorage.setItem(\"token\", res.data.token);\r\n          // 跳转主页\r\n          this.$router.push(\"/home\");\r\n          this.$message.success(\"登录成功！\");\r\n        } else {\r\n          this.$message.error(\"账号或密码错误！\");\r\n        }\r\n      }).catch(() => {\r\n        this.$message.error(\"登录失败，请重试！\");\r\n      });\r\n    },\r\n    // 注册\r\n    handleRegister() {\r\n      if (this.registerForm.password !== this.registerForm.confirmPassword) {\r\n        this.$message.error(\"两次密码不一致！\");\r\n        return;\r\n      }\r\n      this.request.post(\"/user/register\", {\r\n        username: this.registerForm.username,\r\n        password: this.registerForm.password\r\n      }).then(res => {\r\n        if (res.data) {\r\n          this.$message.success(\"注册成功！请登录\");\r\n          this.activeTab = \"login\"; // 切换到登录\r\n          this.resetForm();\r\n        }\r\n      }).catch(() => {\r\n        this.$message.error(\"注册失败，请重试！\");\r\n      });\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.login-container {\r\n  height: 100vh;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  background: #f0f2f5;\r\n}\r\n.login-card {\r\n  width: 400px;\r\n  border-radius: 8px;\r\n}\r\n.tab-container {\r\n  padding: 20px;\r\n}\r\n.login-form {\r\n  margin-top: 20px;\r\n}\r\n</style>"],"mappings":";AA6CA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,SAAA;MAAA;MACAC,SAAA;QACAC,QAAA;QACAC,QAAA;MACA;MACAC,YAAA;QACAF,QAAA;QACAC,QAAA;QACAE,eAAA;MACA;IACA;EACA;EACAC,OAAA;IACA;IACAC,UAAA;MACA,SAAAP,SAAA;QACA,KAAAQ,KAAA,CAAAP,SAAA,EAAAQ,WAAA;MACA;QACA,KAAAD,KAAA,CAAAJ,YAAA,EAAAK,WAAA;MACA;IACA;IACA;IACAC,YAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,qBAAAX,SAAA,EAAAY,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAf,IAAA,CAAAgB,KAAA;UACA;UACAC,YAAA,CAAAC,OAAA,UAAAH,GAAA,CAAAf,IAAA,CAAAgB,KAAA;UACA;UACA,KAAAG,OAAA,CAAAC,IAAA;UACA,KAAAC,QAAA,CAAAC,OAAA;QACA;UACA,KAAAD,QAAA,CAAAE,KAAA;QACA;MACA,GAAAC,KAAA;QACA,KAAAH,QAAA,CAAAE,KAAA;MACA;IACA;IACA;IACAE,eAAA;MACA,SAAApB,YAAA,CAAAD,QAAA,UAAAC,YAAA,CAAAC,eAAA;QACA,KAAAe,QAAA,CAAAE,KAAA;QACA;MACA;MACA,KAAAX,OAAA,CAAAC,IAAA;QACAV,QAAA,OAAAE,YAAA,CAAAF,QAAA;QACAC,QAAA,OAAAC,YAAA,CAAAD;MACA,GAAAU,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAf,IAAA;UACA,KAAAqB,QAAA,CAAAC,OAAA;UACA,KAAArB,SAAA;UACA,KAAAO,SAAA;QACA;MACA,GAAAgB,KAAA;QACA,KAAAH,QAAA,CAAAE,KAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}