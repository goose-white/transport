{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\nimport request from '@/utils/request';\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      loading: false,\n      dialogFormVisible: false,\n      // 弹窗显示状态（核心：确保初始值为false）\n      form: {},\n      // 查询表单（对应前四列）\n      queryForm: {\n        id: '',\n        name: '',\n        type: '',\n        deviceId: ''\n      },\n      formRules: {\n        name: [{\n          required: true,\n          message: '请输入任务名称',\n          trigger: 'blur'\n        }],\n        type: [{\n          required: true,\n          message: '请选择任务类型',\n          trigger: 'change'\n        }],\n        deviceId: [{\n          required: true,\n          message: '请输入无人机ID',\n          trigger: 'blur'\n        }, {\n          type: 'number',\n          message: '无人机ID必须为数字',\n          trigger: 'blur'\n        }],\n        status: [{\n          required: true,\n          message: '请选择任务状态',\n          trigger: 'change'\n        }]\n      }\n    };\n  },\n  created() {\n    this.loadTaskData();\n  },\n  methods: {\n    resetForm() {\n      this.form = {};\n      this.$refs.formRef?.resetFields();\n    },\n    // 加载数据（支持带查询条件）\n    async loadTaskData() {\n      try {\n        this.loading = true;\n        const res = await request.get(\"/task/getAllData\", {\n          params: this.queryForm\n        });\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : [];\n      } catch (error) {\n        console.error('加载失败：', error);\n        this.taskList = [];\n        this.$message.error('数据加载失败，请重试');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleQuery() {\n      this.loadTaskData();\n    },\n    handleReset() {\n      this.queryForm = {\n        id: '',\n        name: '',\n        type: '',\n        deviceId: ''\n      };\n      this.loadTaskData();\n    },\n    handleAdd() {\n      this.form = {\n        type: \"0\",\n        status: \"0\"\n      };\n      this.dialogFormVisible = true;\n    },\n    // 修复编辑按钮无响应的核心函数：增加日志+强制打开弹窗\n    handleEdit(row) {\n      // 第一步：打印日志，确认是否触发函数、row是否有值（调试用）\n      console.log('编辑按钮触发，选中的行数据：', row);\n\n      // 第二步：强制赋值弹窗状态为true\n      this.dialogFormVisible = true;\n\n      // 第三步：深拷贝行数据，确保回显\n      this.form = JSON.parse(JSON.stringify({\n        id: row.id,\n        name: row.name,\n        type: row.type?.toString() || \"0\",\n        deviceId: row.deviceId || \"\",\n        status: row.status?.toString() || \"0\"\n      }));\n\n      // 第四步：再次确认弹窗状态（兜底）\n      this.$nextTick(() => {\n        this.dialogFormVisible = true;\n        console.log('弹窗状态：', this.dialogFormVisible);\n      });\n    },\n    async saveTask() {\n      try {\n        await this.$refs.formRef.validate();\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\";\n        const submitData = {\n          id: this.form.id,\n          name: this.form.name,\n          type: Number(this.form.type),\n          deviceId: Number(this.form.deviceId),\n          status: Number(this.form.status)\n        };\n        const res = await request.post(apiUrl, submitData);\n        if (res?.code === 200) {\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功');\n          this.dialogFormVisible = false;\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '保存失败');\n        }\n      } catch (error) {\n        this.$message.error('保存失败，请检查数据');\n      }\n    },\n    async handleDelete(row) {\n      try {\n        await this.$confirm('确定删除该任务？', '提示', {\n          type: 'warning'\n        });\n        const res = await request.post(\"/task/delete\", {\n          id: row.id\n        });\n        if (res?.code === 200) {\n          this.$message.success('删除成功');\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '删除失败');\n        }\n      } catch (error) {\n        if (error !== 'cancel') this.$message.error('删除失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","queryForm","id","type","deviceId","formRules","required","message","trigger","status","created","loadTaskData","methods","resetForm","$refs","formRef","resetFields","res","get","params","Array","isArray","error","console","$message","handleQuery","handleReset","handleAdd","handleEdit","row","log","JSON","parse","stringify","toString","$nextTick","saveTask","validate","apiUrl","submitData","Number","post","code","success","msg","handleDelete","$confirm"],"sources":["src/views/task.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 查询条件区域 -->\r\n    <div style=\"margin-bottom: 20px; display: flex; align-items: center; gap: 15px;\">\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">任务ID：</label>\r\n        <el-input v-model=\"queryForm.id\" placeholder=\"输入任务ID\" style=\"width: 150px;\" />\r\n      </div>\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">任务名称：</label>\r\n        <el-input v-model=\"queryForm.name\" placeholder=\"输入任务名称\" style=\"width: 180px;\" />\r\n      </div>\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">任务类型：</label>\r\n        <el-input v-model=\"queryForm.type\" placeholder=\"输入任务类型（0-3）\" style=\"width: 150px;\" />\r\n      </div>\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">执行无人机：</label>\r\n        <el-input v-model=\"queryForm.deviceId\" placeholder=\"输入执行无人机ID\" style=\"width: 150px;\" />\r\n      </div>\r\n      <el-button type=\"primary\" @click=\"handleQuery\">查询</el-button>\r\n      <el-button @click=\"handleReset\">重置</el-button>\r\n    </div>\r\n\r\n    <!-- 新增按钮 -->\r\n    <el-button type=\"primary\" style=\"margin-bottom: 20px;\" @click=\"handleAdd\">新增任务</el-button>\r\n\r\n    <!-- 编辑弹窗：修复v-model绑定（Element Plus用model-value，Element UI用visible） -->\r\n    <el-dialog\r\n        :title=\"form.id ? '编辑任务' : '新增任务'\"\r\n        v-model=\"dialogFormVisible\"\r\n        width=\"500px\"\r\n        @close=\"resetForm\"\r\n    >\r\n      <el-form ref=\"formRef\" :model=\"form\" label-width=\"100px\" size=\"small\" :rules=\"formRules\">\r\n        <el-form-item label=\"任务名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"type\">\r\n          <el-select v-model=\"form.type\" placeholder=\"请选择任务类型\">\r\n            <el-option label=\"0-道路巡航\" value=\"0\"></el-option>\r\n            <el-option label=\"1-水域巡逻\" value=\"1\"></el-option>\r\n            <el-option label=\"2-事故取证\" value=\"2\"></el-option>\r\n            <el-option label=\"3-隐患排查\" value=\"3\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"deviceId\">\r\n          <el-input v-model.number=\"form.deviceId\" placeholder=\"请输入无人机ID\" type=\"number\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务状态\" prop=\"status\">\r\n          <el-select v-model=\"form.status\" placeholder=\"请选择任务状态\">\r\n            <el-option label=\"0-未开始\" value=\"0\"></el-option>\r\n            <el-option label=\"1-执行中\" value=\"1\"></el-option>\r\n            <el-option label=\"2-已完成\" value=\"2\"></el-option>\r\n            <el-option label=\"3-已取消\" value=\"3\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTask\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 任务表格 -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column prop=\"id\" label=\"任务ID\" width=\"120\" />\r\n      <el-table-column prop=\"name\" label=\"任务名称\" width=\"180\" />\r\n      <el-table-column prop=\"type\" label=\"任务类型\" width=\"120\" />\r\n      <el-table-column prop=\"deviceId\" label=\"执行无人机\" width=\"120\" />\r\n      <el-table-column prop=\"startTime\" label=\"创建时间\" width=\"180\">\r\n        <template #default=\"scope\">\r\n          {{ scope.row.startTime || '未设置' }}\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"endTime\" label=\"任务结束时间\" width=\"180\">\r\n        <template #default=\"scope\">\r\n          {{ scope.row.endTime || '未设置' }}\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"status\" label=\"任务状态\" width=\"120\" />\r\n      <el-table-column label=\"操作\" width=\"150\">\r\n        <template #default=\"scope\">\r\n          <!-- 修复：添加click事件的row参数传递，增加日志调试 -->\r\n          <el-button type=\"primary\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click=\"handleDelete(scope.row)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [],\r\n      loading: false,\r\n      dialogFormVisible: false, // 弹窗显示状态（核心：确保初始值为false）\r\n      form: {},\r\n      // 查询表单（对应前四列）\r\n      queryForm: {\r\n        id: '',\r\n        name: '',\r\n        type: '',\r\n        deviceId: ''\r\n      },\r\n      formRules: {\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请选择任务类型', trigger: 'change' }],\r\n        deviceId: [\r\n          { required: true, message: '请输入无人机ID', trigger: 'blur' },\r\n          { type: 'number', message: '无人机ID必须为数字', trigger: 'blur' }\r\n        ],\r\n        status: [{ required: true, message: '请选择任务状态', trigger: 'change' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData()\r\n  },\r\n  methods: {\r\n    resetForm() {\r\n      this.form = {}\r\n      this.$refs.formRef?.resetFields()\r\n    },\r\n\r\n    // 加载数据（支持带查询条件）\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true\r\n        const res = await request.get(\"/task/getAllData\", {\r\n          params: this.queryForm\r\n        })\r\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : []\r\n      } catch (error) {\r\n        console.error('加载失败：', error)\r\n        this.taskList = []\r\n        this.$message.error('数据加载失败，请重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    handleQuery() {\r\n      this.loadTaskData()\r\n    },\r\n\r\n    handleReset() {\r\n      this.queryForm = {\r\n        id: '',\r\n        name: '',\r\n        type: '',\r\n        deviceId: ''\r\n      }\r\n      this.loadTaskData()\r\n    },\r\n\r\n    handleAdd() {\r\n      this.form = { type: \"0\", status: \"0\" }\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    // 修复编辑按钮无响应的核心函数：增加日志+强制打开弹窗\r\n    handleEdit(row) {\r\n      // 第一步：打印日志，确认是否触发函数、row是否有值（调试用）\r\n      console.log('编辑按钮触发，选中的行数据：', row)\r\n\r\n      // 第二步：强制赋值弹窗状态为true\r\n      this.dialogFormVisible = true\r\n\r\n      // 第三步：深拷贝行数据，确保回显\r\n      this.form = JSON.parse(JSON.stringify({\r\n        id: row.id,\r\n        name: row.name,\r\n        type: row.type?.toString() || \"0\",\r\n        deviceId: row.deviceId || \"\",\r\n        status: row.status?.toString() || \"0\"\r\n      }))\r\n\r\n      // 第四步：再次确认弹窗状态（兜底）\r\n      this.$nextTick(() => {\r\n        this.dialogFormVisible = true\r\n        console.log('弹窗状态：', this.dialogFormVisible)\r\n      })\r\n    },\r\n\r\n    async saveTask() {\r\n      try {\r\n        await this.$refs.formRef.validate()\r\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\"\r\n        const submitData = {\r\n          id: this.form.id,\r\n          name: this.form.name,\r\n          type: Number(this.form.type),\r\n          deviceId: Number(this.form.deviceId),\r\n          status: Number(this.form.status)\r\n        }\r\n        const res = await request.post(apiUrl, submitData)\r\n\r\n        if (res?.code === 200) {\r\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功')\r\n          this.dialogFormVisible = false\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '保存失败')\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('保存失败，请检查数据')\r\n      }\r\n    },\r\n\r\n    async handleDelete(row) {\r\n      try {\r\n        await this.$confirm('确定删除该任务？', '提示', { type: 'warning' })\r\n        const res = await request.post(\"/task/delete\", { id: row.id })\r\n\r\n        if (res?.code === 200) {\r\n          this.$message.success('删除成功')\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') this.$message.error('删除失败')\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n:deep(.el-button) { margin: 0 4px; }\r\n:deep(.el-form-item) { margin-bottom: 15px; }\r\n</style>"],"mappings":";;AAmGA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,OAAA;MACAC,iBAAA;MAAA;MACAC,IAAA;MACA;MACAC,SAAA;QACAC,EAAA;QACAP,IAAA;QACAQ,IAAA;QACAC,QAAA;MACA;MACAC,SAAA;QACAV,IAAA;UAAAW,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAL,IAAA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAJ,QAAA,GACA;UAAAE,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,GACA;UAAAL,IAAA;UAAAI,OAAA;UAAAC,OAAA;QAAA,EACA;QACAC,MAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAE,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACAC,UAAA;MACA,KAAAb,IAAA;MACA,KAAAc,KAAA,CAAAC,OAAA,EAAAC,WAAA;IACA;IAEA;IACA,MAAAL,aAAA;MACA;QACA,KAAAb,OAAA;QACA,MAAAmB,GAAA,SAAAvB,OAAA,CAAAwB,GAAA;