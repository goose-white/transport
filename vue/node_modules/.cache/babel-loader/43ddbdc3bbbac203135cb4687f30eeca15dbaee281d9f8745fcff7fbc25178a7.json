{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.some.js\";\nimport Aside from \"@/components/Aside\";\nexport default {\n  components: {\n    Aside\n  },\n  data() {\n    return {\n      isCollapse: false,\n      sideWidth: 300,\n      logoTextShow: true,\n      timeTimer: null,\n      activeTab: \"/home\",\n      tabs: [{\n        path: \"/home\",\n        name: \"主页\"\n      }],\n      loginUsername: \"\",\n      loginUserId: \"\"\n    };\n  },\n  methods: {\n    collapse() {\n      this.isCollapse = !this.isCollapse;\n      this.sideWidth = this.isCollapse ? 64 : 300;\n      this.logoTextShow = !this.isCollapse;\n    },\n    logout() {\n      localStorage.clear();\n      this.loginUsername = \"\";\n      this.loginUserId = \"\";\n      this.$router.push(\"/login\");\n    },\n    getCurrentDate() {\n      const date = new Date();\n      const year = date.getFullYear();\n      const month = (date.getMonth() + 1).toString().padStart(2, \"0\");\n      const day = date.getDate().toString().padStart(2, \"0\");\n      const hour = date.getHours().toString().padStart(2, \"0\");\n      const minute = date.getMinutes().toString().padStart(2, \"0\");\n      const second = date.getSeconds().toString().padStart(2, \"0\");\n      const week = [\"周日\", \"周一\", \"周二\", \"周三\", \"周四\", \"周五\", \"周六\"][date.getDay()];\n      const dateText = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\n      const currentDateEl = document.getElementById(\"current-date\");\n      const todoDateEl = document.getElementById(\"todo-date\");\n      const todoDate2El = document.getElementById(\"todo-date2\");\n      if (currentDateEl) currentDateEl.innerText = dateText;\n      if (todoDateEl) todoDateEl.innerText = dateText;\n      if (todoDate2El) todoDate2El.innerText = dateText;\n    },\n    addTab(route) {\n      const isExist = this.tabs.some(tab => tab.path === route.path);\n      if (!isExist) {\n        const tabNameMap = {\n          \"/home\": \"主页\",\n          \"/drone\": \"无人机管理\",\n          \"/task\": \"无人机任务管理\",\n          \"/photography\": \"现场视频\",\n          \"/recognition\": \"识别结果\"\n        };\n        this.tabs.push({\n          path: route.path,\n          name: tabNameMap[route.path] || \"未知页面\"\n        });\n      }\n      this.activeTab = route.path;\n    },\n    handleTabClick(tab) {\n      this.$router.push(tab.name);\n      this.activeTab = tab.name;\n    },\n    closeTab(path) {\n      const tabIndex = this.tabs.findIndex(tab => tab.path === path);\n      if (tabIndex > -1) {\n        this.tabs.splice(tabIndex, 1);\n        if (this.activeTab === path) {\n          this.activeTab = this.tabs.length > 0 ? this.tabs[this.tabs.length - 1].path : \"/home\";\n          this.$router.push(this.activeTab);\n        }\n      }\n    },\n    // 优化：加日志，方便排查\n    getLoginInfo() {\n      const username = localStorage.getItem(\"username\") || \"\";\n      const userId = localStorage.getItem(\"userId\") || \"\";\n      console.log(\"读取到的登录信息：\", {\n        username,\n        userId\n      }); // 关键：看控制台是否有值\n      this.loginUsername = username;\n      this.loginUserId = userId;\n    }\n  },\n  watch: {\n    $route: {\n      immediate: true,\n      handler(to) {\n        this.addTab(to);\n        // 优化：加 nextTick 确保 localStorage 已存储\n        this.$nextTick(() => {\n          this.getLoginInfo();\n        });\n      }\n    }\n  },\n  mounted() {\n    this.getCurrentDate();\n    this.timeTimer = setInterval(() => {\n      this.getCurrentDate();\n    }, 1000);\n    this.getLoginInfo();\n  },\n  beforeDestroy() {\n    if (this.timeTimer) {\n      clearInterval(this.timeTimer);\n    }\n  }\n};","map":{"version":3,"names":["Aside","components","data","isCollapse","sideWidth","logoTextShow","timeTimer","activeTab","tabs","path","name","loginUsername","loginUserId","methods","collapse","logout","localStorage","clear","$router","push","getCurrentDate","date","Date","year","getFullYear","month","getMonth","toString","padStart","day","getDate","hour","getHours","minute","getMinutes","second","getSeconds","week","getDay","dateText","currentDateEl","document","getElementById","todoDateEl","todoDate2El","innerText","addTab","route","isExist","some","tab","tabNameMap","handleTabClick","closeTab","tabIndex","findIndex","splice","length","getLoginInfo","username","getItem","userId","console","log","watch","$route","immediate","handler","to","$nextTick","mounted","setInterval","beforeDestroy","clearInterval"],"sources":["src/views/Manage.vue"],"sourcesContent":["<template>\r\n  <!-- 其他代码不变，仅修复 el-icon-close 的语法错误 -->\r\n  <template slot=\"tab\" slot-scope=\"{ tab, index }\">\r\n    <div\r\n        :style=\"{\r\n        display: 'inline-flex',\r\n        alignItems: 'center',\r\n        padding: '0 18px',\r\n        height: '36px',\r\n        marginRight: '8px',\r\n        borderRadius: '18px',\r\n        cursor: 'pointer',\r\n        background: tab.active ? '#4299E1' : '#e9ecef',\r\n        color: tab.active ? '#fff' : '#6c757d',\r\n        fontSize: '14px',\r\n        fontWeight: tab.active ? 500 : 400,\r\n        border: 'none',\r\n        transition: 'all 0.2s ease'\r\n      }\"\r\n    >\r\n      {{ tab.label }}\r\n      <!-- 修复：去掉多余的 < 符号 -->\r\n      <i\r\n          v-if=\"tab.closable\"\r\n          class=\"el-icon-close\"\r\n          style=\"margin-left: 8px; font-size: 12px; cursor: pointer;\"\r\n          :style=\"{ color: tab.active ? 'rgba(255,255,255,0.8)' : '#6c757d' }\"\r\n          @mouseenter=\"(e) => e.target.style.color = tab.active ? '#fff' : '#F56C6C'\"\r\n          @mouseleave=\"(e) => e.target.style.color = tab.active ? 'rgba(255,255,255,0.8)' : '#6c757d'\"\r\n          @click.stop=\"closeTab(tab.name)\"\r\n      ></i>\r\n    </div>\r\n  </template>\r\n</template>\r\n\r\n<script>\r\nimport Aside from \"@/components/Aside\";\r\n\r\nexport default {\r\n  components: { Aside },\r\n  data() {\r\n    return {\r\n      isCollapse: false,\r\n      sideWidth: 300,\r\n      logoTextShow: true,\r\n      timeTimer: null,\r\n      activeTab: \"/home\",\r\n      tabs: [{ path: \"/home\", name: \"主页\" }],\r\n      loginUsername: \"\",\r\n      loginUserId: \"\"\r\n    };\r\n  },\r\n  methods: {\r\n    collapse() {\r\n      this.isCollapse = !this.isCollapse;\r\n      this.sideWidth = this.isCollapse ? 64 : 300;\r\n      this.logoTextShow = !this.isCollapse;\r\n    },\r\n    logout() {\r\n      localStorage.clear();\r\n      this.loginUsername = \"\";\r\n      this.loginUserId = \"\";\r\n      this.$router.push(\"/login\");\r\n    },\r\n    getCurrentDate() {\r\n      const date = new Date();\r\n      const year = date.getFullYear();\r\n      const month = (date.getMonth() + 1).toString().padStart(2, \"0\");\r\n      const day = date.getDate().toString().padStart(2, \"0\");\r\n      const hour = date.getHours().toString().padStart(2, \"0\");\r\n      const minute = date.getMinutes().toString().padStart(2, \"0\");\r\n      const second = date.getSeconds().toString().padStart(2, \"0\");\r\n      const week = [\"周日\", \"周一\", \"周二\", \"周三\", \"周四\", \"周五\", \"周六\"][date.getDay()];\r\n      const dateText = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\r\n\r\n      const currentDateEl = document.getElementById(\"current-date\");\r\n      const todoDateEl = document.getElementById(\"todo-date\");\r\n      const todoDate2El = document.getElementById(\"todo-date2\");\r\n\r\n      if (currentDateEl) currentDateEl.innerText = dateText;\r\n      if (todoDateEl) todoDateEl.innerText = dateText;\r\n      if (todoDate2El) todoDate2El.innerText = dateText;\r\n    },\r\n    addTab(route) {\r\n      const isExist = this.tabs.some((tab) => tab.path === route.path);\r\n      if (!isExist) {\r\n        const tabNameMap = {\r\n          \"/home\": \"主页\",\r\n          \"/drone\": \"无人机管理\",\r\n          \"/task\": \"无人机任务管理\",\r\n          \"/photography\": \"现场视频\",\r\n          \"/recognition\": \"识别结果\",\r\n        };\r\n        this.tabs.push({\r\n          path: route.path,\r\n          name: tabNameMap[route.path] || \"未知页面\",\r\n        });\r\n      }\r\n      this.activeTab = route.path;\r\n    },\r\n    handleTabClick(tab) {\r\n      this.$router.push(tab.name);\r\n      this.activeTab = tab.name;\r\n    },\r\n    closeTab(path) {\r\n      const tabIndex = this.tabs.findIndex((tab) => tab.path === path);\r\n      if (tabIndex > -1) {\r\n        this.tabs.splice(tabIndex, 1);\r\n        if (this.activeTab === path) {\r\n          this.activeTab = this.tabs.length > 0 ? this.tabs[this.tabs.length - 1].path : \"/home\";\r\n          this.$router.push(this.activeTab);\r\n        }\r\n      }\r\n    },\r\n    // 优化：加日志，方便排查\r\n    getLoginInfo() {\r\n      const username = localStorage.getItem(\"username\") || \"\";\r\n      const userId = localStorage.getItem(\"userId\") || \"\";\r\n      console.log(\"读取到的登录信息：\", { username, userId }); // 关键：看控制台是否有值\r\n      this.loginUsername = username;\r\n      this.loginUserId = userId;\r\n    }\r\n  },\r\n  watch: {\r\n    $route: {\r\n      immediate: true,\r\n      handler(to) {\r\n        this.addTab(to);\r\n        // 优化：加 nextTick 确保 localStorage 已存储\r\n        this.$nextTick(() => {\r\n          this.getLoginInfo();\r\n        });\r\n      },\r\n    },\r\n  },\r\n  mounted() {\r\n    this.getCurrentDate();\r\n    this.timeTimer = setInterval(() => {\r\n      this.getCurrentDate();\r\n    }, 1000);\r\n    this.getLoginInfo();\r\n  },\r\n  beforeDestroy() {\r\n    if (this.timeTimer) {\r\n      clearInterval(this.timeTimer);\r\n    }\r\n  },\r\n};\r\n</script>"],"mappings":";;;AAoCA,OAAAA,KAAA;AAEA;EACAC,UAAA;IAAAD;EAAA;EACAE,KAAA;IACA;MACAC,UAAA;MACAC,SAAA;MACAC,YAAA;MACAC,SAAA;MACAC,SAAA;MACAC,IAAA;QAAAC,IAAA;QAAAC,IAAA;MAAA;MACAC,aAAA;MACAC,WAAA;IACA;EACA;EACAC,OAAA;IACAC,SAAA;MACA,KAAAX,UAAA,SAAAA,UAAA;MACA,KAAAC,SAAA,QAAAD,UAAA;MACA,KAAAE,YAAA,SAAAF,UAAA;IACA;I