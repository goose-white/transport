{"ast":null,"code":"export default {\n  name: \"Home\",\n  data() {\n    return {\n      currentTime: \"\",\n      timer: null,\n      exitHover: false,\n      // 退出登录悬浮状态\n      userHover: false // 人员信息悬浮状态\n    };\n  },\n  methods: {\n    // 实时更新时间（含时分秒）\n    updateTime() {\n      const date = new Date();\n      const year = date.getFullYear();\n      const month = String(date.getMonth() + 1).padStart(2, '0');\n      const day = String(date.getDate()).padStart(2, '0');\n      const hour = String(date.getHours()).padStart(2, '0');\n      const minute = String(date.getMinutes()).padStart(2, '0');\n      const second = String(date.getSeconds()).padStart(2, '0');\n      const weekArr = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];\n      const week = weekArr[date.getDay()];\n      this.currentTime = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\n    },\n    // 退出登录\n    logout() {\n      localStorage.removeItem('token');\n      alert('已退出登录');\n    }\n  },\n  mounted() {\n    this.updateTime();\n    this.timer = setInterval(() => this.updateTime(), 1000);\n  },\n  beforeDestroy() {\n    clearInterval(this.timer);\n  }\n};","map":{"version":3,"names":["name","data","currentTime","timer","exitHover","userHover","methods","updateTime","date","Date","year","getFullYear","month","String","getMonth","padStart","day","getDate","hour","getHours","minute","getMinutes","second","getSeconds","weekArr","week","getDay","logout","localStorage","removeItem","alert","mounted","setInterval","beforeDestroy","clearInterval"],"sources":["src/views/Home.vue"],"sourcesContent":["<template>\n  <div id=\"app-container\">\n    <!-- 顶部导航栏（含实时时间+交互效果） -->\n    <div style=\"background: #2D2D2D; color: #fff; padding: 0 20px; height: 60px; line-height: 60px; display: flex; justify-content: flex-end; align-items: center; gap: 20px;\">\n      <!-- 通知图标 -->\n      <div style=\"position: relative; cursor: pointer; transition: transform 0.2s;\">\n        <<i class=\"el-icon-bell\" style=\"font-size: 18px;\"></</i>\n        <span style=\"position: absolute; top: -5px; right: -8px; background: #F56C6C; color: #fff; font-size: 12px; width: 18px; height: 18px; line-height: 18px; text-align: center; border-radius: 50%;\">3</span>\n      </div>\n\n      <!-- 搜索框 -->\n      <el-input placeholder=\"请输入搜索内容\" style=\"width: 200px; background: rgba(255,255,255,0.1); border: none; color: #fff;\" prefix-icon=\"el-icon-search\"></el-input>\n\n      <!-- 实时时间（含具体时分秒） -->\n      <span style=\"font-size: 14px;\">{{ currentTime }}</span>\n\n      <!-- 退出登录（点击效果） -->\n      <div\n          style=\"cursor: pointer; transition: color 0.2s; display: flex; align-items: center; gap: 5px;\"\n          @mouseenter=\"exitHover = true\"\n          @mouseleave=\"exitHover = false\"\n          @click=\"logout\"\n      >\n        <<i class=\"el-icon-switch-button\"></</i>\n        <span :style=\"{ color: exitHover ? '#4299E1' : '#fff' }\">退出登录</span>\n      </div>\n\n      <!-- 人员信息（悬浮显示电话+工号+性别） -->\n      <el-tooltip\n          effect=\"dark\"\n          placement=\"bottom\"\n          :content=\"`电话号码：138xxxx1234\n工号：20230001\n性别：男`\"\n          class=\"user-tooltip\"\n      >\n        <div\n            style=\"display: flex; align-items: center; gap: 8px; cursor: pointer; transition: opacity 0.2s;\"\n            @mouseenter=\"userHover = true\"\n            @mouseleave=\"userHover = false\"\n        >\n          <el-avatar icon=\"el-icon-user\" size=\"medium\" style=\"background: #4299E1; color: #fff; opacity: ${userHover ? 0.8 : 1}\"></el-avatar>\n          <span :style=\"{ opacity: userHover ? 0.8 : 1 }\">贾舒凯</span>\n        </div>\n      </el-tooltip>\n    </div>\n\n    <!-- 主内容区（示例） -->\n    <div style=\"padding: 20px; background: #fff; min-height: calc(100vh - 60px);\">\n      <div>页面内容区域</div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      currentTime: \"\",\n      timer: null,\n      exitHover: false, // 退出登录悬浮状态\n      userHover: false  // 人员信息悬浮状态\n    }\n  },\n  methods: {\n    // 实时更新时间（含时分秒）\n    updateTime() {\n      const date = new Date()\n      const year = date.getFullYear()\n      const month = String(date.getMonth() + 1).padStart(2, '0')\n      const day = String(date.getDate()).padStart(2, '0')\n      const hour = String(date.getHours()).padStart(2, '0')\n      const minute = String(date.getMinutes()).padStart(2, '0')\n      const second = String(date.getSeconds()).padStart(2, '0')\n      const weekArr = ['周日', '周一', '周二', '周三', '周四', '周五', '周六']\n      const week = weekArr[date.getDay()]\n      this.currentTime = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`\n    },\n    // 退出登录\n    logout() {\n      localStorage.removeItem('token');\n      alert('已退出登录');\n    }\n  },\n  mounted() {\n    this.updateTime();\n    this.timer = setInterval(() => this.updateTime(), 1000);\n  },\n  beforeDestroy() {\n    clearInterval(this.timer);\n  }\n}\n</script>\n\n<style scoped>\n#app-container {\n  width: 100%;\n  height: 100%;\n  overflow: hidden;\n}\n\n/* 用户悬浮框换行样式 */\n::v-deep .user-tooltip .el-tooltip__popper {\n  white-space: pre-line !important;\n  padding: 10px;\n}\n</style>"],"mappings":"AAuDA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,WAAA;MACAC,KAAA;MACAC,SAAA;MAAA;MACAC,SAAA;IACA;EACA;EACAC,OAAA;IACA;IACAC,WAAA;MACA,MAAAC,IAAA,OAAAC,IAAA;MACA,MAAAC,IAAA,GAAAF,IAAA,CAAAG,WAAA;MACA,MAAAC,KAAA,GAAAC,MAAA,CAAAL,IAAA,CAAAM,QAAA,QAAAC,QAAA;MACA,MAAAC,GAAA,GAAAH,MAAA,CAAAL,IAAA,CAAAS,OAAA,IAAAF,QAAA;MACA,MAAAG,IAAA,GAAAL,MAAA,CAAAL,IAAA,CAAAW,QAAA,IAAAJ,QAAA;MACA,MAAAK,MAAA,GAAAP,MAAA,CAAAL,IAAA,CAAAa,UAAA,IAAAN,QAAA;MACA,MAAAO,MAAA,GAAAT,MAAA,CAAAL,IAAA,CAAAe,UAAA,IAAAR,QAAA;MACA,MAAAS,OAAA;MACA,MAAAC,IAAA,GAAAD,OAAA,CAAAhB,IAAA,CAAAkB,MAAA;MACA,KAAAxB,WAAA,MAAAQ,IAAA,IAAAE,KAAA,IAAAI,GAAA,IAAAS,IAAA,IAAAP,IAAA,IAAAE,MAAA,IAAAE,MAAA;IACA;IACA;IACAK,OAAA;MACAC,YAAA,CAAAC,UAAA;MACAC,KAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAxB,UAAA;IACA,KAAAJ,KAAA,GAAA6B,WAA