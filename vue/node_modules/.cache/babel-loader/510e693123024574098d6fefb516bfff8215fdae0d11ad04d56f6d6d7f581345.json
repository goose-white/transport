{"ast":null,"code":"export default {\n  name: \"Aside\",\n  props: {\n    isCollapse: Boolean,\n    logoTextShow: Boolean\n  },\n  methods: {\n    handleSelect() {\n      this.$route.fullPath.split(\"/\");\n    }\n  }\n};","map":{"version":3,"names":["name","props","isCollapse","Boolean","logoTextShow","methods","handleSelect","$route","fullPath","split"],"sources":["src/components/Aside.vue"],"sourcesContent":["<template>\r\n  <el-menu\r\n      :default-openeds=\"['1', '3']\"\r\n      mode=\"horizontal\"\r\n      style=\"min-height: 60px; line-height: 60px; width: 100%; border-bottom: none;\"\r\n      background-color=\"#2D2D2D\"\r\n      text-color=\"#E2E8F0\"\r\n      active-text-color=\"#38BDF8\"\r\n      :collapse-transition=\"false\"\r\n      :collapse=\"isCollapse\"\r\n      router\r\n      @select=\"handleSelect\"\r\n  >\r\n    <!-- 已删除图标和标题容器，仅保留导航项 -->\r\n\r\n    <!-- 导航栏 -->\r\n    <el-menu-item index=\"/home\">\r\n      <i class=\"el-icon-house\"></i>\r\n      <span slot=\"title\">主页</span>\r\n    </el-menu-item>\r\n\r\n    <!--系统管理，实现二级菜单 -->\r\n    <el-submenu index=\"2\">\r\n      <template slot=\"title\">\r\n        <i class=\"el-icon-menu\"></i>\r\n        <span slot=\"title\">系统管理</span>\r\n      </template>\r\n\r\n      <!--无人机管理-->\r\n      <el-menu-item index=\"/drone\">\r\n        <template slot=\"title\">\r\n          <i class=\"el-icon-s-custom\"></i>\r\n          <span slot=\"title\">无人机管理</span>\r\n        </template>\r\n      </el-menu-item>\r\n\r\n      <!--无人机任务管理-->\r\n      <el-menu-item index=\"/task\">\r\n        <template slot=\"title\">\r\n          <i class=\"el-icon-s-custom\"></i>\r\n          <span slot=\"title\">无人机任务管理</span>\r\n        </template>\r\n      </el-menu-item>\r\n\r\n      <!-- 摄影管理 -->\r\n      <el-menu-item index=\"/photography\">\r\n        <template slot=\"title\">\r\n          <i class=\"el-icon-s-tools\"></i>\r\n          <span slot=\"title\">现场视频</span>\r\n        </template>\r\n      </el-menu-item>\r\n\r\n      <!-- 识别结果 -->\r\n      <el-menu-item index=\"/recognition\">\r\n        <template slot=\"title\">\r\n          <i class=\"el-icon-s-tools\"></i>\r\n          <span slot=\"title\">识别结果</span>\r\n        </template>\r\n      </el-menu-item>\r\n    </el-submenu>\r\n  </el-menu>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Aside\",\r\n  props: {\r\n    isCollapse: Boolean,\r\n    logoTextShow: Boolean\r\n  },\r\n  methods:{\r\n    handleSelect(){\r\n      this.$route.fullPath.split(\"/\")\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 优化下拉菜单样式 */\r\n:deep(.el-submenu__dropdown) {\r\n  background-color: #2D2D2D !important;\r\n  border: none;\r\n}\r\n:deep(.el-menu-item:hover) {\r\n  background-color: #383838 !important;\r\n}\r\n</style>"],"mappings":"AAgEA;EACAA,IAAA;EACAC,KAAA;IACAC,UAAA,EAAAC,OAAA;IACAC,YAAA,EAAAD;EACA;EACAE,OAAA;IACAC,aAAA;MACA,KAAAC,MAAA,CAAAC,QAAA,CAAAC,KAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}