{"ast":null,"code":"import request from '@/utils/request';\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      loading: false,\n      dialogFormVisible: false,\n      form: {},\n      formRules: {\n        name: [{\n          required: true,\n          message: '请输入任务名称',\n          trigger: 'blur'\n        }],\n        type: [{\n          required: true,\n          message: '请选择任务类型',\n          trigger: 'change'\n        }],\n        deviceId: [{\n          required: true,\n          message: '请输入无人机ID',\n          trigger: 'blur'\n        }],\n        status: [{\n          required: true,\n          message: '请选择任务状态',\n          trigger: 'change'\n        }]\n      }\n    };\n  },\n  created() {\n    this.loadTaskData();\n  },\n  methods: {\n    resetForm() {\n      this.form = {};\n      this.$refs.formRef?.resetFields();\n    },\n    // 加载数据：直接使用后端驼峰字段，无转换\n    async loadTaskData() {\n      try {\n        this.loading = true;\n        const res = await request.get(\"/task/getAllData\", {});\n        // 直接赋值后端返回的驼峰字段数据\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : [];\n      } catch (error) {\n        console.error('加载失败：', error);\n        this.taskList = [];\n        this.$message.error('数据加载失败，请重试');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleAdd() {\n      this.form = {\n        type: \"0\",\n        status: \"0\"\n      }; // 新增默认值\n      this.dialogFormVisible = true;\n    },\n    // 编辑：读取后端驼峰字段\n    handleEdit(row) {\n      this.form = {\n        id: row.id,\n        name: row.name,\n        type: row.type?.toString() || \"0\",\n        // 转为字符串适配下拉框\n        deviceId: row.deviceId || \"\",\n        // 适配deviceId\n        status: row.status?.toString() || \"0\" // 转为字符串适配下拉框\n      };\n      this.dialogFormVisible = true;\n    },\n    // 保存：提交驼峰字段，匹配后端实体类\n    async saveTask() {\n      try {\n        await this.$refs.formRef.validate();\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\";\n        // 提交驼峰字段，类型转为数字匹配后端Byte/Integer\n        const submitData = {\n          id: this.form.id,\n          name: this.form.name,\n          type: Number(this.form.type),\n          // 转为数字匹配后端Byte\n          deviceId: Number(this.form.deviceId),\n          // 转为数字匹配后端Integer\n          status: Number(this.form.status) // 转为数字匹配后端Byte\n        };\n        const res = await request.post(apiUrl, submitData);\n        if (res?.code === 200) {\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功');\n          this.dialogFormVisible = false;\n          this.loadTaskData(); // 刷新后显示完整数据\n        } else {\n          this.$message.error(res?.msg || '保存失败');\n        }\n      } catch (error) {\n        this.$message.error('保存失败，请检查数据');\n      }\n    },\n    async handleDelete(row) {\n      try {\n        await this.$confirm('确定删除该任务？', '提示', {\n          type: 'warning'\n        });\n        const res = await request.post(\"/task/delete\", {\n          id: row.id\n        });\n        if (res?.code === 200) {\n          this.$message.success('删除成功');\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '删除失败');\n        }\n      } catch (error) {\n        if (error !== 'cancel') this.$message.error('删除失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","formRules","required","message","trigger","type","deviceId","status","created","loadTaskData","methods","resetForm","$refs","formRef","resetFields","res","get","Array","isArray","error","console","$message","handleAdd","handleEdit","row","id","toString","saveTask","validate","apiUrl","submitData","Number","post","code","success","msg","handleDelete","$confirm"],"sources":["src/views/task.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 新增/编辑弹窗：下拉选择保留数字值 -->\r\n    <el-dialog title=\"任务信息\" v-model=\"dialogFormVisible\" width=\"500px\" @close=\"resetForm\">\r\n      <el-form ref=\"formRef\" :model=\"form\" label-width=\"100px\" size=\"small\" :rules=\"formRules\">\r\n        <el-form-item label=\"任务名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"type\">\r\n          <el-select v-model=\"form.type\" placeholder=\"请选择任务类型\">\r\n            <el-option label=\"0-道路巡航\" value=\"0\"></el-option>\r\n            <el-option label=\"1-水域巡逻\" value=\"1\"></el-option>\r\n            <el-option label=\"2-事故取证\" value=\"2\"></el-option>\r\n            <el-option label=\"3-隐患排查\" value=\"3\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"deviceId\">\r\n          <el-input v-model=\"form.deviceId\" placeholder=\"请输入无人机ID\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务状态\" prop=\"status\">\r\n          <el-select v-model=\"form.status\" placeholder=\"请选择任务状态\">\r\n            <el-option label=\"0-未开始\" value=\"0\"></el-option>\r\n            <el-option label=\"1-执行中\" value=\"1\"></el-option>\r\n            <el-option label=\"2-已完成\" value=\"2\"></el-option>\r\n            <el-option label=\"3-已取消\" value=\"3\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTask\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 新增按钮 -->\r\n    <el-button type=\"primary\" style=\"margin-bottom: 20px;\" @click=\"handleAdd\">新增任务</el-button>\r\n\r\n    <!-- 表格：绑定后端驼峰字段，显示原始数字值 -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column prop=\"id\" label=\"任务ID\" width=\"120\" />\r\n      <el-table-column prop=\"name\" label=\"任务名称\" width=\"180\" />\r\n      <el-table-column prop=\"type\" label=\"任务类型\" width=\"120\" /> <!-- 显示0/1/2/3 -->\r\n      <el-table-column prop=\"deviceId\" label=\"执行无人机\" width=\"120\" /> <!-- 适配deviceId -->\r\n      <el-table-column prop=\"startTime\" label=\"创建时间\" width=\"180\"> <!-- 适配startTime -->\r\n        <template #default=\"scope\">\r\n          {{ scope.row.startTime || '未设置' }} <!-- 时间格式化兜底 -->\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"endTime\" label=\"任务结束时间\" width=\"180\"> <!-- 适配endTime -->\r\n        <template #default=\"scope\">\r\n          {{ scope.row.endTime || '未设置' }} <!-- 时间格式化兜底 -->\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"status\" label=\"任务状态\" width=\"120\" /> <!-- 显示0/1/2/3 -->\r\n      <el-table-column label=\"操作\" width=\"150\">\r\n        <template #default=\"scope\">\r\n          <el-button type=\"primary\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click=\"handleDelete(scope.row)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [],\r\n      loading: false,\r\n      dialogFormVisible: false,\r\n      form: {},\r\n      formRules: {\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请选择任务类型', trigger: 'change' }],\r\n        deviceId: [{ required: true, message: '请输入无人机ID', trigger: 'blur' }],\r\n        status: [{ required: true, message: '请选择任务状态', trigger: 'change' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData()\r\n  },\r\n  methods: {\r\n    resetForm() {\r\n      this.form = {}\r\n      this.$refs.formRef?.resetFields()\r\n    },\r\n\r\n    // 加载数据：直接使用后端驼峰字段，无转换\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true\r\n        const res = await request.get(\"/task/getAllData\", {})\r\n        // 直接赋值后端返回的驼峰字段数据\r\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : []\r\n      } catch (error) {\r\n        console.error('加载失败：', error)\r\n        this.taskList = []\r\n        this.$message.error('数据加载失败，请重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    handleAdd() {\r\n      this.form = { type: \"0\", status: \"0\" } // 新增默认值\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    // 编辑：读取后端驼峰字段\r\n    handleEdit(row) {\r\n      this.form = {\r\n        id: row.id,\r\n        name: row.name,\r\n        type: row.type?.toString() || \"0\", // 转为字符串适配下拉框\r\n        deviceId: row.deviceId || \"\", // 适配deviceId\r\n        status: row.status?.toString() || \"0\" // 转为字符串适配下拉框\r\n      }\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    // 保存：提交驼峰字段，匹配后端实体类\r\n    async saveTask() {\r\n      try {\r\n        await this.$refs.formRef.validate()\r\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\"\r\n        // 提交驼峰字段，类型转为数字匹配后端Byte/Integer\r\n        const submitData = {\r\n          id: this.form.id,\r\n          name: this.form.name,\r\n          type: Number(this.form.type), // 转为数字匹配后端Byte\r\n          deviceId: Number(this.form.deviceId), // 转为数字匹配后端Integer\r\n          status: Number(this.form.status) // 转为数字匹配后端Byte\r\n        }\r\n        const res = await request.post(apiUrl, submitData)\r\n\r\n        if (res?.code === 200) {\r\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功')\r\n          this.dialogFormVisible = false\r\n          this.loadTaskData() // 刷新后显示完整数据\r\n        } else {\r\n          this.$message.error(res?.msg || '保存失败')\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('保存失败，请检查数据')\r\n      }\r\n    },\r\n\r\n    async handleDelete(row) {\r\n      try {\r\n        await this.$confirm('确定删除该任务？', '提示', { type: 'warning' })\r\n        const res = await request.post(\"/task/delete\", { id: row.id })\r\n\r\n        if (res?.code === 200) {\r\n          this.$message.success('删除成功')\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') this.$message.error('删除失败')\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n:deep(.el-button) { margin: 0 4px; }\r\n:deep(.el-form-item) { margin-bottom: 15px; }\r\n</style>"],"mappings":"AAuEA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,OAAA;MACAC,iBAAA;MACAC,IAAA;MACAC,SAAA;QACAN,IAAA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,IAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAE,QAAA;UAAAJ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAG,MAAA;UAAAL,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAI,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACAC,UAAA;MACA,KAAAX,IAAA;MACA,KAAAY,KAAA,CAAAC,OAAA,EAAAC,WAAA;IACA;IAEA;IACA,MAAAL,aAAA;MACA;QACA,KAAAX,OAAA;QACA,MAAAiB,GAAA,SAAArB,OAAA,CAAAsB,GAAA;QACA;QACA,KAAAnB,QAAA,GAAAkB,GAAA,CAAAnB,IAAA,CAAAA,IAAA,IAAAqB,KAAA,CAAAC,OAAA,CAAAH,GAAA,CAAAnB,IAAA,CAAAA,IAAA,IAAAmB,GAAA,CAAAnB,IAAA,CAAAA,IAAA;MACA,SAAAuB,KAAA;QACAC,OAAA,CAAAD,KAAA,UAAAA,KAAA;QACA,KAAAtB,QAAA;QACA,KAAAwB,QAAA,CAAAF,KAAA;MACA;QACA,KAAArB,OAAA;MACA;IACA;IAEAwB,UAAA;MACA,KAAAtB,IAAA;QAAAK,IAAA;QAAAE,MAAA;MAAA;MACA,KAAAR,iBAAA;IACA;IAEA;IACAwB,WAAAC,GAAA;MACA,KAAAxB,IAAA;QACAyB,EAAA,EAAAD,GAAA,CAAAC,EAAA;QACA9B,IAAA,EAAA6B,GAAA,CAAA7B,IAAA;QACAU,IAAA,EAAAmB,GAAA,CAAAnB,IAAA,EAAAqB,QAAA;QAAA;QACApB,QAAA,EAAAkB,GAAA,CAAAlB,QAAA;QAAA;QACAC,MAAA,EAAAiB,GAAA,CAAAjB,MAAA,EAAAmB,QAAA;MACA;MACA,KAAA3B,iBAAA;IACA;IAEA;IACA,MAAA4B,SAAA;MACA;QACA,WAAAf,KAAA,CAAAC,OAAA,CAAAe,QAAA;QACA,MAAAC,MAAA,QAAA7B,IAAA,CAAAyB,EAAA;QACA;QACA