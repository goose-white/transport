{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport request from '@/utils/request';\nexport default {\n  name: \"Login\",\n  data() {\n    return {\n      activeTab: \"login\",\n      loginForm: {\n        username: \"\",\n        password: \"\"\n      },\n      registerForm: {\n        username: \"\",\n        password: \"\",\n        confirmPassword: \"\"\n      }\n    };\n  },\n  methods: {\n    async handleLogin() {\n      if (!this.loginForm.username || !this.loginForm.password) {\n        this.$message.error(\"请输入账号和密码！\");\n        return;\n      }\n      try {\n        const res = await request.post('/user/login', this.loginForm);\n        if (res.data.code === '200') {\n          localStorage.setItem(\"token\", res.data.data.token);\n          this.$message.success(\"登录成功！\");\n          this.$router.push(\"/home\");\n        } else {\n          this.$message.error(res.data.msg || \"登录失败\");\n        }\n      } catch (error) {\n        this.$message.error(\"登录失败，请检查网络！\");\n      }\n    },\n    async handleRegister() {\n      if (!this.registerForm.username || !this.registerForm.password) {\n        this.$message.error(\"请输入账号和密码！\");\n        return;\n      }\n      if (this.registerForm.password !== this.registerForm.confirmPassword) {\n        this.$message.error(\"两次密码不一致！\");\n        return;\n      }\n      try {\n        const res = await request.post('/user/register', this.registerForm);\n        if (res.data.code === '200') {\n          this.$message.success(\"注册成功，请登录！\");\n          this.activeTab = \"login\";\n        } else {\n          this.$message.error(res.data.msg || \"注册失败\");\n        }\n      } catch (error) {\n        this.$message.error(\"注册失败，请检查网络！\");\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","activeTab","loginForm","username","password","registerForm","confirmPassword","methods","handleLogin","$message","error","res","post","code","localStorage","setItem","token","success","$router","push","msg","handleRegister"],"sources":["src/views/login/Login.vue"],"sourcesContent":["<template>\r\n  <div class=\"login-container\">\r\n    <!-- 动态背景（加入交通/无人机元素） -->\r\n    <div class=\"login-bg\">\r\n      <!-- 背景装饰：无人机剪影（CSS绘制） -->\r\n      <div class=\"bg-drone\"></div>\r\n      <!-- 背景装饰：道路标线（CSS绘制） -->\r\n      <div class=\"bg-road\"></div>\r\n    </div>\r\n    <!-- 登录卡片 -->\r\n    <el-card class=\"login-card\" shadow=\"hover\">\r\n      <!-- 系统标识（无人机+交通组合） -->\r\n      <div class=\"card-header\">\r\n        <div class=\"logo\">\r\n          <!-- 无人机图标+交通标识组合 -->\r\n          <div class=\"drone-icon\">\r\n            <div class=\"drone-body\"></div>\r\n            <div class=\"drone-wing left\"></div>\r\n            <div class=\"drone-wing right\"></div>\r\n            <div class=\"drone-propeller left\"></div>\r\n            <div class=\"drone-propeller right\"></div>\r\n          </div>\r\n          <span>交通无人机管理系统</span>\r\n        </div>\r\n        <div class=\"desc\">交通巡检 · 无人机调度中心</div>\r\n      </div>\r\n\r\n      <el-tabs v-model=\"activeTab\" type=\"border-card\" class=\"tab-container\">\r\n        <!-- 登录标签页 -->\r\n        <el-tab-pane label=\"登录\" name=\"login\">\r\n          <el-form :model=\"loginForm\" label-width=\"0\" class=\"login-form\">\r\n            <el-form-item prop=\"username\">\r\n              <el-input\r\n                  v-model=\"loginForm.username\"\r\n                  placeholder=\"请输入账号\"\r\n                  prefix-icon=\"el-icon-user\"\r\n                  class=\"input-item\"\r\n              />\r\n            </el-form-item>\r\n            <el-form-item prop=\"password\">\r\n              <el-input\r\n                  v-model=\"loginForm.password\"\r\n                  type=\"password\"\r\n                  placeholder=\"请输入密码\"\r\n                  prefix-icon=\"el-icon-lock\"\r\n                  class=\"input-item\"\r\n              />\r\n            </el-form-item>\r\n            <el-form-item class=\"form-actions\">\r\n              <el-button\r\n                  type=\"primary\"\r\n                  @click=\"handleLogin\"\r\n                  class=\"login-btn\"\r\n                  icon=\"el-icon-right\"\r\n              >\r\n                登录\r\n              </el-button>\r\n            </el-form-item>\r\n          </el-form>\r\n        </el-tab-pane>\r\n\r\n        <!-- 注册标签页 -->\r\n        <el-tab-pane label=\"注册\" name=\"register\">\r\n          <el-form :model=\"registerForm\" label-width=\"0\" class=\"login-form\">\r\n            <el-form-item prop=\"username\">\r\n              <el-input\r\n                  v-model=\"registerForm.username\"\r\n                  placeholder=\"请输入账号\"\r\n                  prefix-icon=\"el-icon-user\"\r\n                  class=\"input-item\"\r\n              />\r\n            </el-form-item>\r\n            <el-form-item prop=\"password\">\r\n              <el-input\r\n                  v-model=\"registerForm.password\"\r\n                  type=\"password\"\r\n                  placeholder=\"请输入密码\"\r\n                  prefix-icon=\"el-icon-lock\"\r\n                  class=\"input-item\"\r\n              />\r\n            </el-form-item>\r\n            <el-form-item prop=\"confirmPassword\">\r\n              <el-input\r\n                  v-model=\"registerForm.confirmPassword\"\r\n                  type=\"password\"\r\n                  placeholder=\"请确认密码\"\r\n                  prefix-icon=\"el-icon-lock\"\r\n                  class=\"input-item\"\r\n              />\r\n            </el-form-item>\r\n            <el-form-item class=\"form-actions\">\r\n              <el-button\r\n                  type=\"primary\"\r\n                  @click=\"handleRegister\"\r\n                  class=\"login-btn\"\r\n                  icon=\"el-icon-check\"\r\n              >\r\n                注册\r\n              </el-button>\r\n            </el-form-item>\r\n          </el-form>\r\n        </el-tab-pane>\r\n      </el-tabs>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Login\",\r\n  data() {\r\n    return {\r\n      activeTab: \"login\",\r\n      loginForm: { username: \"\", password: \"\" },\r\n      registerForm: { username: \"\", password: \"\", confirmPassword: \"\" }\r\n    };\r\n  },\r\n  methods: {\r\n    async handleLogin() {\r\n      if (!this.loginForm.username || !this.loginForm.password) {\r\n        this.$message.error(\"请输入账号和密码！\");\r\n        return;\r\n      }\r\n      try {\r\n        const res = await request.post('/user/login', this.loginForm);\r\n        if (res.data.code === '200') {\r\n          localStorage.setItem(\"token\", res.data.data.token);\r\n          this.$message.success(\"登录成功！\");\r\n          this.$router.push(\"/home\");\r\n        } else {\r\n          this.$message.error(res.data.msg || \"登录失败\");\r\n        }\r\n      } catch (error) {\r\n        this.$message.error(\"登录失败，请检查网络！\");\r\n      }\r\n    },\r\n    async handleRegister() {\r\n      if (!this.registerForm.username || !this.registerForm.password) {\r\n        this.$message.error(\"请输入账号和密码！\");\r\n        return;\r\n      }\r\n      if (this.registerForm.password !== this.registerForm.confirmPassword) {\r\n        this.$message.error(\"两次密码不一致！\");\r\n        return;\r\n      }\r\n      try {\r\n        const res = await request.post('/user/register', this.registerForm);\r\n        if (res.data.code === '200') {\r\n          this.$message.success(\"注册成功，请登录！\");\r\n          this.activeTab = \"login\";\r\n        } else {\r\n          this.$message.error(res.data.msg || \"注册失败\");\r\n        }\r\n      } catch (error) {\r\n        this.$message.error(\"注册失败，请检查网络！\");\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* 登录页面容器 */\r\n.login-container {\r\n  height: 100vh;\r\n  width: 100vw;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  background-color: #f0f2f5;\r\n  overflow: hidden;\r\n  position: relative;\r\n}\r\n\r\n/* 动态背景（加入交通/无人机元素） */\r\n.login-bg {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  background: linear-gradient(135deg, #2b6cb0 0%, #1a365d 100%);\r\n  animation: bg-shift 15s ease infinite;\r\n  background-size: 400% 400%;\r\n  z-index: 0;\r\n}\r\n\r\n/* 背景动画 */\r\n@keyframes bg-shift {\r\n  0% { background-position: 0% 50%; }\r\n  50% { background-position: 100% 50%; }\r\n  100% { background-position: 0% 50%; }\r\n}\r\n\r\n/* 背景装饰：无人机剪影（CSS绘制） */\r\n.bg-drone {\r\n  position: absolute;\r\n  top: 20%;\r\n  right: 15%;\r\n  width: 80px;\r\n  height: 50px;\r\n  background: rgba(255, 255, 255, 0.1);\r\n  border-radius: 10px;\r\n  transform: rotate(15deg);\r\n  animation: drone-fly 20s linear infinite;\r\n}\r\n.bg-drone::before, .bg-drone::after {\r\n  content: '';\r\n  position: absolute;\r\n  width: 30px;\r\n  height: 10px;\r\n  background: rgba(255, 255, 255, 0.1);\r\n  top: 20px;\r\n}\r\n.bg-drone::before { left: -30px; }\r\n.bg-drone::after { right: -30px; }\r\n/* 无人机飞行动画 */\r\n@keyframes drone-fly {\r\n  0% { right: -10%; top: 20%; }\r\n  50% { top: 30%; }\r\n  100% { right: 110%; top: 20%; }\r\n}\r\n\r\n/* 背景装饰：道路标线（CSS绘制） */\r\n.bg-road {\r\n  position: absolute;\r\n  bottom: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 120px;\r\n  background: rgba(0, 0, 0, 0.1);\r\n}\r\n.bg-road::before {\r\n  content: '';\r\n  position: absolute;\r\n  top: 50%;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 4px;\r\n  background: repeating-linear-gradient(\r\n      to right,\r\n      rgba(255, 255, 255, 0.2),\r\n      rgba(255, 255, 255, 0.2) 40px,\r\n      transparent 40px,\r\n      transparent 80px\r\n  );\r\n  animation: road-line 10s linear infinite;\r\n}\r\n/* 道路标线滚动动画 */\r\n@keyframes road-line {\r\n  0% { transform: translateX(0); }\r\n  100% { transform: translateX(-80px); }\r\n}\r\n\r\n/* 登录卡片 */\r\n.login-card {\r\n  width: 420px;\r\n  border-radius: 12px;\r\n  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);\r\n  background-color: rgba(255, 255, 255, 0.95);\r\n  z-index: 1;\r\n  overflow: hidden;\r\n  transition: transform 0.3s ease;\r\n}\r\n.login-card:hover {\r\n  transform: translateY(-5px);\r\n}\r\n\r\n/* 系统标识：无人机图标（CSS绘制） */\r\n.card-header {\r\n  padding: 24px;\r\n  text-align: center;\r\n}\r\n.logo {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 24px;\r\n  font-weight: bold;\r\n  color: #2b6cb0;\r\n  margin-bottom: 8px;\r\n}\r\n/* 无人机图标（CSS绘制） */\r\n.drone-icon {\r\n  position: relative;\r\n  width: 36px;\r\n  height: 36px;\r\n  margin-right: 12px;\r\n}\r\n.drone-body {\r\n  position: absolute;\r\n  top: 12px;\r\n  left: 8px;\r\n  width: 20px;\r\n  height: 12px;\r\n  background: #4299e1;\r\n  border-radius: 6px;\r\n}\r\n.drone-wing {\r\n  position: absolute;\r\n  top: 16px;\r\n  width: 20px;\r\n  height: 4px;\r\n  background: #2b6cb0;\r\n  border-radius: 2px;\r\n}\r\n.drone-wing.left { left: -12px; }\r\n.drone-wing.right { right: -12px; }\r\n.drone-propeller {\r\n  position: absolute;\r\n  top: 8px;\r\n  width: 8px;\r\n  height: 8px;\r\n  border: 2px solid #2b6cb0;\r\n  border-radius: 50%;\r\n  animation: propeller-spin 1s linear infinite;\r\n}\r\n.drone-propeller.left { left: -16px; }\r\n.drone-propeller.right { right: -16px; }\r\n/* 螺旋桨旋转动画 */\r\n@keyframes propeller-spin {\r\n  0% { transform: rotate(0deg); }\r\n  100% { transform: rotate(360deg); }\r\n}\r\n\r\n.desc {\r\n  font-size: 14px;\r\n  color: #666;\r\n}\r\n\r\n/* 标签页/表单/按钮样式（保持之前的美化） */\r\n.tab-container {\r\n  padding: 0 24px 24px;\r\n}\r\n.login-form {\r\n  margin-top: 16px;\r\n}\r\n.input-item {\r\n  height: 48px;\r\n  font-size: 14px;\r\n  border-radius: 8px;\r\n  border-color: #e5e7eb;\r\n  transition: all 0.3s ease;\r\n}\r\n.input-item:focus {\r\n  border-color: #4299e1;\r\n  box-shadow: 0 0 0 2px rgba(66, 153, 225, 0.2);\r\n}\r\n.form-actions {\r\n  margin-top: 24px;\r\n}\r\n.login-btn {\r\n  width: 100%;\r\n  height: 48px;\r\n  font-size: 16px;\r\n  border-radius: 8px;\r\n  background: linear-gradient(135deg, #4299e1 0%, #2b6cb0 100%);\r\n  border: none;\r\n  transition: all 0.3s ease;\r\n}\r\n.login-btn:hover {\r\n  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 4px 12px rgba(66, 153, 225, 0.3);\r\n}\r\n</style>"],"mappings":";AA4GA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,SAAA;MACAC,SAAA;QAAAC,QAAA;QAAAC,QAAA;MAAA;MACAC,YAAA;QAAAF,QAAA;QAAAC,QAAA;QAAAE,eAAA;MAAA;IACA;EACA;EACAC,OAAA;IACA,MAAAC,YAAA;MACA,UAAAN,SAAA,CAAAC,QAAA,UAAAD,SAAA,CAAAE,QAAA;QACA,KAAAK,QAAA,CAAAC,KAAA;QACA;MACA;MACA;QACA,MAAAC,GAAA,SAAAb,OAAA,CAAAc,IAAA,qBAAAV,SAAA;QACA,IAAAS,GAAA,CAAAX,IAAA,CAAAa,IAAA;UACAC,YAAA,CAAAC,OAAA,UAAAJ,GAAA,CAAAX,IAAA,CAAAA,IAAA,CAAAgB,KAAA;UACA,KAAAP,QAAA,CAAAQ,OAAA;UACA,KAAAC,OAAA,CAAAC,IAAA;QACA;UACA,KAAAV,QAAA,CAAAC,KAAA,CAAAC,GAAA,CAAAX,IAAA,CAAAoB,GAAA;QACA;MACA,SAAAV,KAAA;QACA,KAAAD,QAAA,CAAAC,KAAA;MACA;IACA;IACA,MAAAW,eAAA;MACA,UAAAhB,YAAA,CAAAF,QAAA,UAAAE,YAAA,CAAAD,QAAA;QACA,KAAAK,QAAA,CAAAC,KAAA;QACA;MACA;MACA,SAAAL,YAAA,CAAAD,QAAA,UAAAC,YAAA,CAAAC,eAAA;QACA,KAAAG,QAAA,CAAAC,KAAA;QACA;MACA;MACA;QACA,MAAAC,GAAA,SAAAb,OAAA,CAAAc,IAAA,wBAAAP,YAAA;QACA,IAAAM,GAAA,CAAAX,IAAA,CAAAa,IAAA;UACA,KAAAJ,QAAA,CAAAQ,OAAA;UACA,KAAAhB,SAAA;QACA;UACA,KAAAQ,QAAA,CAAAC,KAAA,CAAAC,GAAA,CAAAX,IAAA,CAAAoB,GAAA;QACA;MACA,SAAAV,KAAA;QACA,KAAAD,QAAA,CAAAC,KAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}