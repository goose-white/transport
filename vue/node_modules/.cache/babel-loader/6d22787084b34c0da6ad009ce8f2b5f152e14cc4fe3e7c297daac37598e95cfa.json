{"ast":null,"code":"export default {\n  name: \"drone\",\n  data() {\n    return {\n      tableData: [],\n      form: {},\n      dialogFormVisible: false,\n      queryKey: \"\" // 新增：存储查询关键词\n    };\n  },\n  created() {\n    this.load();\n  },\n  methods: {\n    save() {\n      // 原保存逻辑（保持不变）\n      this.request.post(\"/drone/save\", this.form).then(res => {\n        if (res.data) {\n          this.$message.success(\"保存成功!\");\n          this.dialogFormVisible = false;\n          this.load();\n        }\n      });\n    },\n    // 修改：load方法携带查询参数\n    load() {\n      this.request.get(\"/drone/getAllData\", {\n        params: {\n          queryKey: this.queryKey\n        } // 把查询关键词传给后端\n      }).then(res => {\n        this.tableData = res.data;\n      });\n    },\n    handleEdit(row) {\n      // 原编辑逻辑（保持不变）\n      this.form = row;\n      this.dialogFormVisible = true;\n    }\n  }\n};","map":{"version":3,"names":["name","data","tableData","form","dialogFormVisible","queryKey","created","load","methods","save","request","post","then","res","$message","success","get","params","handleEdit","row"],"sources":["src/views/drone.vue"],"sourcesContent":["<script>\r\nexport default {\r\n  name: \"drone\",\r\n  data() {\r\n    return {\r\n      tableData: [],\r\n      form: {},\r\n      dialogFormVisible: false,\r\n      queryKey: \"\" // 新增：存储查询关键词\r\n    };\r\n  },\r\n  created() {\r\n    this.load();\r\n  },\r\n  methods: {\r\n    save() {\r\n      // 原保存逻辑（保持不变）\r\n      this.request.post(\"/drone/save\", this.form).then(res=>{\r\n        if (res.data){\r\n          this.$message.success(\"保存成功!\")\r\n          this.dialogFormVisible = false\r\n          this.load()\r\n        }\r\n      })\r\n    },\r\n    // 修改：load方法携带查询参数\r\n    load() {\r\n      this.request.get(\"/drone/getAllData\", {\r\n        params: { queryKey: this.queryKey } // 把查询关键词传给后端\r\n      }).then(res=>{\r\n        this.tableData = res.data\r\n      })\r\n    },\r\n    handleEdit(row){\r\n      // 原编辑逻辑（保持不变）\r\n      this.form = row\r\n      this.dialogFormVisible = true\r\n    },\r\n  }\r\n};\r\n</script>\r\n\r\n<template>\r\n  <div>\r\n    <!-- 新增：查询区域 -->\r\n    <el-form inline style=\"margin-bottom: 15px;\">\r\n      <el-form-item label=\"快速查询\">\r\n        <el-input\r\n            v-model=\"queryKey\"\r\n            placeholder=\"输入编号/姓名/年龄\"\r\n            style=\"width: 220px;\"\r\n        ></el-input>\r\n      </el-form-item>\r\n      <el-form-item>\r\n        <el-button type=\"primary\" @click=\"load\">查询</el-button>\r\n      </el-form-item>\r\n    </el-form>\r\n    <el-dialog title=\"设备信息\" :visible.sync=\"dialogFormVisible\" width=\"30%\">\r\n      <el-form label-width=\"80px\" size=\"small\">\r\n        <el-form-item label=\"设备状态\" >\r\n          <el-input v-model=\"form.status\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"电池电量\" >\r\n          <el-input v-model=\"form.battery\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"设备类型\" >\r\n          <el-input v-model=\"form.model\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <el-table\r\n        :data=\"drone\"\r\n        style=\"width: 100%\"\r\n        :row-class-name=\"tableRowClassName\">\r\n      <el-table-column\r\n          prop=\"id\"\r\n          label=\"唯一标识（主键）\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"model\"\r\n          label=\"设备类型\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"status\"\r\n          label=\"设备状态 (0 - 待命，1 - 飞行，2 - 维修)\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"battery\"\r\n          label=\"电池电量\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"maxSpeed\"\r\n          label=\"最快飞行速度\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"maxFlightTime\"\r\n          label=\"最大续航时间（分钟）\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column label = \"操作\">\r\n        <template v-slot = \"scope\">\r\n          <el-button type = \"success\" @click = \"handleEdit(scope.row)\"> 编辑 <i class = \"el-icon-edit\"></i></el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":"AACA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,SAAA;MACAC,IAAA;MACAC,iBAAA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACAC,KAAA;MACA;MACA,KAAAC,OAAA,CAAAC,IAAA,qBAAAR,IAAA,EAAAS,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAZ,IAAA;UACA,KAAAa,QAAA,CAAAC,OAAA;UACA,KAAAX,iBAAA;UACA,KAAAG,IAAA;QACA;MACA;IACA;IACA;IACAA,KAAA;MACA,KAAAG,OAAA,CAAAM,GAAA;QACAC,MAAA;UAAAZ,QAAA,OAAAA;QAAA;MACA,GAAAO,IAAA,CAAAC,GAAA;QACA,KAAAX,SAAA,GAAAW,GAAA,CAAAZ,IAAA;MACA;IACA;IACAiB,WAAAC,GAAA;MACA;MACA,KAAAhB,IAAA,GAAAgB,GAAA;MACA,KAAAf,iBAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}