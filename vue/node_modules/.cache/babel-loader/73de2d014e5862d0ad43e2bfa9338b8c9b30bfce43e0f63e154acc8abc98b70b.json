{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\nimport request from '@/utils/request';\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      // ✅ 初始值必须是空数组（第一层兜底）\n      loading: false,\n      dialogFormVisible: false,\n      form: {},\n      formRules: {\n        name: [{\n          required: true,\n          message: '请输入任务名称',\n          trigger: 'blur'\n        }],\n        // 改为name\n        type: [{\n          required: true,\n          message: '请选择任务类型',\n          trigger: 'change'\n        }],\n        // 改为type\n        device_id: [{\n          required: true,\n          message: '请输入无人机ID',\n          trigger: 'blur'\n        }] // 改为device_id\n      }\n    };\n  },\n  created() {\n    this.loadTaskData();\n  },\n  methods: {\n    resetForm() {\n      this.form = {};\n      this.$refs.formRef?.resetFields();\n    },\n    // 核心修复：强制确保 taskList 是数组\n    async loadTaskData() {\n      try {\n        this.loading = true;\n        const res = await request.get(\"/task/getAllData\", {});\n\n        // 👇 调试：打印接口返回，帮你定位真实格式\n        console.log('接口返回完整数据：', res);\n        console.log('res.data 类型：', Object.prototype.toString.call(res.data));\n\n        // 【终极兜底逻辑】不管接口返回什么，最终只取数组\n        let tableData = [];\n        // 场景1：接口返回 {code:200, data: [...]} → 取 res.data.data\n        if (res?.data?.data && Array.isArray(res.data.data)) {\n          tableData = res.data.data;\n        }\n        // 场景2：接口直接返回数组 → 取 res.data\n        else if (Array.isArray(res.data)) {\n          tableData = res.data;\n        }\n        // 场景3：其他格式 → 空数组（兜底）\n        else {\n          tableData = [];\n        }\n\n        // ✅ 最后强制校验：确保是数组（第二层兜底）\n        this.taskList = Array.isArray(tableData) ? tableData : [];\n      } catch (error) {\n        console.error('加载失败：', error);\n        this.taskList = []; // ❗ 异常时必重置为空数组\n        this.$message.error('数据加载失败，请重试');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleAdd() {\n      this.form = {};\n      this.dialogFormVisible = true;\n    },\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row));\n      this.dialogFormVisible = true;\n    },\n    async saveTask() {\n      try {\n        await this.$refs.formRef.validate();\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\";\n        const res = await request.post(apiUrl, this.form);\n        if (res?.code === 200) {\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功');\n          this.dialogFormVisible = false;\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '保存失败');\n        }\n      } catch (error) {\n        this.$message.error('保存失败，请检查数据');\n      }\n    },\n    async handleDelete(row) {\n      try {\n        await this.$confirm('确定删除该任务？', '提示', {\n          type: 'warning'\n        });\n        const res = await request.post(\"/task/delete\", {\n          id: row.id\n        });\n        if (res?.code === 200) {\n          this.$message.success('删除成功');\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '删除失败');\n        }\n      } catch (error) {\n        if (error !== 'cancel') this.$message.error('删除失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","formRules","required","message","trigger","type","device_id","created","loadTaskData","methods","resetForm","$refs","formRef","resetFields","res","get","console","log","Object","prototype","toString","call","tableData","Array","isArray","error","$message","handleAdd","handleEdit","row","JSON","parse","stringify","saveTask","validate","apiUrl","id","post","code","success","msg","handleDelete","$confirm"],"sources":["src/views/task.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 新增/编辑弹窗 -->\r\n    <el-dialog title=\"任务信息\" v-model=\"dialogFormVisible\" width=\"500px\" @close=\"resetForm\">\r\n      <el-form ref=\"formRef\" :model=\"form\" label-width=\"100px\" size=\"small\" :rules=\"formRules\">\r\n        <el-form-item label=\"任务名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"type\">\r\n          <el-select v-model=\"form.type\" placeholder=\"请选择任务类型\">\r\n            <el-option label=\"巡逻任务\" value=\"巡逻任务\"></el-option>\r\n            <el-option label=\"巡检任务\" value=\"巡检任务\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"device_id\">\r\n          <el-input v-model=\"form.device_id\" placeholder=\"请输入无人机ID\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTask\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 新增按钮 -->\r\n    <el-button type=\"primary\" style=\"margin-bottom: 20px;\" @click=\"handleAdd\">新增任务</el-button>\r\n\r\n    <!-- 任务表格（核心：绑定数组 + 匹配后端字段） -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column prop=\"id\" label=\"任务ID\" width=\"120\" />\r\n      <el-table-column prop=\"name\" label=\"任务名称\" width=\"180\" /> <!-- 改为name -->\r\n      <el-table-column prop=\"type\" label=\"任务类型\" width=\"120\" /> <!-- 改为type -->\r\n      <el-table-column prop=\"device_id\" label=\"执行无人机\" width=\"120\" /> <!-- 改为device_id -->\r\n      <el-table-column prop=\"start_time\" label=\"创建时间\" width=\"180\" /> <!-- 改为start_time -->\r\n      <el-table-column label=\"操作\" width=\"150\">\r\n        <template #default=\"scope\">\r\n          <el-button type=\"primary\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click=\"handleDelete(scope.row)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [], // ✅ 初始值必须是空数组（第一层兜底）\r\n      loading: false,\r\n      dialogFormVisible: false,\r\n      form: {},\r\n      formRules: {\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }], // 改为name\r\n        type: [{ required: true, message: '请选择任务类型', trigger: 'change' }], // 改为type\r\n        device_id: [{ required: true, message: '请输入无人机ID', trigger: 'blur' }] // 改为device_id\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData()\r\n  },\r\n  methods: {\r\n    resetForm() {\r\n      this.form = {}\r\n      this.$refs.formRef?.resetFields()\r\n    },\r\n\r\n    // 核心修复：强制确保 taskList 是数组\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true\r\n        const res = await request.get(\"/task/getAllData\", {})\r\n\r\n        // 👇 调试：打印接口返回，帮你定位真实格式\r\n        console.log('接口返回完整数据：', res)\r\n        console.log('res.data 类型：', Object.prototype.toString.call(res.data))\r\n\r\n        // 【终极兜底逻辑】不管接口返回什么，最终只取数组\r\n        let tableData = []\r\n        // 场景1：接口返回 {code:200, data: [...]} → 取 res.data.data\r\n        if (res?.data?.data && Array.isArray(res.data.data)) {\r\n          tableData = res.data.data\r\n        }\r\n        // 场景2：接口直接返回数组 → 取 res.data\r\n        else if (Array.isArray(res.data)) {\r\n          tableData = res.data\r\n        }\r\n        // 场景3：其他格式 → 空数组（兜底）\r\n        else {\r\n          tableData = []\r\n        }\r\n\r\n        // ✅ 最后强制校验：确保是数组（第二层兜底）\r\n        this.taskList = Array.isArray(tableData) ? tableData : []\r\n      } catch (error) {\r\n        console.error('加载失败：', error)\r\n        this.taskList = [] // ❗ 异常时必重置为空数组\r\n        this.$message.error('数据加载失败，请重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    handleAdd() {\r\n      this.form = {}\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    handleEdit(row) {\r\n      this.form = JSON.parse(JSON.stringify(row))\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    async saveTask() {\r\n      try {\r\n        await this.$refs.formRef.validate()\r\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\"\r\n        const res = await request.post(apiUrl, this.form)\r\n        if (res?.code === 200) {\r\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功')\r\n          this.dialogFormVisible = false\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '保存失败')\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('保存失败，请检查数据')\r\n      }\r\n    },\r\n\r\n    async handleDelete(row) {\r\n      try {\r\n        await this.$confirm('确定删除该任务？', '提示', { type: 'warning' })\r\n        const res = await request.post(\"/task/delete\", { id: row.id })\r\n        if (res?.code === 200) {\r\n          this.$message.success('删除成功')\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') this.$message.error('删除失败')\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n:deep(.el-button) { margin: 0 4px; }\r\n:deep(.el-form-item) { margin-bottom: 15px; }\r\n</style>"],"mappings":";;AAmDA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MAAA;MACAC,OAAA;MACAC,iBAAA;MACAC,IAAA;MACAC,SAAA;QACAN,IAAA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QAAA;QACAC,IAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QAAA;QACAE,SAAA;UAAAJ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAG,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACAC,UAAA;MACA,KAAAV,IAA