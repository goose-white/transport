{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\nimport request from '@/utils/request';\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      loading: false,\n      dialogFormVisible: false,\n      form: {},\n      queryForm: {\n        id: '',\n        name: '',\n        type: '',\n        deviceId: ''\n      },\n      formRules: {\n        name: [{\n          required: true,\n          message: '请输入任务名称',\n          trigger: 'blur'\n        }],\n        type: [{\n          required: true,\n          message: '请选择任务类型',\n          trigger: 'change'\n        }],\n        deviceId: [{\n          required: true,\n          message: '请输入无人机ID',\n          trigger: 'blur'\n        }, {\n          type: 'number',\n          message: '无人机ID必须为数字',\n          trigger: 'blur'\n        }],\n        status: [{\n          required: true,\n          message: '请选择任务状态',\n          trigger: 'change'\n        }]\n      }\n    };\n  },\n  created() {\n    this.loadTaskData();\n  },\n  methods: {\n    // 核心修复：适配后端datetime格式的时间转换函数\n    formatTime(timeStr) {\n      // 1. 空值/Null/空字符串直接返回“未设置”\n      if (!timeStr || timeStr === 'Null' || timeStr === 'null' || timeStr === '') return '未设置';\n      // 2. 兼容数组格式（旧数据）和字符串格式（新数据）\n      let timeValue = Array.isArray(timeStr) ? timeStr.join('-') : timeStr;\n      try {\n        // 3. 构造Date对象并转为本地时间格式\n        const date = new Date(timeValue);\n        // 4. 过滤Invalid Date情况\n        return date.toString() !== 'Invalid Date' ? date.toLocaleString() : '未设置';\n      } catch (e) {\n        // 5. 转换失败时返回原始值，避免页面报错\n        return timeValue || '未设置';\n      }\n    },\n    resetForm() {\n      this.form = {};\n      this.$refs.formRef && this.$refs.formRef.resetFields();\n    },\n    // 适配后端四个独立查询参数\n    async loadTaskData() {\n      try {\n        this.loading = true;\n        // 构造独立查询参数\n        const params = {};\n        if (this.queryForm.id) params.id = Number(this.queryForm.id);\n        if (this.queryForm.name) params.name = this.queryForm.name.trim();\n        if (this.queryForm.type) params.type = Number(this.queryForm.type);\n        if (this.queryForm.deviceId) params.deviceId = Number(this.queryForm.deviceId);\n\n        // 调用后端查询接口\n        const res = await request.get(\"/task/getAllData\", {\n          params\n        });\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : [];\n      } catch (error) {\n        console.error('加载任务数据失败：', error);\n        this.taskList = [];\n        this.$message.error('数据加载失败，请重试');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleQuery() {\n      this.loadTaskData();\n    },\n    handleReset() {\n      this.queryForm = {\n        id: '',\n        name: '',\n        type: '',\n        deviceId: ''\n      };\n      this.loadTaskData();\n    },\n    handleAdd() {\n      this.form = {\n        type: \"0\",\n        status: \"0\"\n      };\n      this.dialogFormVisible = true;\n    },\n    handleEdit(row) {\n      this.dialogFormVisible = true;\n      this.form = JSON.parse(JSON.stringify({\n        id: row.id,\n        name: row.name,\n        type: row.type?.toString() || \"0\",\n        deviceId: row.deviceId || \"\",\n        status: row.status?.toString() || \"0\"\n      }));\n      this.$nextTick(() => {\n        this.dialogFormVisible = true;\n      });\n    },\n    // 新增/编辑：仅显示成功提示，取消失败提示\n    async saveTask() {\n      try {\n        await this.$refs.formRef.validate();\n        const submitData = {\n          id: this.form.id ? Number(this.form.id) : null,\n          name: this.form.name,\n          type: parseInt(this.form.type) & 0xFF,\n          deviceId: Number(this.form.deviceId),\n          status: parseInt(this.form.status) & 0xFF,\n          startTime: new Date().toISOString(),\n          endTime: null\n        };\n        const res = await request.post(\"/task/save\", submitData);\n        // 仅在成功时显示提示\n        const isSuccess = String(res?.data?.code) === '200' || res?.data?.data?.includes('成功');\n        if (isSuccess) {\n          const tipMsg = res?.data?.data || (this.form.id ? '编辑成功' : '新增成功');\n          this.$message.success(tipMsg);\n        }\n        this.dialogFormVisible = false;\n        this.loadTaskData();\n      } catch (error) {\n        console.error('保存任务失败详情：', error);\n        this.dialogFormVisible = false;\n        this.loadTaskData();\n      }\n    },\n    // 删除：仅显示成功提示，取消失败提示\n    async handleDelete(row) {\n      try {\n        await this.$confirm('确定删除该任务？', '提示', {\n          type: 'warning'\n        });\n        const res = await request.post(\"/task/delete\", {}, {\n          params: {\n            id: row.id\n          }\n        });\n        // 仅在成功时显示提示\n        const isSuccess = String(res?.data?.code) === '200' || res?.data?.data?.includes('成功');\n        if (isSuccess) {\n          const tipMsg = res?.data?.data || '删除成功';\n          this.$message.success(tipMsg);\n        }\n        this.loadTaskData();\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('删除任务失败：', error);\n        }\n        this.loadTaskData();\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","queryForm","id","type","deviceId","formRules","required","message","trigger","status","created","loadTaskData","methods","formatTime","timeStr","timeValue","Array","isArray","join","date","Date","toString","toLocaleString","e","resetForm","$refs","formRef","resetFields","params","Number","trim","res","get","error","console","$message","handleQuery","handleReset","handleAdd","handleEdit","row","JSON","parse","stringify","$nextTick","saveTask","validate","submitData","parseInt","startTime","toISOString","endTime","post","isSuccess","String","code","includes","tipMsg","success","handleDelete","$confirm"],"sources":["src/views/task.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 查询条件区域 -->\r\n    <div style=\"margin-bottom: 20px; display: flex; align-items: center; gap: 15px;\">\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">任务ID：</label>\r\n        <el-input v-model=\"queryForm.id\" placeholder=\"输入任务ID\" style=\"width: 150px;\" />\r\n      </div>\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">任务名称：</label>\r\n        <el-input v-model=\"queryForm.name\" placeholder=\"输入任务名称\" style=\"width: 180px;\" />\r\n      </div>\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">任务类型：</label>\r\n        <el-input v-model=\"queryForm.type\" placeholder=\"输入任务类型（0-3）\" style=\"width: 150px;\" />\r\n      </div>\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">执行无人机：</label>\r\n        <el-input v-model=\"queryForm.deviceId\" placeholder=\"输入执行无人机ID\" style=\"width: 150px;\" />\r\n      </div>\r\n      <el-button type=\"primary\" @click=\"handleQuery\">查询</el-button>\r\n      <el-button @click=\"handleReset\">重置</el-button>\r\n    </div>\r\n\r\n    <!-- 新增按钮 -->\r\n    <el-button type=\"primary\" style=\"margin-bottom: 20px;\" @click=\"handleAdd\">新增任务</el-button>\r\n\r\n    <!-- 编辑弹窗 -->\r\n    <el-dialog\r\n        title=\"任务信息\"\r\n        :visible.sync=\"dialogFormVisible\"\r\n        width=\"500px\"\r\n        @close=\"resetForm\"\r\n    >\r\n      <el-form ref=\"formRef\" :model=\"form\" label-width=\"100px\" size=\"small\" :rules=\"formRules\">\r\n        <el-form-item label=\"任务名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"type\">\r\n          <el-select v-model=\"form.type\" placeholder=\"请选择任务类型\">\r\n            <el-option label=\"0-道路巡航\" value=\"0\"></el-option>\r\n            <el-option label=\"1-水域巡逻\" value=\"1\"></el-option>\r\n            <el-option label=\"2-事故取证\" value=\"2\"></el-option>\r\n            <el-option label=\"3-隐患排查\" value=\"3\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"deviceId\">\r\n          <el-input v-model.number=\"form.deviceId\" placeholder=\"请输入无人机ID\" type=\"number\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务状态\" prop=\"status\">\r\n          <el-select v-model=\"form.status\" placeholder=\"请选择任务状态\">\r\n            <el-option label=\"0-未开始\" value=\"0\"></el-option>\r\n            <el-option label=\"1-执行中\" value=\"1\"></el-option>\r\n            <el-option label=\"2-已完成\" value=\"2\"></el-option>\r\n            <el-option label=\"3-已取消\" value=\"3\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTask\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 任务表格（修复时间格式+操作列） -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column prop=\"id\" label=\"任务ID\" width=\"120\" />\r\n      <el-table-column prop=\"name\" label=\"任务名称\" width=\"180\" />\r\n      <el-table-column prop=\"type\" label=\"任务类型\" width=\"120\" />\r\n      <el-table-column prop=\"deviceId\" label=\"执行无人机\" width=\"120\" />\r\n      <!-- 修复：时间格式转换 -->\r\n      <el-table-column label=\"创建时间\" width=\"180\">\r\n        <template slot-scope=\"scope\">\r\n          {{ formatTime(scope.row.startTime) }}\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column label=\"任务结束时间\" width=\"180\">\r\n        <template slot-scope=\"scope\">\r\n          {{ formatTime(scope.row.endTime) }}\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"status\" label=\"任务状态\" width=\"120\" />\r\n      <el-table-column label=\"操作\" width=\"150\">\r\n        <template slot-scope=\"scope\">\r\n          <el-button type=\"primary\" size=\"small\" @click.stop=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click.stop=\"handleDelete(scope.row)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [],\r\n      loading: false,\r\n      dialogFormVisible: false,\r\n      form: {},\r\n      queryForm: {\r\n        id: '',\r\n        name: '',\r\n        type: '',\r\n        deviceId: ''\r\n      },\r\n      formRules: {\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请选择任务类型', trigger: 'change' }],\r\n        deviceId: [\r\n          { required: true, message: '请输入无人机ID', trigger: 'blur' },\r\n          { type: 'number', message: '无人机ID必须为数字', trigger: 'blur' }\r\n        ],\r\n        status: [{ required: true, message: '请选择任务状态', trigger: 'change' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData()\r\n  },\r\n  methods: {\r\n    // 核心修复：适配后端datetime格式的时间转换函数\r\n    formatTime(timeStr) {\r\n      // 1. 空值/Null/空字符串直接返回“未设置”\r\n      if (!timeStr || timeStr === 'Null' || timeStr === 'null' || timeStr === '') return '未设置'\r\n      // 2. 兼容数组格式（旧数据）和字符串格式（新数据）\r\n      let timeValue = Array.isArray(timeStr) ? timeStr.join('-') : timeStr\r\n      try {\r\n        // 3. 构造Date对象并转为本地时间格式\r\n        const date = new Date(timeValue)\r\n        // 4. 过滤Invalid Date情况\r\n        return date.toString() !== 'Invalid Date' ? date.toLocaleString() : '未设置'\r\n      } catch (e) {\r\n        // 5. 转换失败时返回原始值，避免页面报错\r\n        return timeValue || '未设置'\r\n      }\r\n    },\r\n\r\n    resetForm() {\r\n      this.form = {}\r\n      this.$refs.formRef && this.$refs.formRef.resetFields()\r\n    },\r\n\r\n    // 适配后端四个独立查询参数\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true\r\n        // 构造独立查询参数\r\n        const params = {}\r\n        if (this.queryForm.id) params.id = Number(this.queryForm.id)\r\n        if (this.queryForm.name) params.name = this.queryForm.name.trim()\r\n        if (this.queryForm.type) params.type = Number(this.queryForm.type)\r\n        if (this.queryForm.deviceId) params.deviceId = Number(this.queryForm.deviceId)\r\n\r\n        // 调用后端查询接口\r\n        const res = await request.get(\"/task/getAllData\", { params })\r\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : []\r\n      } catch (error) {\r\n        console.error('加载任务数据失败：', error)\r\n        this.taskList = []\r\n        this.$message.error('数据加载失败，请重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    handleQuery() {\r\n      this.loadTaskData()\r\n    },\r\n\r\n    handleReset() {\r\n      this.queryForm = {\r\n        id: '',\r\n        name: '',\r\n        type: '',\r\n        deviceId: ''\r\n      }\r\n      this.loadTaskData()\r\n    },\r\n\r\n    handleAdd() {\r\n      this.form = { type: \"0\", status: \"0\" }\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    handleEdit(row) {\r\n      this.dialogFormVisible = true\r\n      this.form = JSON.parse(JSON.stringify({\r\n        id: row.id,\r\n        name: row.name,\r\n        type: row.type?.toString() || \"0\",\r\n        deviceId: row.deviceId || \"\",\r\n        status: row.status?.toString() || \"0\"\r\n      }))\r\n      this.$nextTick(() => {\r\n        this.dialogFormVisible = true\r\n      })\r\n    },\r\n\r\n    // 新增/编辑：仅显示成功提示，取消失败提示\r\n    async saveTask() {\r\n      try {\r\n        await this.$refs.formRef.validate()\r\n        const submitData = {\r\n          id: this.form.id ? Number(this.form.id) : null,\r\n          name: this.form.name,\r\n          type: parseInt(this.form.type) & 0xFF,\r\n          deviceId: Number(this.form.deviceId),\r\n          status: parseInt(this.form.status) & 0xFF,\r\n          startTime: new Date().toISOString(),\r\n          endTime: null\r\n        }\r\n\r\n        const res = await request.post(\"/task/save\", submitData)\r\n        // 仅在成功时显示提示\r\n        const isSuccess = String(res?.data?.code) === '200' || res?.data?.data?.includes('成功')\r\n        if (isSuccess) {\r\n          const tipMsg = res?.data?.data || (this.form.id ? '编辑成功' : '新增成功')\r\n          this.$message.success(tipMsg)\r\n        }\r\n\r\n        this.dialogFormVisible = false\r\n        this.loadTaskData()\r\n\r\n      } catch (error) {\r\n        console.error('保存任务失败详情：', error)\r\n        this.dialogFormVisible = false\r\n        this.loadTaskData()\r\n      }\r\n    },\r\n\r\n    // 删除：仅显示成功提示，取消失败提示\r\n    async handleDelete(row) {\r\n      try {\r\n        await this.$confirm('确定删除该任务？', '提示', { type: 'warning' })\r\n        const res = await request.post(\"/task/delete\", {}, {\r\n          params: { id: row.id }\r\n        })\r\n        // 仅在成功时显示提示\r\n        const isSuccess = String(res?.data?.code) === '200' || res?.data?.data?.includes('成功')\r\n        if (isSuccess) {\r\n          const tipMsg = res?.data?.data || '删除成功'\r\n          this.$message.success(tipMsg)\r\n        }\r\n\r\n        this.loadTaskData()\r\n\r\n      } catch (error) {\r\n        if (error !== 'cancel') {\r\n          console.error('删除任务失败：', error)\r\n        }\r\n        this.loadTaskData()\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n::v-deep .el-button { margin: 0 4px; }\r\n::v-deep .el-form-item { margin-bottom: 15px; }\r\n</style>"],"mappings":";;AAmGA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,OAAA;MACAC,iBAAA;MACAC,IAAA;MACAC,SAAA;QACAC,EAAA;QACAP,IAAA;QACAQ,IAAA;QACAC,QAAA;MACA;MACAC,SAAA;QACAV,IAAA;UAAAW,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAL,IAAA