{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport request from '@/utils/request';\nexport default {\n  name: \"Login\",\n  data() {\n    return {\n      activeTab: \"login\",\n      loginForm: {\n        username: \"\",\n        password: \"\"\n      },\n      registerForm: {\n        username: \"\",\n        password: \"\",\n        confirmPassword: \"\"\n      }\n    };\n  },\n  methods: {\n    // 登录方法（带async）\n    async handleLogin() {\n      if (!this.loginForm.username || !this.loginForm.password) {\n        this.$message.error(\"请输入账号和密码！\");\n        return;\n      }\n      try {\n        const res = await request.post('/user/login', this.loginForm);\n        if (res.data.code === '200') {\n          localStorage.setItem(\"token\", res.data.data.token);\n          this.$message.success(\"登录成功！\");\n          this.$router.push(\"/home\");\n        } else {\n          this.$message.error(res.data.msg || \"登录失败\");\n        }\n      } catch (error) {\n        this.$message.error(\"登录失败，请检查网络！\");\n      }\n    },\n    // 注册方法（修复：添加async关键字）\n    async handleRegister() {\n      if (!this.registerForm.username || !this.registerForm.password) {\n        this.$message.error(\"请输入账号和密码！\");\n        return;\n      }\n      if (this.registerForm.password !== this.registerForm.confirmPassword) {\n        this.$message.error(\"两次密码不一致！\");\n        return;\n      }\n      try {\n        const res = await request.post('/user/register', this.registerForm);\n        if (res.data.code === '200') {\n          this.$message.success(\"注册成功，请登录！\");\n          this.activeTab = \"login\";\n        } else {\n          this.$message.error(res.data.msg || \"注册失败\");\n        }\n      } catch (error) {\n        this.$message.error(\"注册失败，请检查网络！\");\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","activeTab","loginForm","username","password","registerForm","confirmPassword","methods","handleLogin","$message","error","res","post","code","localStorage","setItem","token","success","$router","push","msg","handleRegister"],"sources":["src/views/login/Login.vue"],"sourcesContent":["<template>\r\n  <div class=\"login-container\">\r\n    <!-- 动态背景（渐变+粒子效果） -->\r\n    <div class=\"login-bg\"></div>\r\n    <!-- 登录卡片 -->\r\n    <el-card class=\"login-card\" shadow=\"hover\">\r\n      <div class=\"card-header\">\r\n        <div class=\"logo\">\r\n          <i class=\"el-icon-airplane\"></i>\r\n          <span>无人机管理系统</span>\r\n        </div>\r\n        <div class=\"desc\">请登录您的账号</div>\r\n      </div>\r\n\r\n      <el-tabs v-model=\"activeTab\" type=\"border-card\" class=\"tab-container\">\r\n        <!-- 登录标签页 -->\r\n        <el-tab-pane label=\"登录\" name=\"login\">\r\n          <el-form :model=\"loginForm\" label-width=\"0\" class=\"login-form\">\r\n            <el-form-item prop=\"username\">\r\n              <el-input\r\n                  v-model=\"loginForm.username\"\r\n                  placeholder=\"请输入账号\"\r\n                  prefix-icon=\"el-icon-user\"\r\n                  class=\"input-item\"\r\n              />\r\n            </el-form-item>\r\n            <el-form-item prop=\"password\">\r\n              <el-input\r\n                  v-model=\"loginForm.password\"\r\n                  type=\"password\"\r\n                  placeholder=\"请输入密码\"\r\n                  prefix-icon=\"el-icon-lock\"\r\n                  class=\"input-item\"\r\n              />\r\n            </el-form-item>\r\n            <el-form-item class=\"form-actions\">\r\n              <el-button\r\n                  type=\"primary\"\r\n                  @click=\"handleLogin\"\r\n                  class=\"login-btn\"\r\n                  icon=\"el-icon-right\"\r\n              >\r\n                登录\r\n              </el-button>\r\n            </el-form-item>\r\n          </el-form>\r\n        </el-tab-pane>\r\n\r\n        <!-- 注册标签页 -->\r\n        <el-tab-pane label=\"注册\" name=\"register\">\r\n          <el-form :model=\"registerForm\" label-width=\"0\" class=\"login-form\">\r\n            <el-form-item prop=\"username\">\r\n              <el-input\r\n                  v-model=\"registerForm.username\"\r\n                  placeholder=\"请输入账号\"\r\n                  prefix-icon=\"el-icon-user\"\r\n                  class=\"input-item\"\r\n              />\r\n            </el-form-item>\r\n            <el-form-item prop=\"password\">\r\n              <el-input\r\n                  v-model=\"registerForm.password\"\r\n                  type=\"password\"\r\n                  placeholder=\"请输入密码\"\r\n                  prefix-icon=\"el-icon-lock\"\r\n                  class=\"input-item\"\r\n              />\r\n            </el-form-item>\r\n            <el-form-item prop=\"confirmPassword\">\r\n              <el-input\r\n                  v-model=\"registerForm.confirmPassword\"\r\n                  type=\"password\"\r\n                  placeholder=\"请确认密码\"\r\n                  prefix-icon=\"el-icon-lock\"\r\n                  class=\"input-item\"\r\n              />\r\n            </el-form-item>\r\n            <el-form-item class=\"form-actions\">\r\n              <el-button\r\n                  type=\"primary\"\r\n                  @click=\"handleRegister\"\r\n                  class=\"login-btn\"\r\n                  icon=\"el-icon-check\"\r\n              >\r\n                注册\r\n              </el-button>\r\n            </el-form-item>\r\n          </el-form>\r\n        </el-tab-pane>\r\n      </el-tabs>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Login\",\r\n  data() {\r\n    return {\r\n      activeTab: \"login\",\r\n      loginForm: { username: \"\", password: \"\" },\r\n      registerForm: { username: \"\", password: \"\", confirmPassword: \"\" }\r\n    };\r\n  },\r\n  methods: {\r\n    // 登录方法（带async）\r\n    async handleLogin() {\r\n      if (!this.loginForm.username || !this.loginForm.password) {\r\n        this.$message.error(\"请输入账号和密码！\");\r\n        return;\r\n      }\r\n      try {\r\n        const res = await request.post('/user/login', this.loginForm);\r\n        if (res.data.code === '200') {\r\n          localStorage.setItem(\"token\", res.data.data.token);\r\n          this.$message.success(\"登录成功！\");\r\n          this.$router.push(\"/home\");\r\n        } else {\r\n          this.$message.error(res.data.msg || \"登录失败\");\r\n        }\r\n      } catch (error) {\r\n        this.$message.error(\"登录失败，请检查网络！\");\r\n      }\r\n    },\r\n    // 注册方法（修复：添加async关键字）\r\n    async handleRegister() {\r\n      if (!this.registerForm.username || !this.registerForm.password) {\r\n        this.$message.error(\"请输入账号和密码！\");\r\n        return;\r\n      }\r\n      if (this.registerForm.password !== this.registerForm.confirmPassword) {\r\n        this.$message.error(\"两次密码不一致！\");\r\n        return;\r\n      }\r\n      try {\r\n        const res = await request.post('/user/register', this.registerForm);\r\n        if (res.data.code === '200') {\r\n          this.$message.success(\"注册成功，请登录！\");\r\n          this.activeTab = \"login\";\r\n        } else {\r\n          this.$message.error(res.data.msg || \"注册失败\");\r\n        }\r\n      } catch (error) {\r\n        this.$message.error(\"注册失败，请检查网络！\");\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* 登录页面容器 */\r\n.login-container {\r\n  height: 100vh;\r\n  width: 100vw;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  background-color: #f0f2f5;\r\n  overflow: hidden;\r\n  position: relative;\r\n}\r\n\r\n/* 动态背景 */\r\n.login-bg {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  background: linear-gradient(135deg, #4299e1 0%, #2b6cb0 100%);\r\n  /* 背景动画 */\r\n  animation: bg-shift 15s ease infinite;\r\n  background-size: 400% 400%;\r\n  z-index: 0;\r\n}\r\n\r\n/* 背景渐变动画 */\r\n@keyframes bg-shift {\r\n  0% { background-position: 0% 50%; }\r\n  50% { background-position: 100% 50%; }\r\n  100% { background-position: 0% 50%; }\r\n}\r\n\r\n/* 登录卡片 */\r\n.login-card {\r\n  width: 420px;\r\n  border-radius: 12px;\r\n  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);\r\n  background-color: rgba(255, 255, 255, 0.95);\r\n  z-index: 1;\r\n  overflow: hidden;\r\n  transition: transform 0.3s ease;\r\n}\r\n\r\n/* 卡片悬浮动画 */\r\n.login-card:hover {\r\n  transform: translateY(-5px);\r\n}\r\n\r\n/* 卡片头部 */\r\n.card-header {\r\n  padding: 24px;\r\n  text-align: center;\r\n}\r\n\r\n.logo {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 24px;\r\n  font-weight: bold;\r\n  color: #2b6cb0;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.logo i {\r\n  font-size: 28px;\r\n  margin-right: 8px;\r\n  color: #4299e1;\r\n}\r\n\r\n.desc {\r\n  font-size: 14px;\r\n  color: #666;\r\n}\r\n\r\n/* 标签页容器 */\r\n.tab-container {\r\n  padding: 0 24px 24px;\r\n}\r\n\r\n/* 表单样式 */\r\n.login-form {\r\n  margin-top: 16px;\r\n}\r\n\r\n/* 输入框样式 */\r\n.input-item {\r\n  height: 48px;\r\n  font-size: 14px;\r\n  border-radius: 8px;\r\n  border-color: #e5e7eb;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.input-item:focus {\r\n  border-color: #4299e1;\r\n  box-shadow: 0 0 0 2px rgba(66, 153, 225, 0.2);\r\n}\r\n\r\n/* 按钮样式 */\r\n.form-actions {\r\n  margin-top: 24px;\r\n}\r\n\r\n.login-btn {\r\n  width: 100%;\r\n  height: 48px;\r\n  font-size: 16px;\r\n  border-radius: 8px;\r\n  background: linear-gradient(135deg, #4299e1 0%, #2b6cb0 100%);\r\n  border: none;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.login-btn:hover {\r\n  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 4px 12px rgba(66, 153, 225, 0.3);\r\n}\r\n</style>"],"mappings":";AA+FA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,SAAA;MACAC,SAAA;QAAAC,QAAA;QAAAC,QAAA;MAAA;MACAC,YAAA;QAAAF,QAAA;QAAAC,QAAA;QAAAE,eAAA;MAAA;IACA;EACA;EACAC,OAAA;IACA;IACA,