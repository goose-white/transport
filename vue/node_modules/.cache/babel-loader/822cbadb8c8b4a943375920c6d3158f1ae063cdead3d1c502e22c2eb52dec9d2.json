{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.some.js\";\nimport Aside from \"@/components/Aside\";\nexport default {\n  components: {\n    Aside\n  },\n  data() {\n    return {\n      isCollapse: false,\n      sideWidth: 300,\n      logoTextShow: true,\n      timeTimer: null,\n      // 标签页相关数据\n      activeTab: \"/home\",\n      // 当前激活的标签\n      tabs: [\n      // 初始标签（主页）\n      {\n        path: \"/home\",\n        name: \"主页\"\n      }]\n    };\n  },\n  methods: {\n    collapse() {\n      this.isCollapse = !this.isCollapse;\n      this.sideWidth = this.isCollapse ? 64 : 300;\n      this.logoTextShow = !this.isCollapse;\n    },\n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    },\n    getCurrentDate() {\n      // 日期时间逻辑（原有）\n      const date = new Date();\n      const year = date.getFullYear();\n      const month = (date.getMonth() + 1).toString().padStart(2, '0');\n      const day = date.getDate().toString().padStart(2, '0');\n      const hour = date.getHours().toString().padStart(2, '0');\n      const minute = date.getMinutes().toString().padStart(2, '0');\n      const second = date.getSeconds().toString().padStart(2, '0');\n      const week = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'][date.getDay()];\n      document.getElementById('current-date').innerText = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\n    },\n    // 新增：添加标签页\n    addTab(route) {\n      const isExist = this.tabs.some(tab => tab.path === route.path);\n      if (!isExist) {\n        this.tabs.push({\n          path: route.path,\n          name: this.getTabName(route.path)\n        });\n      }\n      this.activeTab = route.path;\n    },\n    // 新增：关闭标签页\n    closeTab(path) {\n      const index = this.tabs.findIndex(tab => tab.path === path);\n      this.tabs.splice(index, 1);\n      // 关闭后激活前一个标签\n      if (this.activeTab === path) {\n        this.activeTab = this.tabs.length > 0 ? this.tabs[this.tabs.length - 1].path : \"/home\";\n        this.$router.push(this.activeTab);\n      }\n    },\n    // 新增：根据路由路径获取标签名称\n    getTabName(path) {\n      const tabMap = {\n        \"/home\": \"主页\",\n        \"/drone\": \"无人机管理\",\n        \"/task\": \"无人机任务管理\",\n        \"/photography\": \"现场视频\",\n        \"/recognition\": \"识别结果\"\n      };\n      return tabMap[path] || \"未知页面\";\n    }\n  },\n  watch: {\n    // 新增：监听路由变化，自动添加标签\n    $route(to) {\n      this.addTab(to);\n    }\n  },\n  mounted() {\n    this.getCurrentDate();\n    this.timeTimer = setInterval(() => {\n      this.getCurrentDate();\n    }, 1000);\n    // 初始化时添加当前路由标签\n    this.addTab(this.$route);\n  },\n  beforeDestroy() {\n    if (this.timeTimer) {\n      clearInterval(this.timeTimer);\n    }\n  }\n};","map":{"version":3,"names":["Aside","components","data","isCollapse","sideWidth","logoTextShow","timeTimer","activeTab","tabs","path","name","methods","collapse","logout","localStorage","removeItem","$router","push","getCurrentDate","date","Date","year","getFullYear","month","getMonth","toString","padStart","day","getDate","hour","getHours","minute","getMinutes","second","getSeconds","week","getDay","document","getElementById","innerText","addTab","route","isExist","some","tab","getTabName","closeTab","index","findIndex","splice","length","tabMap","watch","$route","to","mounted","setInterval","beforeDestroy","clearInterval"],"sources":["src/views/Manage.vue"],"sourcesContent":["<template>\r\n  <el-container style=\"min-height:100vh\">\r\n    <!-- 顶部标题栏 -->\r\n    <el-header style=\"\r\n      background-color: #2D2D2D;\r\n      padding: 0 20px;\r\n      height: auto;\r\n      min-height: 70px;\r\n      display: flex;\r\n      justify-content: space-between;\r\n      align-items: center;\r\n    \">\r\n      <!-- 左侧标题 -->\r\n      <div style=\"display: block; text-align: left;\">\r\n        <div style=\"font-size: 22px; font-weight: 800; color: #4299E1;\">无人机管理系统</div>\r\n        <div style=\"font-size: 16px; font-weight: 500; margin-top: 4px; color: #90CDF4;\">Drone Management System</div>\r\n      </div>\r\n\r\n      <!-- 右侧区域 -->\r\n      <div style=\"display: flex; align-items: center; gap: 20px; color: #E2E8F0;\">\r\n        <!-- 通知框 -->\r\n        <el-dropdown placement=\"bottom-end\">\r\n          <span class=\"el-dropdown-link\" style=\"position: relative; cursor: pointer;\">\r\n            <i class=\"el-icon-bell\" style=\"font-size: 18px;\"></i>\r\n            <span style=\"\r\n              position: absolute;\r\n              top: -5px;\r\n              right: -8px;\r\n              background: #F56C6C;\r\n              color: #fff;\r\n              font-size: 12px;\r\n              width: 18px;\r\n              height: 18px;\r\n              line-height: 18px;\r\n              text-align: center;\r\n              border-radius: 50%;\r\n            \">3</span>\r\n          </span>\r\n          <el-dropdown-menu slot=\"dropdown\" style=\"width: 300px; padding: 10px;\">\r\n            <!-- 待办内容（原有） -->\r\n          </el-dropdown-menu>\r\n        </el-dropdown>\r\n\r\n        <!-- 搜索框 -->\r\n        <el-input\r\n            placeholder=\"请输入搜索内容\"\r\n            style=\"width: 200px; background: rgba(255,255,255,0.1); border: none; color: #E2E8F0;\"\r\n            prefix-icon=\"el-icon-search\"\r\n        ></el-input>\r\n\r\n        <!-- 日期 -->\r\n        <span style=\"font-size: 14px;\" id=\"current-date\"></span>\r\n\r\n        <!-- 退出按钮 -->\r\n        <el-button\r\n            type=\"text\"\r\n            icon=\"el-icon-switch-button\"\r\n            style=\"color: #E2E8F0; font-size: 16px;\"\r\n            @click=\"logout\"\r\n        >\r\n          退出登录\r\n        </el-button>\r\n\r\n        <!-- 用户信息 -->\r\n        <div style=\"display: flex; align-items: center; gap: 8px; cursor: pointer;\">\r\n          <el-avatar icon=\"el-icon-user\" size=\"medium\" style=\"background: #4299E1; color: #fff;\"></el-avatar>\r\n          <div style=\"text-align: left;\">\r\n            <span style=\"font-size: 14px; display: block;\">贾舒凯</span>\r\n            <span style=\"font-size: 12px; color: #90CDF4; display: block;\">工号：JSK2025 | 性别：男</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </el-header>\r\n\r\n    <!-- 新增：标签页区域（红色框位置） -->\r\n    <el-tabs\r\n        v-model=\"activeTab\"\r\n        type=\"card\"\r\n        style=\"background: #fff; border-bottom: 1px solid #eee; padding: 0 20px;\"\r\n        @tab-remove=\"closeTab\"\r\n    >\r\n      <el-tab-pane\r\n          v-for=\"tab in tabs\"\r\n          :key=\"tab.path\"\r\n          :label=\"tab.name\"\r\n          :closable=\"tab.path !== '/home'\"\r\n      >\r\n      </el-tab-pane>\r\n    </el-tabs>\r\n\r\n    <!-- 主体区域 -->\r\n    <el-container>\r\n      <el-aside :width=\"sideWidth + 'px'\" style=\"background-color: #33393B; border-right: 1px solid #ccc;\">\r\n        <Aside :is-collapse=\"isCollapse\" :logoTextShow=\"logoTextShow\" />\r\n      </el-aside>\r\n      <el-container>\r\n        <el-main style=\"padding: 0; background: #fff;\">\r\n          <router-view />\r\n        </el-main>\r\n      </el-container>\r\n    </el-container>\r\n  </el-container>\r\n</template>\r\n\r\n<script>\r\nimport Aside from \"@/components/Aside\";\r\n\r\nexport default {\r\n  components: { Aside },\r\n  data() {\r\n    return {\r\n      isCollapse: false,\r\n      sideWidth: 300,\r\n      logoTextShow: true,\r\n      timeTimer: null,\r\n      // 标签页相关数据\r\n      activeTab: \"/home\", // 当前激活的标签\r\n      tabs: [ // 初始标签（主页）\r\n        { path: \"/home\", name: \"主页\" }\r\n      ]\r\n    }\r\n  },\r\n  methods: {\r\n    collapse() {\r\n      this.isCollapse = !this.isCollapse\r\n      this.sideWidth = this.isCollapse ? 64 : 300\r\n      this.logoTextShow = !this.isCollapse\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      this.$router.push('/login')\r\n    },\r\n    getCurrentDate() {\r\n      // 日期时间逻辑（原有）\r\n      const date = new Date()\r\n      const year = date.getFullYear()\r\n      const month = (date.getMonth() + 1).toString().padStart(2, '0')\r\n      const day = date.getDate().toString().padStart(2, '0')\r\n      const hour = date.getHours().toString().padStart(2, '0')\r\n      const minute = date.getMinutes().toString().padStart(2, '0')\r\n      const second = date.getSeconds().toString().padStart(2, '0')\r\n      const week = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'][date.getDay()]\r\n      document.getElementById('current-date').innerText = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`\r\n    },\r\n    // 新增：添加标签页\r\n    addTab(route) {\r\n      const isExist = this.tabs.some(tab => tab.path === route.path)\r\n      if (!isExist) {\r\n        this.tabs.push({\r\n          path: route.path,\r\n          name: this.getTabName(route.path)\r\n        })\r\n      }\r\n      this.activeTab = route.path\r\n    },\r\n    // 新增：关闭标签页\r\n    closeTab(path) {\r\n      const index = this.tabs.findIndex(tab => tab.path === path)\r\n      this.tabs.splice(index, 1)\r\n      // 关闭后激活前一个标签\r\n      if (this.activeTab === path) {\r\n        this.activeTab = this.tabs.length > 0 ? this.tabs[this.tabs.length - 1].path : \"/home\"\r\n        this.$router.push(this.activeTab)\r\n      }\r\n    },\r\n    // 新增：根据路由路径获取标签名称\r\n    getTabName(path) {\r\n      const tabMap = {\r\n        \"/home\": \"主页\",\r\n        \"/drone\": \"无人机管理\",\r\n        \"/task\": \"无人机任务管理\",\r\n        \"/photography\": \"现场视频\",\r\n        \"/recognition\": \"识别结果\"\r\n      }\r\n      return tabMap[path] || \"未知页面\"\r\n    }\r\n  },\r\n  watch: {\r\n    // 新增：监听路由变化，自动添加标签\r\n    $route(to) {\r\n      this.addTab(to)\r\n    }\r\n  },\r\n  mounted() {\r\n    this.getCurrentDate()\r\n    this.timeTimer = setInterval(() => {\r\n      this.getCurrentDate()\r\n    }, 1000)\r\n    // 初始化时添加当前路由标签\r\n    this.addTab(this.$route)\r\n  },\r\n  beforeDestroy() {\r\n    if (this.timeTimer) {\r\n      clearInterval(this.timeTimer)\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 标签页样式优化 */\r\n:deep(.el-tabs__header) {\r\n  margin: 0 !important;\r\n  padding: 10px 0;\r\n}\r\n:deep(.el-tabs__item) {\r\n  margin-right: 10px;\r\n}\r\n</style>"],"mappings":";;;AAyGA,OAAAA,KAAA;AAEA;EACAC,UAAA;IAAAD;EAAA;EACAE,KAAA;IACA;MACAC,UAAA;MACAC,SAAA;MACAC,YAAA;MACAC,SAAA;MACA;MACAC,SAAA;MAAA;MACAC,IAAA;MAAA;MACA;QAAAC,IAAA;QAAAC,IAAA;MAAA;IAEA;EACA;EACAC,OAAA;IACAC,SAAA;MACA,KAAAT,UAAA,SAAAA,UAAA;MACA,KAAAC,SAAA,QAAAD,UAAA;MACA,KAAAE,YAAA,SAAAF,UAAA;IACA;IACAU,OAAA;MACAC,YAAA,CAAAC,UAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;IACAC,eAAA;MACA;MACA,MAAAC,IAAA,OAAAC,IAAA;MACA,MAAAC,IAAA,GAAAF,IAAA,CAAAG,WAAA;MACA,MAAAC,KAAA,IAAAJ,IAAA,CAAAK,QAAA,QAAAC,QAAA,GAAAC,QAAA;MACA,MAAAC,GAAA,GAAAR,IAAA,CAAAS,OAAA,GAAAH,QAAA,GAAAC,QAAA;MACA,MAAAG,IAAA,GAAAV,IAAA,CAAAW,QAAA,GAAAL,QAAA,GAAAC,QAAA;MACA,MAAAK,MAAA,GAAAZ,IAAA,CAAAa,UAAA,GAAAP,QAAA,GAAAC,QAAA;MACA,MAAAO,MAAA,GAAAd,IAAA,CAAAe,UAAA,GAAAT,QAAA,GAAAC,QAAA;MACA,MAAAS,IAAA,8CAAAhB,IAAA,CAAAiB,MAAA;MACAC,QAAA,CAAAC,cAAA,iBAAAC,SAAA,MAAAlB,IAAA,IAAAE,KAAA,IAAAI,GAAA,IAAAQ,IAAA,IAAAN,IAAA,IAAAE,MAAA,IAAAE,MAAA;IACA;IACA;IACAO,OAAAC,KAAA;MACA,MAAAC,OAAA,QAAAlC,IAAA,CAAAmC,IAAA,CAAAC,GAAA,IAAAA,GAAA,CAAAnC,IAAA,KAAAgC,KAAA,CAAAhC,IAAA;MACA,KAAAiC,OAAA;QACA,KAAAlC,IAAA,CAAAS,IAAA;UACAR,IAAA,EAAAgC,KAAA,CAAAhC,IAAA;UACAC,IAAA,OAAAmC,UAAA,CAAAJ,KAAA,CAAAhC,IAAA;QACA;MACA;MACA,KAAAF,SAAA,GAAAkC,KAAA,CAAAhC,IAAA;IACA;IACA;IACAqC,SAAArC,IAAA;MACA,MAAAsC,KAAA,QAAAvC,IAAA,CAAAwC,SAAA,CAAAJ,GAAA,IAAAA,GAAA,CAAAnC,IAAA,KAAAA,IAAA;MACA,KAAAD,IAAA,CAAAyC,MAAA,CAAAF,KAAA;MACA;MACA,SAAAxC,SAAA,KAAAE,IAAA;QACA,KAAAF,SAAA,QAAAC,IAAA,CAAA0C,MAAA,YAAA1C,IAAA,MAAAA,IAAA,CAAA0C,MAAA,MAAAzC,IAAA;QACA,KAAAO,OAAA,CAAAC,IAAA,MAAAV,SAAA;MACA;IACA;IACA;IACAsC,WAAApC,IAAA;MACA,MAAA0C,MAAA;QACA;QACA;QACA;QACA;QACA;MACA;MACA,OAAAA,MAAA,CAAA1C,IAAA;IACA;EACA;EACA2C,KAAA;IACA;IACAC,OAAAC,EAAA;MACA,KAAAd,MAAA,