lumn\n          prop=\"droneId\"\n          label=\"无人机ID\"\n          align=\"center\"\n          width=\"100\"\n      />\n      <el-table-column\n          prop=\"droneName\"\n          label=\"无人机名称\"\n          align=\"center\"\n          width=\"120\"\n      />\n      <!-- 修复：状态列（用slot渲染富文本） -->\n      <el-table-column\n          label=\"状态\"\n          align=\"center\"\n          width=\"100\"\n      >\n        <template slot-scope=\"scope\">\n          <span\n              :style=\"{\n                color: scope.row.status === 1 ? '#4299E1' : scope.row.status === 2 ? '#F56C6C' : '#67C21A',\n                fontWeight: 'bold'\n              }\"\n          >\n            {{ scope.row.status === 1 ? '充电中' : scope.row.status === 2 ? '维修中' : '正常' }}\n          </span>\n        </template>\n      </el-table-column>\n      <el-table-column\n          prop=\"operateTime\"\n          label=\"操作时间\"\n          align=\"center\"\n          width=\"180\"\n      />\n      <el-table-column\n          prop=\"operator\"\n          label=\"操作人员\"\n          align=\"center\"\n          width=\"100\"\n      />\n      <!-- 新增：备注栏编辑功能 -->\n      <el-table-column\n          label=\"备注\"\n          align=\"center\"\n      >\n        <template slot-scope=\"scope\">\n          <el-input\n              v-if=\"scope.row.isEditing\"\n              v-model=\"scope.row.remark\"\n              size=\"small\"\n              @blur=\"scope.row.isEditing = false\"\n              @keyup.enter=\"scope.row.isEditing = false\"\n              style=\"width: 90%;\"\n          />\n          <span\n              v-else\n              style=\"cursor: pointer; color: #4299E1;\"\n              @click=\"scope.row.isEditing = true\"\n          >\n            {{ scope.row.remark }}\n          </span>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <div style=\"margin-top: 10px; text-align: right;\">\n      <el-button type=\"primary\" size=\"small\" icon=\"el-icon-refresh\" @click=\"refreshMaintainData\">刷新数据</el-button>\n    </div>\n  </el-col>\n</template>\n\n<script>\n// 其他代码不变，修改data和方法\nexport default {\n  data() {\n    return {\n      // 其他数据...\n      // 修复：添加isEditing字段（控制备注编辑状态）\n      droneMaintainData: [\n        {\n          droneId: \"DR-001\",\n          droneName: \"巡逻无人机01\",\n          status: 1,\n          operateTime: \"2025-12-22 14:30:25\",\n          operator: \"贾舒凯\",\n          remark: \"常规充电，电量80%\",\n          isEditing: false // 新增：编辑状态标识\n        },\n        {\n          droneId: \"DR-002\",\n          droneName: \"巡检无人机02\",\n          status: 2,\n          operateTime: \"2025-12-23 09:15:10\",\n          operator: \"张三\",\n          remark: \"电机故障，更换配件\",\n          isEditing: false\n        },\n        {\n          droneId: \"DR-003\",\n          droneName: \"应急无人机03\",\n          status: 1,\n          operateTime: \"2025-12-24 11:20:30\",\n          operator: \"贾舒凯\",\n          remark: \"任务后补电，电量100%\",\n          isEditing: false\n        },\n        {\n          droneId: \"DR-004\",\n          droneName: \"巡逻无人机04\",\n          status: 2,\n          operateTime: \"2025-12-24 15:40:18\",\n          operator: \"李四\",\n          remark: \"电池鼓包，更换新电池\",\n          isEditing: false\n        },\n        {\n          droneId: \"DR-005\",\n          droneName: \"巡检无人机05\",\n          status: 1,\n          operateTime: \"2025-12-24 16:10:05\",\n          operator: \"王五\",\n          remark: \"日常充电，电量90%\",\n          isEditing: false\n        }\n      ]\n    }\n  },\n  methods: {\n    // 移除原formatMaintainStatus方法（改用模板slot渲染）\n    // 其他方法...\n  }\n}\n</script>"],"mappings":"AAoFA;AACA;EACAA,KAAA;IACA;MACA;MACA;MACAC,iBAAA,GACA;QACAC,OAAA;QACAC,SAAA;QACAC,MAAA;QACAC,WAAA;QACAC,QAAA;QACAC,MAAA;QACAC,SAAA;MACA,GACA;QACAN,OAAA;QACAC,SAAA;QACAC,MAAA;QACAC,WAAA;QACAC,QAAA;QACAC,MAAA;QACAC,SAAA;MACA,GACA;QACAN,OAAA;QACAC,SAAA;QACAC,MAAA;QACAC,WAAA;QACAC,QAAA;QACAC,MAAA;QACAC,SAAA;MACA,GACA;QACAN,OAAA;QACAC,SAAA;QACAC,MAAA;QACAC,