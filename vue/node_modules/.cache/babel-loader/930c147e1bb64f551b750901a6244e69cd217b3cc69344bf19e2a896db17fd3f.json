      <el-form-item label=\"任务名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"type\">\r\n          <el-select v-model=\"form.type\" placeholder=\"请选择任务类型\">\r\n            <el-option label=\"0-道路巡航\" value=\"0\"></el-option>\r\n            <el-option label=\"1-水域巡逻\" value=\"1\"></el-option>\r\n            <el-option label=\"2-事故取证\" value=\"2\"></el-option>\r\n            <el-option label=\"3-隐患排查\" value=\"3\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"deviceId\">\r\n          <el-input v-model=\"form.deviceId\" placeholder=\"请输入无人机ID\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务状态\" prop=\"status\">\r\n          <el-select v-model=\"form.status\" placeholder=\"请选择任务状态\">\r\n            <el-option label=\"0-未开始\" value=\"0\"></el-option>\r\n            <el-option label=\"1-执行中\" value=\"1\"></el-option>\r\n            <el-option label=\"2-已完成\" value=\"2\"></el-option>\r\n            <el-option label=\"3-已取消\" value=\"3\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTask\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 任务表格 -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column prop=\"id\" label=\"任务ID\" width=\"120\" />\r\n      <el-table-column prop=\"name\" label=\"任务名称\" width=\"180\" />\r\n      <el-table-column prop=\"type\" label=\"任务类型\" width=\"120\" />\r\n      <el-table-column prop=\"deviceId\" label=\"执行无人机\" width=\"120\" />\r\n      <el-table-column prop=\"startTime\" label=\"创建时间\" width=\"180\">\r\n        <template slot-scope=\"scope\">\r\n          {{ scope.row.startTime || '未设置' }}\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"endTime\" label=\"任务结束时间\" width=\"180\">\r\n        <template slot-scope=\"scope\">\r\n          {{ scope.row.endTime || '未设置' }}\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"status\" label=\"任务状态\" width=\"120\" />\r\n      <el-table-column label=\"操作\" width=\"150\">\r\n        <template slot-scope=\"scope\">\r\n          <!-- Vue2 Element UI 用 slot-scope，点击事件加.stop -->\r\n          <el-button type=\"primary\" size=\"small\" @click.stop=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click.stop=\"handleDelete(scope.row)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [],\r\n      loading: false,\r\n      dialogFormVisible: false, // Vue2 Element UI 用 visible.sync 绑定的变量\r\n      form: {},\r\n      queryForm: {\r\n        id: '',\r\n        name: '',\r\n        type: '',\r\n        deviceId: ''\r\n      },\r\n      formRules: {\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请选择任务类型', trigger: 'change' }],\r\n        deviceId: [{ required: true, message: '请输入无人机ID', trigger: 'blur' }],\r\n        status: [{ required: true, message: '请选择任务状态', trigger: 'change' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData()\r\n  },\r\n  methods: {\r\n    resetForm() {\r\n      this.form = {}\r\n      this.$refs.formRef && this.$refs.formRef.resetFields()\r\n    },\r\n\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true\r\n        const res = await request.get(\"/task/getAllData\", {\r\n          params: this.queryForm\r\n        })\r\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : []\r\n      } catch (error) {\r\n        console.error('加载失败：', error)\r\n        this.taskList = []\r\n        this.$message.error('数据加载失败，请重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    handleQuery() {\r\n      this.loadTaskData()\r\n    },\r\n\r\n    handleReset() {\r\n      this.queryForm = {\r\n        id: '',\r\n        name: '',\r\n        type: '',\r\n        deviceId: ''\r\n      }\r\n      this.loadTaskData()\r\n    },\r\n\r\n    handleAdd() {\r\n      this.form = { type: \"0\", status: \"0\" }\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    // 编辑按钮核心修复：Vue2 中直接修改 visible.sync 绑定的变量\r\n    handleEdit(row) {\r\n      // 1. 强制打开弹窗\r\n      this.dialogFormVisible = true\r\n      // 2. 深拷贝行数据\r\n      this.form = JSON.parse(JSON.stringify({\r\n        id: row.id,\r\n        name: row.name,\r\n        type: row.type?.toString() || \"0\",\r\n        deviceId: row.deviceId || \"\",\r\n        status: row.status?.toString() || \"0\"\r\n      }))\r\n      // 3. Vue2 用 $nextTick 确保DOM更新\r\n      this.$nextTick(() => {\r\n        this.dialogFormVisible = true\r\n      })\r\n    },\r\n\r\n    async saveTask() {\r\n      try {\r\n        await this.$refs.formRef.validate()\r\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\"\r\n        const submitData = {\r\n          id: this.form.id,\r\n          name: this.form.name,\r\n          type: Number(this.form.type),\r\n          deviceId: Number(this.form.deviceId),\r\n          status: Number(this.form.status)\r\n        }\r\n        const res = await request.post(apiUrl, submitData)\r\n\r\n        if (res?.code === 200) {\r\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功')\r\n          this.dialogFormVisible = false\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '保存失败')\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('保存失败，请检查数据')\r\n      }\r\n    },\r\n\r\n    async handleDelete(row) {\r\n      try {\r\n        await this.$confirm('确定删除该任务？', '提示', { type: 'warning' })\r\n        const res = await request.post(\"/task/delete\", { id: row.id })\r\n\r\n        if (res?.code === 200) {\r\n          this.$message.success('删除成功')\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') this.$message.error('删除失败')\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n::v-deep .el-button { margin: 0 4px; }\r\n::v-deep .el-form-item { margin-bottom: 15px; }\r\n</style>"],"mappings":";;AAmGA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,OAAA;MACAC,iBAAA;MAAA;MACAC,IAAA;MACAC,SAAA;QACAC,EAAA;QACAP,IAAA;QACAQ,IAAA;QACAC,QAAA;MACA;MACAC,SAAA;QACAV,IAAA;UAAAW,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAL,IAAA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAJ,QAAA;UAAAE,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,MAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAE,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACAC,UAAA;MACA,KAAAb,IAAA;MACA,KAAAc,KAAA,CAAAC,OAAA,SAAAD,KAAA,CAAAC,OAAA,CAAAC,WAAA;IACA;IAEA,MAAAL,aAAA;MACA;QACA,KAAAb,OAAA;QACA,MAAAmB,GAAA,SAAAvB,OAAA,CAAAwB,GAAA;UACAC,MAAA,OAAAlB;QACA;QACA,KAAAJ,QAAA,GAAAoB,GAAA,CAAArB,IAAA,CAAAA,IAAA,IAAAwB,KAAA,CAAAC,OAAA,CAAAJ,GAAA,CAAArB,IAAA,CAAAA,IAAA,IAAAqB,GAAA,CAAArB,IAAA,CAAAA,IAAA;MACA,SAAA0B,KAAA;QACAC,OAAA,CAAAD,KAAA,UAAAA,KAAA;QACA,KAAAzB,QAAA;QACA,KAAA2B,QAAA,CAAAF,KAAA;MACA;QACA,KAAAxB,OAAA;MACA;IACA;IAEA2B,YAAA;MACA,KAAAd,YAAA;IACA;IAEAe,YAAA;MACA,KAAAzB,SAAA;QACAC,EAAA;QACAP,IAAA;QACAQ,IAAA;QACAC,QAAA;MACA;MACA,KAAAO,YAAA;IACA;IAEAgB,UAAA;MACA,KAAA3B,IAAA;QAAAG,IAAA;QAAAM,MAAA;MAAA;MACA,KAAAV,iBAAA;IACA;IAEA;IACA6B,WAAAC,GAAA;MACA;MACA,KAAA9B,iBAAA;MACA;MACA,KAAAC,IAAA,GAAA8B,IAA