{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\nimport request from '@/utils/request';\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      loading: false,\n      dialogFormVisible: false,\n      // Vue2 Element UI 用 visible.sync 绑定的变量\n      form: {},\n      queryForm: {\n        id: '',\n        name: '',\n        type: '',\n        deviceId: ''\n      },\n      formRules: {\n        name: [{\n          required: true,\n          message: '请输入任务名称',\n          trigger: 'blur'\n        }],\n        type: [{\n          required: true,\n          message: '请选择任务类型',\n          trigger: 'change'\n        }],\n        deviceId: [{\n          required: true,\n          message: '请输入无人机ID',\n          trigger: 'blur'\n        }],\n        status: [{\n          required: true,\n          message: '请选择任务状态',\n          trigger: 'change'\n        }]\n      }\n    };\n  },\n  created() {\n    this.loadTaskData();\n  },\n  methods: {\n    resetForm() {\n      this.form = {};\n      this.$refs.formRef && this.$refs.formRef.resetFields();\n    },\n    async loadTaskData() {\n      try {\n        this.loading = true;\n        const res = await request.get(\"/task/getAllData\", {\n          params: this.queryForm\n        });\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : [];\n      } catch (error) {\n        console.error('加载失败：', error);\n        this.taskList = [];\n        this.$message.error('数据加载失败，请重试');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleQuery() {\n      this.loadTaskData();\n    },\n    handleReset() {\n      this.queryForm = {\n        id: '',\n        name: '',\n        type: '',\n        deviceId: ''\n      };\n      this.loadTaskData();\n    },\n    handleAdd() {\n      this.form = {\n        type: \"0\",\n        status: \"0\"\n      };\n      this.dialogFormVisible = true;\n    },\n    // 编辑按钮核心修复：Vue2 中直接修改 visible.sync 绑定的变量\n    handleEdit(row) {\n      // 1. 强制打开弹窗\n      this.dialogFormVisible = true;\n      // 2. 深拷贝行数据\n      this.form = JSON.parse(JSON.stringify({\n        id: row.id,\n        name: row.name,\n        type: row.type?.toString() || \"0\",\n        deviceId: row.deviceId || \"\",\n        status: row.status?.toString() || \"0\"\n      }));\n      // 3. Vue2 用 $nextTick 确保DOM更新\n      this.$nextTick(() => {\n        this.dialogFormVisible = true;\n      });\n    },\n    async saveTask() {\n      try {\n        await this.$refs.formRef.validate();\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\";\n        const submitData = {\n          id: this.form.id,\n          name: this.form.name,\n          type: Number(this.form.type),\n          deviceId: Number(this.form.deviceId),\n          status: Number(this.form.status)\n        };\n        const res = await request.post(apiUrl, submitData);\n        if (res?.code === 200) {\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功');\n          this.dialogFormVisible = false;\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '保存失败');\n        }\n      } catch (error) {\n        this.$message.error('保存失败，请检查数据');\n      }\n    },\n    async handleDelete(row) {\n      try {\n        await this.$confirm('确定删除该任务？', '提示', {\n          type: 'warning'\n        });\n        const res = await request.post(\"/task/delete\", {\n          id: row.id\n        });\n        if (res?.code === 200) {\n          this.$message.success('删除成功');\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '删除失败');\n        }\n      } catch (error) {\n        if (error !== 'cancel') this.$message.error('删除失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","queryForm","id","type","deviceId","formRules","