{"ast":null,"code":"import * as echarts from 'echarts';\n// 引入封装的request（确保路径正确）\nimport request from '@/utils/request';\nexport default {\n  name: \"Home\",\n  // 注册request，方便this调用\n  methods: {\n    // 封装图表初始化方法，避免重复代码\n    async initCharts() {\n      // 模拟数据（后端接口不可用时兜底）\n      const mockData = [80, 120, 90, 150];\n\n      // 初始化柱状图\n      const barChart = echarts.init(document.getElementById('bar'));\n      const barOption = {\n        title: {\n          text: '各季度会员统计数量'\n        },\n        tooltip: {\n          trigger: 'item'\n        },\n        xAxis: {\n          type: 'category',\n          data: ['第一季度', '第二季度', '第三季度', '第四季度']\n        },\n        yAxis: {\n          type: 'value'\n        },\n        series: [{\n          data: mockData,\n          // 默认用模拟数据\n          type: 'bar',\n          showBackground: true,\n          backgroundStyle: {\n            color: 'rgba(180, 180, 180, 0.2)'\n          }\n        }]\n      };\n\n      // 初始化折线图\n      const lineChart = echarts.init(document.getElementById('line'));\n      const lineOption = {\n        title: {\n          text: '各季度会员统计数量'\n        },\n        tooltip: {\n          trigger: 'item'\n        },\n        xAxis: {\n          type: 'category',\n          data: ['第一季度', '第二季度', '第三季度', '第四季度']\n        },\n        yAxis: {\n          type: 'value'\n        },\n        series: [{\n          data: mockData,\n          // 默认用模拟数据\n          type: 'line',\n          smooth: true\n        }]\n      };\n      try {\n        // 尝试请求后端接口（加错误捕获）\n        const res = await request.get(\"/echarts/members\");\n        // 接口返回正常则替换数据\n        if (res && res.data) {\n          barOption.series[0].data = res.data;\n          lineOption.series[0].data = res.data;\n        }\n      } catch (error) {\n        // 接口报错时打印提示，不影响页面\n        console.log('接口请求失败，使用模拟数据：', error.message);\n      }\n\n      // 渲染图表\n      barChart.setOption(barOption);\n      lineChart.setOption(lineOption);\n\n      // 适配窗口大小变化\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n      });\n    }\n  },\n  mounted() {\n    // 页面加载后初始化图表\n    this.initCharts();\n  }\n};","map":{"version":3,"names":["echarts","request","name","methods","initCharts","mockData","barChart","init","document","getElementById","barOption","title","text","tooltip","trigger","xAxis","type","data","yAxis","series","showBackground","backgroundStyle","color","lineChart","lineOption","smooth","res","get","error","console","log","message","setOption","window","addEventListener","resize","mounted"],"sources":["src/views/Home.vue"],"sourcesContent":["<template>\n  <div>\n    <el-row :gutter=\"10\" style=\"margin-bottom: 60px;\">\n      <el-col :span=\"6\">\n        <el-card style=\"color: rgb(255, 255, 255); height: 100px;\" class=\"card-container1\">\n          <div><i class=\"el-icon-s-data\" /> 执勤无人机</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">5</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: rgb(255, 255, 255);height: 100px;\" class=\"card-container2\">\n          <div><i class=\"el-icon-success\" /> 待办任务</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">57</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: rgb(255, 255, 255);height: 100px;\" class=\"card-container3\">\n          <div><i class=\"el-icon-warning\" /> 异常运行无人机</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">2</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: rgb(255, 255, 255);height: 100px;\" class=\"card-container4\">\n          <div><i class=\"el-icon-remove\" /> 日志记录</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">1000</div>\n        </el-card>\n      </el-col>\n    </el-row>\n    <el-row>\n      <el-col :span=\"12\">\n        <div id=\"bar\" style=\"width: 500px; height: 400px\"></div>\n      </el-col>\n      <el-col :span=\"12\">\n        <div id=\"line\" style=\"width: 500px; height: 400px\"></div>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\n// 引入封装的request（确保路径正确）\nimport request from '@/utils/request'\n\nexport default {\n  name: \"Home\",\n  // 注册request，方便this调用\n  methods: {\n    // 封装图表初始化方法，避免重复代码\n    async initCharts() {\n      // 模拟数据（后端接口不可用时兜底）\n      const mockData = [80, 120, 90, 150];\n\n      // 初始化柱状图\n      const barChart = echarts.init(document.getElementById('bar'));\n      const barOption = {\n        title: { text: '各季度会员统计数量' },\n        tooltip: { trigger: 'item' },\n        xAxis: { type: 'category', data: ['第一季度', '第二季度', '第三季度', '第四季度'] },\n        yAxis: { type: 'value' },\n        series: [{\n          data: mockData, // 默认用模拟数据\n          type: 'bar',\n          showBackground: true,\n          backgroundStyle: { color: 'rgba(180, 180, 180, 0.2)' }\n        }]\n      };\n\n      // 初始化折线图\n      const lineChart = echarts.init(document.getElementById('line'));\n      const lineOption = {\n        title: { text: '各季度会员统计数量' },\n        tooltip: { trigger: 'item' },\n        xAxis: { type: 'category', data: ['第一季度', '第二季度', '第三季度', '第四季度'] },\n        yAxis: { type: 'value' },\n        series: [{\n          data: mockData, // 默认用模拟数据\n          type: 'line',\n          smooth: true\n        }]\n      };\n\n      try {\n        // 尝试请求后端接口（加错误捕获）\n        const res = await request.get(\"/echarts/members\");\n        // 接口返回正常则替换数据\n        if (res && res.data) {\n          barOption.series[0].data = res.data;\n          lineOption.series[0].data = res.data;\n        }\n      } catch (error) {\n        // 接口报错时打印提示，不影响页面\n        console.log('接口请求失败，使用模拟数据：', error.message);\n      }\n\n      // 渲染图表\n      barChart.setOption(barOption);\n      lineChart.setOption(lineOption);\n\n      // 适配窗口大小变化\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n      });\n    }\n  },\n  mounted() {\n    // 页面加载后初始化图表\n    this.initCharts();\n  }\n}\n</script>\n\n<style scoped>\n.card-container1 {\n  position: relative;\n  background-image: linear-gradient(to bottom right,#401EFF,#2c44bd);\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container2 {\n  position: relative;\n  background-image: linear-gradient(to bottom right,#67C21A,#204e09);\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container3 {\n  position: relative;\n  background-image: linear-gradient(to bottom right,#F86C6C,#751111);\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container4 {\n  position: relative;\n  background-image: linear-gradient(to bottom right,#909999,#424997);\n  border-radius: 8px;\n  overflow: hidden;\n}\n</style>"],"mappings":"AAwCA,YAAAA,OAAA;AACA;AACA,OAAAC,OAAA;AAEA;EACAC,IAAA;EACA;EACAC,OAAA;IACA;IACA,MAAAC,WAAA;MACA;MACA,MAAAC,QAAA;;MAEA;MACA,MAAAC,QAAA,GAAAN,OAAA,CAAAO,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACA,MAAAC,SAAA;QACAC,KAAA;UAAAC,IAAA;QAAA;QACAC,OAAA;UAAAC,OAAA;QAAA;QACAC,KAAA;UAAAC,IAAA;UAAAC,IAAA;QAAA;QACAC,KAAA;UAAAF,IAAA;QAAA;QACAG,MAAA;UACAF,IAAA,EAAAZ,QAAA;UAAA;UACAW,IAAA;UACAI,cAAA;UACAC,eAAA;YAAAC,KAAA;UAAA;QACA;MACA;;MAEA;MACA,MAAAC,SAAA,GAAAvB,OAAA,CAAAO,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACA,MAAAe,UAAA;QACAb,KAAA;UAAAC,IAAA;QAAA;QACAC,OAAA;UAAAC,OAAA;QAAA;QACAC,KAAA;UAAAC,IAAA;UAAAC,IAAA;QAAA;QACAC,KAAA;UAAAF,IAAA;QAAA;QACAG,MAAA;UACAF,IAAA,EAAAZ,QAAA;UAAA;UACAW,IAAA;UACAS,MAAA;QACA;MACA;MAEA;QACA;QACA,MAAAC,GAAA,SAAAzB,OAAA,CAAA0B,GAAA;QACA;QACA,IAAAD,GAAA,IAAAA,GAAA,CAAAT,IAAA;UACAP,SAAA,CAAAS,MAAA,IAAAF,IAAA,GAAAS,GAAA,CAAAT,IAAA;UACAO,UAAA,CAAAL,MAAA,IAAAF,IAAA,GAAAS,GAAA,CAAAT,IAAA;QACA;MACA,SAAAW,KAAA;QACA;QACAC,OAAA,CAAAC,GAAA,mBAAAF,KAAA,CAAAG,OAAA;MACA;;MAEA;MACAzB,QAAA,CAAA0B,SAAA,CAAAtB,SAAA;MACAa,SAAA,CAAAS,SAAA,CAAAR,UAAA;;MAEA;MACAS,MAAA,CAAAC,gBAAA;QA