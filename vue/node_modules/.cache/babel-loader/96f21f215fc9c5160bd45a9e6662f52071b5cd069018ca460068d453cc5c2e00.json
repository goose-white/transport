{"ast":null,"code":"export default {\n  name: \"Aside\",\n  props: {\n    isCollapse: Boolean,\n    logoTextShow: Boolean,\n    // 接收父组件传递的当前标题\n    currentTitle: {\n      type: String,\n      default: ''\n    }\n  }\n};","map":{"version":3,"names":["name","props","isCollapse","Boolean","logoTextShow","currentTitle","type","String","default"],"sources":["src/components/Aside.vue"],"sourcesContent":["<template>\r\n  <div class=\"aside-container\" style=\"height: 100%; display: flex; flex-direction: column; justify-content: space-between;\">\r\n    <!-- 原有垂直导航菜单 -->\r\n    <el-menu\r\n        mode=\"vertical\"\r\n        style=\"min-height: 100%; width: 100%; border-right: none;\"\r\n        background-color=\"#33393B\"\r\n        text-color=\"#E2E8F0\"\r\n        active-text-color=\"#38BDF8\"\r\n        :collapse=\"isCollapse\"\r\n        router\r\n    >\r\n      <!-- 导航项（垂直排列） -->\r\n      <el-menu-item index=\"/home\">\r\n        <i class=\"el-icon-house\"></i>\r\n        <span slot=\"title\">主页</span>\r\n      </el-menu-item>\r\n\r\n      <!-- 系统管理二级菜单 -->\r\n      <el-submenu index=\"2\">\r\n        <template slot=\"title\">\r\n          <i class=\"el-icon-menu\"></i>\r\n          <span slot=\"title\">系统管理</span>\r\n        </template>\r\n        <el-menu-item index=\"/drone\">\r\n          <i class=\"el-icon-s-custom\"></i>\r\n          <span slot=\"title\">无人机管理</span>\r\n        </el-menu-item>\r\n        <el-menu-item index=\"/task\">\r\n          <i class=\"el-icon-s-custom\"></i>\r\n          <span slot=\"title\">无人机任务管理</span>\r\n        </el-menu-item>\r\n      </el-submenu>\r\n      <!-- 修复index重复问题：从2改为3 -->\r\n      <el-submenu index=\"3\">\r\n        <template slot=\"title\">\r\n          <i class=\"el-icon-menu\"></i>\r\n          <span slot=\"title\">记录管理</span>\r\n        </template>\r\n        <el-menu-item index=\"/photography\">\r\n          <i class=\"el-icon-s-tools\"></i>\r\n          <span slot=\"title\">现场视频</span>\r\n        </el-menu-item>\r\n        <el-menu-item index=\"/recognition\">\r\n          <i class=\"el-icon-s-tools\"></i>\r\n          <span slot=\"title\">识别结果</span>\r\n        </el-menu-item>\r\n      </el-submenu>\r\n    </el-menu>\r\n\r\n    <!-- 修复语法错误：当前页面/表格标题显示区域 -->\r\n    <div\r\n        class=\"current-title-container\"\r\n        :style=\"{\r\n        padding: '12px 20px',\r\n        borderTop: '1px solid #444',\r\n        marginTop: 'auto',\r\n        visibility: currentTitle ? 'visible' : 'hidden'\r\n      }\"\r\n    >\r\n      <span style=\"font-size: 13px; color: #90CDF4;\">当前页面：</span>\r\n      <span style=\"font-size: 14px; color: #E2E8F0; font-weight: 500;\">{{ currentTitle }}</span>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Aside\",\r\n  props: {\r\n    isCollapse: Boolean,\r\n    logoTextShow: Boolean,\r\n    // 接收父组件传递的当前标题\r\n    currentTitle: {\r\n      type: String,\r\n      default: ''\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 左侧导航样式优化 */\r\n:deep(.el-menu) {\r\n  border-right: none;\r\n}\r\n\r\n/* 标题容器样式适配折叠状态 */\r\n:deep(.el-menu--collapse) + .current-title-container {\r\n  padding: 12px 10px !important;\r\n  text-align: center;\r\n}\r\n:deep(.el-menu--collapse) + .current-title-container span {\r\n  font-size: 12px;\r\n}\r\n</style>"],"mappings":"AAmEA;EACAA,IAAA;EACAC,KAAA;IACAC,UAAA,EAAAC,OAAA;IACAC,YAAA,EAAAD,OAAA;IACA;IACAE,YAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}