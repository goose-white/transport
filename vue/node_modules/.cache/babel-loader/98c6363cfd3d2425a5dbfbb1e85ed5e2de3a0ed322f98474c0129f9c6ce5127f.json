{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\nimport request from '@/utils/request';\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      loading: false,\n      dialogFormVisible: false,\n      form: {},\n      formRules: {\n        taskName: [{\n          required: true,\n          message: '请输入任务名称',\n          trigger: 'blur'\n        }],\n        taskType: [{\n          required: true,\n          message: '请选择任务类型',\n          trigger: 'change'\n        }],\n        droneId: [{\n          required: true,\n          message: '请输入无人机ID',\n          trigger: 'blur'\n        }],\n        status: [{\n          required: true,\n          message: '请选择任务状态',\n          trigger: 'change'\n        }]\n      }\n    };\n  },\n  created() {\n    this.loadTaskData();\n  },\n  methods: {\n    resetForm() {\n      this.form = {};\n      if (this.$refs.formRef) {\n        this.$refs.formRef.resetFields();\n      }\n    },\n    async loadTaskData() {\n      try {\n        this.loading = true;\n        const res = await request.get(\"/task/getAllData\", {});\n        let tableData = [];\n        if (res && res.data) {\n          tableData = Array.isArray(res.data) ? res.data : res.data.data || [];\n        }\n        this.taskList = Array.isArray(tableData) ? tableData : [];\n      } catch (error) {\n        console.error('加载任务数据失败：', error);\n        this.taskList = [];\n        this.$message.error('任务数据加载失败，请刷新页面重试');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleAdd() {\n      this.form = {};\n      this.dialogFormVisible = true;\n    },\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row));\n      this.dialogFormVisible = true;\n    },\n    async saveTask() {\n      try {\n        await this.$refs.formRef.validate();\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\";\n        const res = await request.post(apiUrl, this.form);\n        if (res && (res.code === 200 || res.success)) {\n          this.$message.success(this.form.id ? '编辑成功!' : '新增成功!');\n          this.dialogFormVisible = false;\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || (this.form.id ? '编辑失败' : '新增失败') + '，请重试');\n        }\n      } catch (error) {\n        console.error('保存任务失败：', error);\n        this.$message.error('保存失败，请检查数据格式或网络状态');\n      }\n    },\n    async handleDelete(row) {\n      try {\n        await this.$confirm('确定要删除该任务吗？删除后不可恢复！', '温馨提示', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n        const res = await request.post(\"/task/delete\", {\n          id: row.id\n        });\n        if (res && (res.code === 200 || res.success)) {\n          this.$message.success('删除成功！');\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '删除失败，请重试');\n        }\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('删除任务失败：', error);\n          this.$message.error('删除失败，请重试');\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","formRules","taskName","required","message","trigger","taskType","droneId","status","created","loadTaskData","methods","resetForm","$refs","formRef","resetFields","res","get","tableData","Array","isArray","error","console","$message","handleAdd","handleEdit","row","JSON","parse","stringify","saveTask","validate","apiUrl","id","post","code","success","msg","handleDelete","$confirm","confirmButtonText","cancelButtonText","type"],"sources":["src/views/task.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 新增/编辑任务弹窗 -->\r\n    <el-dialog\r\n        title=\"任务信息\"\r\n        v-model=\"dialogFormVisible\"\r\n        width=\"500px\"\r\n        @close=\"resetForm\"\r\n    >\r\n      <el-form\r\n          ref=\"formRef\"\r\n          :model=\"form\"\r\n          label-width=\"100px\"\r\n          size=\"small\"\r\n          :rules=\"formRules\"\r\n      >\r\n        <el-form-item label=\"任务名称\" prop=\"taskName\">\r\n          <el-input v-model=\"form.taskName\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"taskType\">\r\n          <el-select v-model=\"form.taskType\" placeholder=\"请选择任务类型\">\r\n            <el-option label=\"巡逻任务\" value=\"巡逻任务\"></el-option>\r\n            <el-option label=\"巡检任务\" value=\"巡检任务\"></el-option>\r\n            <el-option label=\"应急任务\" value=\"应急任务\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"droneId\">\r\n          <el-input v-model=\"form.droneId\" placeholder=\"请输入无人机ID\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务状态\" prop=\"status\">\r\n          <el-select v-model=\"form.status\" placeholder=\"请选择任务状态\">\r\n            <el-option label=\"待执行\" value=\"0\"></el-option>\r\n            <el-option label=\"执行中\" value=\"1\"></el-option>\r\n            <el-option label=\"已完成\" value=\"2\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTask\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 新增任务按钮 -->\r\n    <el-button type=\"primary\" icon=\"el-icon-plus\" style=\"margin-bottom: 20px;\" @click=\"handleAdd\">\r\n      新增任务\r\n    </el-button>\r\n\r\n    <!-- 任务管理表格 -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column\r\n          prop=\"id\"\r\n          label=\"任务ID\"\r\n          width=\"120\"\r\n      />\r\n      <el-table-column\r\n          prop=\"taskName\"\r\n          label=\"任务名称\"\r\n          min-width=\"180\"\r\n      />\r\n      <el-table-column\r\n          prop=\"taskType\"\r\n          label=\"任务类型\"\r\n          width=\"120\"\r\n      />\r\n      <el-table-column\r\n          prop=\"droneId\"\r\n          label=\"执行无人机\"\r\n          width=\"120\"\r\n      />\r\n      <el-table-column\r\n          prop=\"createTime\"\r\n          label=\"创建时间\"\r\n          width=\"180\"\r\n      />\r\n      <el-table-column\r\n          prop=\"status\"\r\n          label=\"任务状态\"\r\n          width=\"120\"\r\n      >\r\n        <template #default=\"scope\">\r\n          <el-tag :type=\"scope.row.status === '0' ? 'warning' : scope.row.status === '1' ? 'success' : 'danger'\">\r\n            {{ scope.row.status === '0' ? '待执行' : scope.row.status === '1' ? '执行中' : '已完成' }}\r\n          </el-tag>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column label=\"操作\" width=\"180\">\r\n        <template #default=\"scope\">\r\n          <el-button type=\"primary\" size=\"small\" @click=\"handleEdit(scope.row)\">\r\n            编辑 <<i class=\"el-icon-edit\"></</i>\r\n          </el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click=\"handleDelete(scope.row)\">\r\n            删除 <<i class=\"el-icon-delete\"></</i>\r\n          </el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [],\r\n      loading: false,\r\n      dialogFormVisible: false,\r\n      form: {},\r\n      formRules: {\r\n        taskName: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        taskType: [{ required: true, message: '请选择任务类型', trigger: 'change' }],\r\n        droneId: [{ required: true, message: '请输入无人机ID', trigger: 'blur' }],\r\n        status: [{ required: true, message: '请选择任务状态', trigger: 'change' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData()\r\n  },\r\n  methods: {\r\n    resetForm() {\r\n      this.form = {}\r\n      if (this.$refs.formRef) {\r\n        this.$refs.formRef.resetFields()\r\n      }\r\n    },\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true\r\n        const res = await request.get(\"/task/getAllData\", {})\r\n        let tableData = []\r\n        if (res && res.data) {\r\n          tableData = Array.isArray(res.data) ? res.data : (res.data.data || [])\r\n        }\r\n        this.taskList = Array.isArray(tableData) ? tableData : []\r\n      } catch (error) {\r\n        console.error('加载任务数据失败：', error)\r\n        this.taskList = []\r\n        this.$message.error('任务数据加载失败，请刷新页面重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    handleAdd() {\r\n      this.form = {}\r\n      this.dialogFormVisible = true\r\n    },\r\n    handleEdit(row) {\r\n      this.form = JSON.parse(JSON.stringify(row))\r\n      this.dialogFormVisible = true\r\n    },\r\n    async saveTask() {\r\n      try {\r\n        await this.$refs.formRef.validate()\r\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\"\r\n        const res = await request.post(apiUrl, this.form)\r\n        if (res && (res.code === 200 || res.success)) {\r\n          this.$message.success(this.form.id ? '编辑成功!' : '新增成功!')\r\n          this.dialogFormVisible = false\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || (this.form.id ? '编辑失败' : '新增失败') + '，请重试')\r\n        }\r\n      } catch (error) {\r\n        console.error('保存任务失败：', error)\r\n        this.$message.error('保存失败，请检查数据格式或网络状态')\r\n      }\r\n    },\r\n    async handleDelete(row) {\r\n      try {\r\n        await this.$confirm('确定要删除该任务吗？删除后不可恢复！', '温馨提示', {\r\n          confirmButtonText: '确定',\r\n          cancelButtonText: '取消',\r\n          type: 'warning'\r\n        })\r\n        const res = await request.post(\"/task/delete\", { id: row.id })\r\n        if (res && (res.code === 200 || res.success)) {\r\n          this.$message.success('删除成功！')\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '删除失败，请重试')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') {\r\n          console.error('删除任务失败：', error)\r\n          this.$message.error('删除失败，请重试')\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n:deep(.el-table) {\r\n  --el-table-row-hover-bg-color: #f5f8ff;\r\n  --el-table-header-text-color: #333;\r\n}\r\n:deep(.el-button) {\r\n  margin: 0 4px;\r\n}\r\n:deep(.el-form-item) {\r\n  margin-bottom: 15px;\r\n}\r\n:deep(.el-loading-mask) {\r\n  background-color: rgba(255, 255, 255, 0.8);\r\n}\r\n.dialog-footer {\r\n  text-align: right;\r\n}\r\n</style>"],"mappings":";;AA2GA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,OAAA;MACAC,iBAAA;MACAC,IAAA;MACAC,SAAA;QACAC,QAAA;UAAAC,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,QAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAE,OAAA;UAAAJ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAG,MAAA;UAAAL,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAI,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACAC,UAAA;MACA,KAAAZ,IAAA;MACA,SAAAa,KAAA,CAAAC,OAAA;QACA,KAAAD,KAAA,CAAAC,OAAA,CAAAC,WAAA;MACA;IACA;IACA,MAAAL,aAAA;MACA;QACA,KAAAZ,OAAA;QACA,MAAAkB,GAAA,SAAAtB,OAAA,CAAAuB,GAAA;QACA,IAAAC,SAAA;QACA,IAAAF,GAAA,IAAAA,GAAA,CAAApB,IAAA;UACAsB,SAAA,GAAAC,KAAA,CAAAC,OAAA,CAAAJ,GAAA,CAAApB,IAAA,IAAAoB,GAAA,CAAApB,IAAA,GAAAoB,GAAA,CAAApB,IAAA,CAAAA,IAAA;QACA;QACA,KAAAC,QAAA,GAAAsB,KAAA,CAAAC,OAAA,CAAAF,SAAA,IAAAA,SAAA;MACA,SAAAG,KAAA;QACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;QACA,KAAAxB,QAAA;QACA,KAAA0B,QAAA,CAAAF,KAAA;MACA;QACA,KAAAvB,OAAA;MACA;IACA;IACA0B,UAAA;MACA,KAAAxB,IAAA;MACA,KAAAD,iBAAA;IACA;IACA0B,WAAAC,GAAA;MACA,KAAA1B,IAAA,GAAA2B,IAA