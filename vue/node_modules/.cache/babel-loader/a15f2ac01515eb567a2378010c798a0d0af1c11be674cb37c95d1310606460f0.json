{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\n// 引入你的请求工具\nimport request from '@/utils/request';\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      // ✅ 核心：初始值必须是空数组\n      loading: false,\n      // 加载状态\n      // 其他数据（如编辑表单、弹窗等）可按需添加\n      dialogFormVisible: false,\n      form: {}\n    };\n  },\n  created() {\n    this.loadTaskData(); // 页面创建时加载数据\n  },\n  methods: {\n    // 加载任务数据（核心修复逻辑）\n    async loadTaskData() {\n      try {\n        this.loading = true; // 显示加载中\n\n        // 调用任务列表接口\n        const res = await request.get(\"/task/getAllData\", {});\n\n        // 核心：提取数组数据 + 类型校验 + 兜底\n        // 适配常见接口格式：\n        // 格式1：{code:200, data: [...]} → 取 res.data.data\n        // 格式2：直接返回数组 → 取 res.data\n        // 格式3：其他情况 → 空数组\n        let tableData = [];\n        if (res && res.data) {\n          // 优先判断 res.data 是否是数组，不是则取 res.data.data\n          tableData = Array.isArray(res.data) ? res.data : res.data.data || [];\n        }\n\n        // 最终兜底：确保一定是数组\n        this.taskList = Array.isArray(tableData) ? tableData : [];\n      } catch (error) {\n        console.error('加载任务数据失败：', error);\n        this.taskList = []; // ❗ 失败时必须重置为空数组\n        this.$message.error('任务数据加载失败，请刷新页面重试');\n      } finally {\n        this.loading = false; // 关闭加载状态\n      }\n    },\n    // 编辑任务（示例）\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row)); // 深拷贝，避免联动\n      this.dialogFormVisible = true;\n    },\n    // 删除任务（示例）\n    async handleDelete(row) {\n      try {\n        await this.$confirm('确定要删除该任务吗？', '提示', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n        const res = await request.post(\"/task/delete\", {\n          id: row.id\n        });\n        if (res && (res.code === 200 || res.success)) {\n          this.$message.success('删除成功！');\n          this.loadTaskData(); // 重新加载数据\n        } else {\n          this.$message.error(res?.msg || '删除失败');\n        }\n      } catch (error) {\n        if (error !== 'cancel') {\n          // 排除取消操作的报错\n          console.error('删除任务失败：', error);\n          this.$message.error('删除失败，请重试');\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","created","loadTaskData","methods","res","get","tableData","Array","isArray","error","console","$message","handleEdit","row","JSON","parse","stringify","handleDelete","$confirm","confirmButtonText","cancelButtonText","type","post","id","code","success","msg"],"sources":["src/views/task.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 任务管理表格 -->\r\n    <el-table\r\n        :data=\"taskList\"  <!-- 绑定数组类型的数据源 -->\r\n    stripe\r\n    border\r\n    style=\"width: 100%;\"\r\n    v-loading=\"loading\"  <!-- 加载状态，提升体验 -->\r\n    >\r\n    <!-- 可根据你的实际字段调整列配置 -->\r\n    <el-table-column\r\n        prop=\"id\"\r\n        label=\"任务ID\"\r\n        width=\"120\"\r\n    />\r\n    <el-table-column\r\n        prop=\"taskName\"\r\n        label=\"任务名称\"\r\n        min-width=\"180\"\r\n    />\r\n    <el-table-column\r\n        prop=\"taskType\"\r\n        label=\"任务类型\"\r\n        width=\"120\"\r\n    />\r\n    <el-table-column\r\n        prop=\"droneId\"\r\n        label=\"执行无人机\"\r\n        width=\"120\"\r\n    />\r\n    <el-table-column\r\n        prop=\"createTime\"\r\n        label=\"创建时间\"\r\n        width=\"180\"\r\n    />\r\n    <el-table-column\r\n        prop=\"status\"\r\n        label=\"任务状态\"\r\n        width=\"120\"\r\n    >\r\n      <template #default=\"scope\">\r\n        <el-tag :type=\"scope.row.status === 0 ? 'warning' : scope.row.status === 1 ? 'success' : 'danger'\">\r\n          {{ scope.row.status === 0 ? '待执行' : scope.row.status === 1 ? '执行中' : '已完成' }}\r\n        </el-tag>\r\n      </template>\r\n    </el-table-column>\r\n    <el-table-column label=\"操作\" width=\"180\">\r\n      <template #default=\"scope\">\r\n        <el-button type=\"primary\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n        <el-button type=\"danger\" size=\"small\" @click=\"handleDelete(scope.row)\">删除</el-button>\r\n      </template>\r\n    </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\n// 引入你的请求工具\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [],  // ✅ 核心：初始值必须是空数组\r\n      loading: false, // 加载状态\r\n      // 其他数据（如编辑表单、弹窗等）可按需添加\r\n      dialogFormVisible: false,\r\n      form: {}\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData() // 页面创建时加载数据\r\n  },\r\n  methods: {\r\n    // 加载任务数据（核心修复逻辑）\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true // 显示加载中\r\n\r\n        // 调用任务列表接口\r\n        const res = await request.get(\"/task/getAllData\", {})\r\n\r\n        // 核心：提取数组数据 + 类型校验 + 兜底\r\n        // 适配常见接口格式：\r\n        // 格式1：{code:200, data: [...]} → 取 res.data.data\r\n        // 格式2：直接返回数组 → 取 res.data\r\n        // 格式3：其他情况 → 空数组\r\n        let tableData = []\r\n        if (res && res.data) {\r\n          // 优先判断 res.data 是否是数组，不是则取 res.data.data\r\n          tableData = Array.isArray(res.data) ? res.data : (res.data.data || [])\r\n        }\r\n\r\n        // 最终兜底：确保一定是数组\r\n        this.taskList = Array.isArray(tableData) ? tableData : []\r\n      } catch (error) {\r\n        console.error('加载任务数据失败：', error)\r\n        this.taskList = [] // ❗ 失败时必须重置为空数组\r\n        this.$message.error('任务数据加载失败，请刷新页面重试')\r\n      } finally {\r\n        this.loading = false // 关闭加载状态\r\n      }\r\n    },\r\n\r\n    // 编辑任务（示例）\r\n    handleEdit(row) {\r\n      this.form = JSON.parse(JSON.stringify(row)) // 深拷贝，避免联动\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    // 删除任务（示例）\r\n    async handleDelete(row) {\r\n      try {\r\n        await this.$confirm('确定要删除该任务吗？', '提示', {\r\n          confirmButtonText: '确定',\r\n          cancelButtonText: '取消',\r\n          type: 'warning'\r\n        })\r\n        const res = await request.post(\"/task/delete\", { id: row.id })\r\n        if (res && (res.code === 200 || res.success)) {\r\n          this.$message.success('删除成功！')\r\n          this.loadTaskData() // 重新加载数据\r\n        } else {\r\n          this.$message.error(res?.msg || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') { // 排除取消操作的报错\r\n          console.error('删除任务失败：', error)\r\n          this.$message.error('删除失败，请重试')\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 样式优化 */\r\n:deep(.el-table) {\r\n  --el-table-row-hover-bg-color: #f5f8ff;\r\n}\r\n:deep(.el-button) {\r\n  margin: 0 4px;\r\n}\r\n</style>"],"mappings":";;AA0DA;AACA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MAAA;MACAC,OAAA;MAAA;MACA;MACAC,iBAAA;MACAC,IAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACA;IACA,MAAAD,aAAA;MACA;QACA,KAAAJ,OAAA;;QAEA;QACA,MAAAM,GAAA,SAAAV,OAAA,CAAAW,GAAA;;QAEA;QACA;QACA;QACA;QACA;QACA,IAAAC,SAAA;QACA,IAAAF,GAAA,IAAAA,GAAA,CAAAR,IAAA;UACA;UACAU,SAAA,GAAAC,KAAA,CAAAC,OAAA,CAAAJ,GAAA,CAAAR,IAAA,IAAAQ,GAAA,CAAAR,IAAA,GAAAQ,GAAA,CAAAR,IAAA,CAAAA,IAAA;QACA;;QAEA;QACA,KAAAC,QAAA,GAAAU,KAAA,CAAAC,OAAA,CAAAF,SAAA,IAAAA,SAAA;MACA,SAAAG,KAAA;QACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;QACA,KAAAZ,QAAA;QACA,KAAAc,QAAA,CAAAF,KAAA;MACA;QACA,KAAAX,OAAA;MACA;IACA;IAEA;IACAc,WAAAC,GAAA;MACA,KAAAb,IAAA,GAAAc,IAAA,CAAAC,KAAA,CAAAD,IAAA,CAAAE,SAAA,CAAAH,GAAA;MACA,KAAAd,iBAAA;IACA;IAEA;IACA,MAAAkB,aAAAJ,GAAA;MACA;QACA,WAAAK,QAAA;UACAC,iBAAA;UACAC,gBAAA;UACAC,IAAA;QACA;QACA,MAAAjB,GAAA,SAAAV,OAAA,CAAA4B,IAAA;UAAAC,EAAA,EAAAV,GAAA,CAAAU;QAAA;QACA,IAAAnB,GAAA,KAAAA,GAAA,CAAAoB,IAAA,YAAApB,GAAA,CAAAqB,OAAA;UACA,KAAAd,QAAA,CAAAc,OAAA;UACA,KAAAvB,YAAA;QACA;UACA,KAAAS,QAAA,CAAAF,KAAA,CAAAL,GAAA,EAAAsB,GAAA;QACA;MACA,SAAAjB,KAAA;QACA,IAAAA,KAAA;UAAA;UACAC,OAAA,CAAAD,KAAA,YAAAA,KAAA;UACA,KAAAE,QAAA,CAAAF,KAAA;QACA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}