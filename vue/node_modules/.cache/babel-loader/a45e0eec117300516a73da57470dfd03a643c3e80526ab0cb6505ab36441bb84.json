{"ast":null,"code":"import * as echarts from 'echarts';\n// 注释掉request避免报错，实际使用时恢复\n// import request from '@/utils/request'\n\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      config: {\n        systemName: \"无人机管理系统V1.0\",\n        inspectFreq: 30,\n        logRetention: 90,\n        maxHeight: 120,\n        maxBattery: 45,\n        alertThreshold: 5\n      },\n      detailDialogVisible: false,\n      currentWeek: \"\",\n      weekDetailData: {\n        \"12月第1周\": [8, 10, 12],\n        \"12月第2周\": [10, 12, 15],\n        \"12月第3周\": [9, 11, 13],\n        \"12月第4周\": [12, 14, 16]\n      },\n      currentTime: \"\",\n      // 实时时间\n      timer: null // 定时器标识\n    };\n  },\n  methods: {\n    // 实时更新时间（精确到秒，修复格式化）\n    updateTime() {\n      const date = new Date();\n      const year = date.getFullYear();\n      const month = String(date.getMonth() + 1).padStart(2, '0');\n      const day = String(date.getDate()).padStart(2, '0');\n      const hour = String(date.getHours()).padStart(2, '0');\n      const minute = String(date.getMinutes()).padStart(2, '0');\n      const second = String(date.getSeconds()).padStart(2, '0');\n      const weekArr = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];\n      const week = weekArr[date.getDay()];\n      this.currentTime = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\n    },\n    async initCharts() {\n      const taskData = [30, 37, 33, 42];\n      const errorData = [3, 2, 4, 1];\n      const weeks = ['12月第1周', '12月第2周', '12月第3周', '12月第4周'];\n\n      // 柱状图初始化\n      const barChart = echarts.init(document.getElementById('bar'));\n      barChart.setOption({\n        title: {\n          text: '12月各周无人机执行任务数',\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis',\n          formatter: params => {\n            const item = params[0];\n            return `<div style=\"padding: 5px;\">\n              <div>${item.name}</div>\n              <div style=\"color: ${item.color};\">执行任务数：${item.value} 次</div>\n              <div>环比增长：${Math.round(Math.random() * 10)}%</div>\n            </div>`;\n          }\n        },\n        legend: {\n          data: ['执行任务数'],\n          right: 20\n        },\n        xAxis: {\n          type: 'category',\n          data: weeks,\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: '任务数（次）',\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              type: 'dashed',\n              color: '#eee'\n            }\n          }\n        },\n        series: [{\n          name: '执行任务数',\n          data: taskData,\n          type: 'bar',\n          itemStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n              offset: 0,\n              color: '#4299E1'\n            }, {\n              offset: 1,\n              color: '#2B6CB0'\n            }])\n          },\n          emphasis: {\n            itemStyle: {\n              color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n                offset: 0,\n                color: '#66B1FF'\n              }, {\n                offset: 1,\n                color: '#337ECC'\n              }]),\n              shadowBlur: 10,\n              shadowColor: 'rgba(0,0,0,0.3)'\n            }\n          }\n        }]\n      });\n\n      // 点击柱状图下钻\n      barChart.on('click', params => {\n        this.currentWeek = params.name;\n        this.detailDialogVisible = true;\n        this.initDetailChart();\n      });\n\n      // 折线图初始化\n      const lineChart = echarts.init(document.getElementById('line'));\n      lineChart.setOption({\n        title: {\n          text: '12月各周无人机异常次数',\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: {\n            type: 'shadow'\n          }\n        },\n        legend: {\n          data: ['异常次数', '预警阈值'],\n          right: 20\n        },\n        xAxis: {\n          type: 'category',\n          data: weeks,\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: '次数（次）',\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              type: 'dashed',\n              color: '#eee'\n            }\n          },\n          markLine: {\n            data: [{\n              name: '预警阈值',\n              yAxis: this.config.alertThreshold,\n              lineStyle: {\n                type: 'dashed',\n                color: '#F56C6C'\n              }\n            }]\n          }\n        },\n        series: [{\n          name: '异常次数',\n          data: errorData,\n          type: 'line',\n          smooth: true,\n          lineStyle: {\n            width: 3,\n            color: '#4299E1'\n          },\n          itemStyle: {\n            color: '#2B6CB0',\n            borderWidth: 2,\n            borderColor: '#fff'\n          },\n          areaStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n              offset: 0,\n              color: 'rgba(66, 153, 225, 0.5)'\n            }, {\n              offset: 1,\n              color: 'rgba(66, 153, 225, 0.1)'\n            }])\n          },\n          emphasis: {\n            lineStyle: {\n              width: 4\n            },\n            itemStyle: {\n              color: '#66B1FF',\n              shadowBlur: 10\n            }\n          }\n        }, {\n          name: '预警阈值',\n          type: 'line',\n          data: Array(4).fill(this.config.alertThreshold),\n          lineStyle: {\n            type: 'dashed',\n            color: '#F56C6C'\n          },\n          symbol: 'none'\n        }]\n      });\n\n      // 窗口自适应\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n        if (this.detailDialogVisible) this.initDetailChart();\n      });\n    },\n    // 详情饼图初始化\n    initDetailChart() {\n      const detailChart = echarts.init(document.getElementById('detailChart'));\n      detailChart.setOption({\n        title: {\n          text: `${this.currentWeek} 任务类型分布`,\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'item',\n          formatter: '{b}: {c} 次 ({d}%)'\n        },\n        legend: {\n          orient: 'vertical',\n          left: 10,\n          data: ['巡逻任务', '巡检任务', '应急任务']\n        },\n        series: [{\n          type: 'pie',\n          radius: ['40%', '70%'],\n          center: ['50%', '50%'],\n          data: [{\n            name: '巡逻任务',\n            value: this.weekDetailData[this.currentWeek][0]\n          }, {\n            name: '巡检任务',\n            value: this.weekDetailData[this.currentWeek][1]\n          }, {\n            name: '应急任务',\n            value: this.weekDetailData[this.currentWeek][2]\n          }],\n          itemStyle: {\n            color: params => {\n              const colors = ['#4299E1', '#67C21A', '#F56C6C'];\n              return colors[params.dataIndex];\n            },\n            emphasis: {\n              shadowBlur: 10,\n              shadowColor: 'rgba(0,0,0,0.3)'\n            }\n          },\n          label: {\n            show: false\n          },\n          labelLine: {\n            show: false\n          }\n        }]\n      });\n    },\n    // 退出登录\n    logout() {\n      localStorage.removeItem('token');\n      // 注释掉路由跳转避免报错，实际使用时恢复\n      // this.$router.push('/login');\n      alert('已退出登录');\n    }\n  },\n  mounted() {\n    // 初始化图表\n    this.initCharts();\n    // 初始化并启动时间更新\n    this.updateTime();\n    this.timer = setInterval(() => {\n      this.updateTime();\n    }, 1000);\n  },\n  beforeDestroy() {\n    // 清除定时器防止内存泄漏\n    clearInterval(this.timer);\n  }\n};","map":{"version":3,"names":["echarts","name","data","config","systemName","inspectFreq","logRetention","maxHeight","maxBattery","alertThreshold","detailDialogVisible","currentWeek","weekDetailData","currentTime","timer","methods","updateTime","date","Date","year","getFullYear","month","String","getMonth","padStart","day","getDate","hour","getHours","minute","getMinutes","second","getSeconds","weekArr","week","getDay","initCharts","taskData","errorData","weeks","barChart","init","document","getElementById","setOption","title","text","textStyle","fontSize","tooltip","trigger","formatter","params","item","color","value","Math","round","random","legend","right","xAxis","type","axisLine","lineStyle","yAxis","splitLine","series","itemStyle","graphic","LinearGradient","offset","emphasis","shadowBlur","shadowColor","on","initDetailChart","lineChart","axisPointer","markLine","smooth","width","borderWidth","borderColor","areaStyle","Array","fill","symbol","window","addEventListener","resize","detailChart","orient","left","radius","center","colors","dataIndex","label","show","labelLine","logout","localStorage","removeItem","alert","mounted","setInterval","beforeDestroy","clearInterval"],"sources":["src/views/Home.vue"],"sourcesContent":["<template>\n  <div style=\"padding: 20px;\">\n    <!-- 顶部栏：新增实时时间+用户悬浮框 -->\n    <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;\">\n      <div>\n        <span style=\"font-size: 22px; font-weight: 800; color: #4299E1;\">无人机管理系统</span>\n        <div style=\"font-size: 16px; font-weight: 500; margin-top: 4px; color: #90CDF4;\">Drone Management System</div>\n      </div>\n      <div style=\"display: flex; align-items: center; gap: 20px; color: #333;\">\n        <!-- 通知框（修复语法错误） -->\n        <el-dropdown placement=\"bottom-end\">\n          <span class=\"el-dropdown-link\" style=\"position: relative; cursor: pointer;\">\n            <i class=\"el-icon-bell\" style=\"font-size: 18px;\"></i>\n            <span style=\"position: absolute; top: -5px; right: -8px; background: #F56C6C; color: #fff; font-size: 12px; width: 18px; height: 18px; line-height: 18px; text-align: center; border-radius: 50%;\">3</span>\n          </span>\n          <el-dropdown-menu slot=\"dropdown\" style=\"width: 300px; padding: 10px;\">\n            <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;\">\n              <span style=\"font-weight: bold;\">今日待办</span>\n              <el-button type=\"text\" size=\"mini\" style=\"color: #4299E1;\">更多</el-button>\n            </div>\n            <el-dropdown-item style=\"padding: 10px 0; border-bottom: 1px solid #eee;\">\n              <div style=\"display: flex; align-items: center; gap: 10px;\">\n                <span style=\"background: #4299E1; color: #fff; font-size: 12px; padding: 2px 6px; border-radius: 4px;\">待办</span>\n                <div>\n                  <div style=\"font-size: 14px;\">检查无人机设备状态</div>\n                  <div style=\"font-size: 12px; color: #999;\">{{ currentTime }}</div>\n                </div>\n              </div>\n            </el-dropdown-item>\n          </el-dropdown-menu>\n        </el-dropdown>\n\n        <!-- 搜索框（优化样式） -->\n        <el-input placeholder=\"请输入搜索内容\" style=\"width: 200px;\" prefix-icon=\"el-icon-search\"></el-input>\n\n        <!-- 新增：实时时间（精确到秒，醒目样式） -->\n        <span style=\"font-size: 14px; color: #4299E1; font-weight: 500;\">{{ currentTime }}</span>\n\n        <!-- 退出按钮 -->\n        <el-button type=\"text\" icon=\"el-icon-switch-button\" style=\"font-size: 16px;\" @click=\"logout\">退出登录</el-button>\n\n        <!-- 新增：用户悬浮框（修复样式和交互） -->\n        <el-tooltip\n            effect=\"dark\"\n            placement=\"bottom\"\n            :content=\"`工号：20230001\n性别：男`\"\n            class=\"user-tooltip\"\n        >\n          <div style=\"display: flex; align-items: center; gap: 8px; cursor: pointer;\">\n            <el-avatar icon=\"el-icon-user\" size=\"medium\" style=\"background: #4299E1; color: #fff;\"></el-avatar>\n            <span style=\"font-size: 14px; color: #333;\">贾舒凯</span>\n          </div>\n        </el-tooltip>\n      </div>\n    </div>\n\n    <!-- 顶部数据卡片（修复语法错误） -->\n    <el-row :gutter=\"10\" style=\"margin-bottom: 20px;\">\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container1\">\n          <div><i class=\"el-icon-s-data\" /> 执勤无人机</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">5</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container2\">\n          <div><i class=\"el-icon-success\" /> 待办任务</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">57</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container4\">\n          <div><i class=\"el-icon-remove\" /> 日志记录</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">1000</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container3\">\n          <div><i class=\"el-icon-warning\" /> 异常运行无人机</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">2</div>\n        </el-card>\n      </el-col>\n    </el-row>\n\n    <!-- 图表：左右布局（周维度） -->\n    <el-row :gutter=\"20\" style=\"margin-bottom: 20px;\">\n      <el-col :span=\"12\">\n        <div id=\"bar\" style=\"width: 100%; height: 300px;\"></div>\n      </el-col>\n      <el-col :span=\"12\">\n        <div id=\"line\" style=\"width: 100%; height: 300px;\"></div>\n      </el-col>\n    </el-row>\n\n    <!-- 数据下钻弹窗（周维度） -->\n    <el-dialog title=\"周任务详情\" :visible.sync=\"detailDialogVisible\" width=\"50%\">\n      <div id=\"detailChart\" style=\"width: 100%; height: 300px;\"></div>\n    </el-dialog>\n\n    <!-- 无人机系统配置模块 -->\n    <el-row>\n      <el-col :span=\"24\">\n        <el-card style=\"border-radius: 8px;\">\n          <div style=\"font-size: 16px; font-weight: bold; margin-bottom: 15px;\">无人机系统配置</div>\n          <el-form label-width=\"120px\" size=\"small\">\n            <el-form-item label=\"系统名称\">\n              <el-input v-model=\"config.systemName\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"巡检频率\">\n              <el-input v-model=\"config.inspectFreq\" suffix=\"分钟\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"日志保留天数\">\n              <el-input v-model=\"config.logRetention\" suffix=\"天\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"最大飞行高度\">\n              <el-input v-model=\"config.maxHeight\" suffix=\"米\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"单次续航时长\">\n              <el-input v-model=\"config.maxBattery\" suffix=\"分钟\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"异常预警阈值\">\n              <el-input v-model=\"config.alertThreshold\" suffix=\"次/小时\" style=\"width: 300px;\" />\n            </el-form-item>\n          </el-form>\n          <div style=\"margin-top: 20px;\">\n            <el-button type=\"primary\" icon=\"el-icon-check\">保存配置</el-button>\n            <el-button type=\"default\" icon=\"el-icon-refresh\" style=\"margin-left: 10px;\">重置</el-button>\n            <el-button type=\"default\" icon=\"el-icon-upload\" style=\"margin-left: 10px;\">导入配置</el-button>\n            <el-button type=\"default\" icon=\"el-icon-download\" style=\"margin-left: 10px;\">导出配置</el-button>\n          </div>\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\n// 注释掉request避免报错，实际使用时恢复\n// import request from '@/utils/request'\n\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      config: {\n        systemName: \"无人机管理系统V1.0\",\n        inspectFreq: 30,\n        logRetention: 90,\n        maxHeight: 120,\n        maxBattery: 45,\n        alertThreshold: 5\n      },\n      detailDialogVisible: false,\n      currentWeek: \"\",\n      weekDetailData: {\n        \"12月第1周\": [8, 10, 12],\n        \"12月第2周\": [10, 12, 15],\n        \"12月第3周\": [9, 11, 13],\n        \"12月第4周\": [12, 14, 16]\n      },\n      currentTime: \"\", // 实时时间\n      timer: null // 定时器标识\n    }\n  },\n  methods: {\n    // 实时更新时间（精确到秒，修复格式化）\n    updateTime() {\n      const date = new Date()\n      const year = date.getFullYear()\n      const month = String(date.getMonth() + 1).padStart(2, '0')\n      const day = String(date.getDate()).padStart(2, '0')\n      const hour = String(date.getHours()).padStart(2, '0')\n      const minute = String(date.getMinutes()).padStart(2, '0')\n      const second = String(date.getSeconds()).padStart(2, '0')\n      const weekArr = ['周日', '周一', '周二', '周三', '周四', '周五', '周六']\n      const week = weekArr[date.getDay()]\n      this.currentTime = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`\n    },\n\n    async initCharts() {\n      const taskData = [30, 37, 33, 42];\n      const errorData = [3, 2, 4, 1];\n      const weeks = ['12月第1周', '12月第2周', '12月第3周', '12月第4周'];\n\n      // 柱状图初始化\n      const barChart = echarts.init(document.getElementById('bar'));\n      barChart.setOption({\n        title: { text: '12月各周无人机执行任务数', textStyle: { fontSize: 16 } },\n        tooltip: {\n          trigger: 'axis',\n          formatter: (params) => {\n            const item = params[0];\n            return `<div style=\"padding: 5px;\">\n              <div>${item.name}</div>\n              <div style=\"color: ${item.color};\">执行任务数：${item.value} 次</div>\n              <div>环比增长：${Math.round(Math.random()*10)}%</div>\n            </div>`;\n          }\n        },\n        legend: { data: ['执行任务数'], right: 20 },\n        xAxis: { type: 'category', data: weeks, axisLine: { lineStyle: { color: '#999' } } },\n        yAxis: {\n          type: 'value',\n          name: '任务数（次）',\n          axisLine: { lineStyle: { color: '#999' } },\n          splitLine: { lineStyle: { type: 'dashed', color: '#eee' } }\n        },\n        series: [{\n          name: '执行任务数',\n          data: taskData,\n          type: 'bar',\n          itemStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n              { offset: 0, color: '#4299E1' },\n              { offset: 1, color: '#2B6CB0' }\n            ])\n          },\n          emphasis: {\n            itemStyle: {\n              color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n                { offset: 0, color: '#66B1FF' },\n                { offset: 1, color: '#337ECC' }\n              ]),\n              shadowBlur: 10,\n              shadowColor: 'rgba(0,0,0,0.3)'\n            }\n          }\n        }]\n      });\n\n      // 点击柱状图下钻\n      barChart.on('click', (params) => {\n        this.currentWeek = params.name;\n        this.detailDialogVisible = true;\n        this.initDetailChart();\n      });\n\n      // 折线图初始化\n      const lineChart = echarts.init(document.getElementById('line'));\n      lineChart.setOption({\n        title: { text: '12月各周无人机异常次数', textStyle: { fontSize: 16 } },\n        tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },\n        legend: { data: ['异常次数', '预警阈值'], right: 20 },\n        xAxis: { type: 'category', data: weeks, axisLine: { lineStyle: { color: '#999' } } },\n        yAxis: {\n          type: 'value',\n          name: '次数（次）',\n          axisLine: { lineStyle: { color: '#999' } },\n          splitLine: { lineStyle: { type: 'dashed', color: '#eee' } },\n          markLine: {\n            data: [{\n              name: '预警阈值',\n              yAxis: this.config.alertThreshold,\n              lineStyle: { type: 'dashed', color: '#F56C6C' }\n            }]\n          }\n        },\n        series: [\n          {\n            name: '异常次数',\n            data: errorData,\n            type: 'line',\n            smooth: true,\n            lineStyle: { width: 3, color: '#4299E1' },\n            itemStyle: { color: '#2B6CB0', borderWidth: 2, borderColor: '#fff' },\n            areaStyle: {\n              color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n                { offset: 0, color: 'rgba(66, 153, 225, 0.5)' },\n                { offset: 1, color: 'rgba(66, 153, 225, 0.1)' }\n              ])\n            },\n            emphasis: {\n              lineStyle: { width: 4 },\n              itemStyle: { color: '#66B1FF', shadowBlur: 10 }\n            }\n          },\n          {\n            name: '预警阈值',\n            type: 'line',\n            data: Array(4).fill(this.config.alertThreshold),\n            lineStyle: { type: 'dashed', color: '#F56C6C' },\n            symbol: 'none'\n          }\n        ]\n      });\n\n      // 窗口自适应\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n        if (this.detailDialogVisible) this.initDetailChart();\n      });\n    },\n\n    // 详情饼图初始化\n    initDetailChart() {\n      const detailChart = echarts.init(document.getElementById('detailChart'));\n      detailChart.setOption({\n        title: { text: `${this.currentWeek} 任务类型分布`, textStyle: { fontSize: 16 } },\n        tooltip: { trigger: 'item', formatter: '{b}: {c} 次 ({d}%)' },\n        legend: { orient: 'vertical', left: 10, data: ['巡逻任务', '巡检任务', '应急任务'] },\n        series: [{\n          type: 'pie',\n          radius: ['40%', '70%'],\n          center: ['50%', '50%'],\n          data: [\n            { name: '巡逻任务', value: this.weekDetailData[this.cur