{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\nimport request from '@/utils/request';\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      loading: false,\n      dialogFormVisible: false,\n      form: {},\n      queryForm: {\n        id: '',\n        name: '',\n        type: '',\n        deviceId: ''\n      },\n      formRules: {\n        name: [{\n          required: true,\n          message: '请输入任务名称',\n          trigger: 'blur'\n        }],\n        type: [{\n          required: true,\n          message: '请选择任务类型',\n          trigger: 'change'\n        }],\n        deviceId: [{\n          required: true,\n          message: '请输入无人机ID',\n          trigger: 'blur'\n        }, {\n          type: 'number',\n          message: '无人机ID必须为数字',\n          trigger: 'blur'\n        }],\n        status: [{\n          required: true,\n          message: '请选择任务状态',\n          trigger: 'change'\n        }]\n      }\n    };\n  },\n  created() {\n    this.loadTaskData();\n  },\n  methods: {\n    resetForm() {\n      this.form = {};\n      this.$refs.formRef && this.$refs.formRef.resetFields();\n    },\n    async loadTaskData() {\n      try {\n        this.loading = true;\n        // 适配后端查询接口：传入 queryKey（后端支持模糊查询）\n        // 拼接查询条件为字符串（可根据后端实际逻辑调整）\n        const queryKey = [this.queryForm.id, this.queryForm.name, this.queryForm.type, this.queryForm.deviceId].filter(Boolean).join(' ');\n        const res = await request.get(\"/task/getAllData\", {\n          params: {\n            queryKey\n          } // 后端接收的参数名是 queryKey\n        });\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : [];\n      } catch (error) {\n        console.error('加载任务数据失败：', error);\n        this.taskList = [];\n        this.$message.error('数据加载失败，请重试');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleQuery() {\n      this.loadTaskData();\n    },\n    handleReset() {\n      this.queryForm = {\n        id: '',\n        name: '',\n        type: '',\n        deviceId: ''\n      };\n      this.loadTaskData();\n    },\n    handleAdd() {\n      this.form = {\n        type: \"0\",\n        status: \"0\"\n      };\n      this.dialogFormVisible = true;\n    },\n    handleEdit(row) {\n      this.dialogFormVisible = true;\n      this.form = JSON.parse(JSON.stringify({\n        id: row.id,\n        name: row.name,\n        type: row.type?.toString() || \"0\",\n        deviceId: row.deviceId || \"\",\n        status: row.status?.toString() || \"0\"\n      }));\n      this.$nextTick(() => {\n        this.dialogFormVisible = true;\n      });\n    },\n    async saveTask() {\n      try {\n        // 1. 表单校验\n        await this.$refs.formRef.validate();\n\n        // 2. 构造提交数据（适配后端 Task 实体类字段）\n        const submitData = {\n          id: this.form.id,\n          // 编辑时有值，新增时无值\n          name: this.form.name,\n          type: Number(this.form.type),\n          deviceId: Number(this.form.deviceId),\n          status: Number(this.form.status)\n          // 可选：若后端需要创建/结束时间，补充以下字段\n          // startTime: this.form.startTime || new Date().toISOString(),\n          // endTime: this.form.endTime || ''\n        };\n\n        // 3. 调用后端通用接口：/task/save（新增+编辑）\n        const apiUrl = \"/task/save\";\n        console.log('提交数据到后端：', submitData, '接口地址：', apiUrl);\n\n        // 4. 发送请求\n        const res = await request.post(apiUrl, submitData);\n\n        // 5. 结果处理（后端返回 Result 格式，code 需确认，通常是200/0）\n        if (res?.code === 200 || res?.data?.success) {\n          this.$message.success(this.form.id ? '编辑任务成功' : '新增任务成功');\n          this.dialogFormVisible = false;\n          this.loadTaskData(); // 刷新表格\n        } else {\n          this.$message.error(res?.data?.msg || (this.form.id ? '编辑失败' : '新增失败'));\n        }\n      } catch (error) {\n        // 详细打印错误信息\n        console.error('保存任务失败详情：', {\n          message: error.message,\n          url: error.config?.url,\n          status: error.response?.status,\n          data: error.response?.data\n        });\n\n        // 针对性提示\n        if (error.response?.status === 404) {\n          this.$message.error('接口不存在！请确认后端服务是否启动，接口路径是否为 /task/save');\n        } else if (error.response?.status === 500) {\n          this.$message.error('后端服务异常，请联系后端开发人员');\n        } else {\n          this.$message.error('保存失败，请检查数据格式是否正确');\n        }\n      }\n    },\n    async handleDelete(row) {\n      try {\n        await this.$confirm('确定删除该任务？', '提示', {\n          type: 'warning'\n        });\n        // 注意：后端暂未提供删除接口，若需要请让后端新增 /task/delete 接口\n        const res = await request.post(\"/task/delete\", {\n          id: row.id\n        });\n        if (res?.code === 200) {\n          this.$message.success('删除成功');\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '删除失败');\n        }\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('删除任务失败：', error);\n          // 若后端未提供删除接口，提示用户\n          if (error.response?.status === 404) {\n            this.$message.error('删除接口未实现，请联系后端开发人员新增 /task/delete 接口');\n          } else {\n            this.$message.error('删除失败');\n          }\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","queryForm","id","type","deviceId","formRules","required","message","trigger","status","created","loadTaskData","methods","resetForm","$refs","formRef","resetFields","queryKey","filter","Boolean","join","res","get","params","Array","isArray","error","console","$message","handleQuery","handleReset","handleAdd","handleEdit","row","JSON","parse","stringify","toString","$nextTick","saveTask","validate","submitData","Number","apiUrl","log","post","code","success","msg","url","config","response","handleDelete","$confirm"],"sources":["src/views/task.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 查询条件区域 -->\r\n    <div style=\"margin-bottom: 20px; display: flex; align-items: center; gap: 15px;\">\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">任务ID：</label>\r\n        <el-input v-model=\"queryForm.id\" placeholder=\"输入任务ID\" style=\"width: 150px;\" />\r\n      </div>\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">任务名称：</label>\r\n        <el-input v-model=\"queryForm.name\" placeholder=\"输入任务名称\" style=\"width: 180px;\" />\r\n      </div>\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">任务类型：</label>\r\n        <el-input v-model=\"queryForm.type\" placeholder=\"输入任务类型（0-3）\" style=\"width: 150px;\" />\r\n      </div>\r\n      <div>\r\n        <label style=\"margin-right: 8px;\">执行无人机：</label>\r\n        <el-input v-model=\"queryForm.deviceId\" placeholder=\"输入执行无人机ID\" style=\"width: 150px;\" />\r\n      </div>\r\n      <el-button type=\"primary\" @click=\"handleQuery\">查询</el-button>\r\n      <el-button @click=\"handleReset\">重置</el-button>\r\n    </div>\r\n\r\n    <!-- 新增按钮 -->\r\n    <el-button type=\"primary\" style=\"margin-bottom: 20px;\" @click=\"handleAdd\">新增任务</el-button>\r\n\r\n    <!-- 编辑弹窗：Vue2 + Element UI 正确绑定 -->\r\n    <el-dialog\r\n        title=\"任务信息\"\r\n        :visible.sync=\"dialogFormVisible\"\r\n        width=\"500px\"\r\n        @close=\"resetForm\"\r\n    >\r\n      <el-form ref=\"formRef\" :model=\"form\" label-width=\"100px\" size=\"small\" :rules=\"formRules\">\r\n        <el-form-item label=\"任务名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"type\">\r\n          <el-select v-model=\"form.type\" placeholder=\"请选择任务类型\">\r\n            <el-option label=\"0-道路巡航\" value=\"0\"></el-option>\r\n            <el-option label=\"1-水域巡逻\" value=\"1\"></el-option>\r\n            <el-option label=\"2-事故取证\" value=\"2\"></el-option>\r\n            <el-option label=\"3-隐患排查\" value=\"3\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"deviceId\">\r\n          <el-input v-model.number=\"form.deviceId\" placeholder=\"请输入无人机ID\" type=\"number\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务状态\" prop=\"status\">\r\n          <el-select v-model=\"form.status\" placeholder=\"请选择任务状态\">\r\n            <el-option label=\"0-未开始\" value=\"0\"></el-option>\r\n            <el-option label=\"1-执行中\" value=\"1\"></el-option>\r\n            <el-option label=\"2-已完成\" value=\"2\"></el-option>\r\n            <el-option label=\"3-已取消\" value=\"3\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTask\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 任务表格 -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column prop=\"id\" label=\"任务ID\" width=\"120\" />\r\n      <el-table-column prop=\"name\" label=\"任务名称\" width=\"180\" />\r\n      <el-table-column prop=\"type\" label=\"任务类型\" width=\"120\" />\r\n      <el-table-column prop=\"deviceId\" label=\"执行无人机\" width=\"120\" />\r\n      <el-table-column prop=\"startTime\" label=\"创建时间\" width=\"180\">\r\n        <template slot-scope=\"scope\">\r\n          {{ scope.row.startTime || '未设置' }}\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"endTime\" label=\"任务结束时间\" width=\"180\">\r\n        <template slot-scope=\"scope\">\r\n          {{ scope.row.endTime || '未设置' }}\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"status\" label=\"任务状态\" width=\"120\" />\r\n      <el-table-column label=\"操作\" width=\"150\">\r\n        <template slot-scope=\"scope\">\r\n          <el-button type=\"primary\" size=\"small\" @click.stop=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click.stop=\"handleDelete(scope.row)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [],\r\n      loading: false,\r\n      dialogFormVisible: false,\r\n      form: {},\r\n      queryForm: {\r\n        id: '',\r\n        name: '',\r\n        type: '',\r\n        deviceId: ''\r\n      },\r\n      formRules: {\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请选择任务类型', trigger: 'change' }],\r\n        deviceId: [\r\n          { required: true, message: '请输入无人机ID', trigger: 'blur' },\r\n          { type: 'number', message: '无人机ID必须为数字', trigger: 'blur' }\r\n        ],\r\n        status: [{ required: true, message: '请选择任务状态', trigger: 'change' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData()\r\n  },\r\n  methods: {\r\n    resetForm() {\r\n      this.form = {}\r\n      this.$refs.formRef && this.$refs.formRef.resetFields()\r\n    },\r\n\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true\r\n        // 适配后端查询接口：传入 queryKey（后端支持模糊查询）\r\n        // 拼接查询条件为字符串（可根据后端实际逻辑调整）\r\n        const queryKey = [\r\n          this.queryForm.id,\r\n          this.queryForm.name,\r\n          this.queryForm.type,\r\n          this.queryForm.deviceId\r\n        ].filter(Boolean).join(' ');\r\n\r\n        const res = await request.get(\"/task/getAllData\", {\r\n          params: { queryKey } // 后端接收的参数名是 queryKey\r\n        })\r\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : []\r\n      } catch (error) {\r\n        console.error('加载任务数据失败：', error)\r\n        this.taskList = []\r\n        this.$message.error('数据加载失败，请重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    handleQuery() {\r\n      this.loadTaskData()\r\n    },\r\n\r\n    handleReset() {\r\n      this.queryForm = {\r\n        id: '',\r\n        name: '',\r\n        type: '',\r\n        deviceId: ''\r\n      }\r\n      this.loadTaskData()\r\n    },\r\n\r\n    handleAdd() {\r\n      this.form = { type: \"0\", status: \"0\" }\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    handleEdit(row) {\r\n      this.dialogFormVisible = true\r\n      this.form = JSON.parse(JSON.stringify({\r\n        id: row.id,\r\n        name: row.name,\r\n        type: row.type?.toString() || \"0\",\r\n        deviceId: row.deviceId || \"\",\r\n        status: row.status?.toString() || \"0\"\r\n      }))\r\n      this.$nextTick(() => {\r\n        this.dialogFormVisible = true\r\n      })\r\n    },\r\n\r\n    async saveTask() {\r\n      try {\r\n        // 1. 表单校验\r\n        await this.$refs.formRef.validate()\r\n\r\n        // 2. 构造提交数据（适配后端 Task 实体类字段）\r\n        const submitData = {\r\n          id: this.form.id, // 编辑时有值，新增时无值\r\n          name: this.form.name,\r\n          type: Number(this.form.type),\r\n          deviceId: Number(this.form.deviceId),\r\n          status: Number(this.form.status),\r\n          // 可选：若后端需要创建/结束时间，补充以下字段\r\n          // startTime: this.form.startTime || new Date().toISOString(),\r\n          // endTime: this.form.endTime || ''\r\n        }\r\n\r\n        // 3. 调用后端通用接口：/task/save（新增+编辑）\r\n        const apiUrl = \"/task/save\";\r\n        console.log('提交数据到后端：', submitData, '接口地址：', apiUrl)\r\n\r\n        // 4. 发送请求\r\n        const res = await request.post(apiUrl, submitData)\r\n\r\n        // 5. 结果处理（后端返回 Result 格式，code 需确认，通常是200/0）\r\n        if (res?.code === 200 || res?.data?.success) {\r\n          