{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\n// 请确保引入你的请求工具\nimport request from '@/utils/request';\nexport default {\n  name: \"recognition\",\n  data() {\n    return {\n      recognition: [],\n      // 表格数据源（初始为空数组）\n      form: {},\n      // 编辑表单数据\n      dialogFormVisible: false,\n      // 弹窗显示状态\n      loading: false,\n      // 加载状态\n      // 表单校验规则\n      formRules: {\n        time: [{\n          required: true,\n          message: '请输入识别时间',\n          trigger: 'blur'\n        }],\n        content: [{\n          required: true,\n          message: '请输入识别结果详情',\n          trigger: 'blur'\n        }],\n        url: [{\n          required: true,\n          message: '请输入存储路径',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.load(); // 页面创建时加载数据\n  },\n  methods: {\n    // 重置表单（弹窗关闭时调用）\n    resetForm() {\n      this.form = {};\n      if (this.$refs.formRef) {\n        this.$refs.formRef.resetFields();\n      }\n    },\n    // 保存编辑数据\n    async save() {\n      try {\n        // 表单校验\n        await this.$refs.formRef.validate();\n\n        // 调用保存接口\n        const res = await request.post(\"/recognition/save\", this.form);\n\n        // 接口返回判断（适配常见的后端返回格式）\n        if (res && (res.code === 200 || res.success)) {\n          this.$message.success(\"保存成功!\");\n          this.dialogFormVisible = false;\n          this.load(); // 重新加载表格数据\n        } else {\n          this.$message.error(res?.msg || '保存失败，请重试');\n        }\n      } catch (error) {\n        console.error('保存识别数据失败：', error);\n        this.$message.error('保存失败，请检查数据格式或网络状态');\n      }\n    },\n    // 加载表格数据（核心修复：确保数据是数组）\n    async load() {\n      try {\n        this.loading = true; // 显示加载状态\n\n        // 调用获取数据接口\n        const res = await request.get(\"/recognition/getAllData\", {});\n\n        // 核心逻辑：兼容不同接口返回格式，确保最终是数组\n        // 适配场景1：{code:200, data: [...]}  场景2：直接返回数组  场景3：其他格式兜底为空数组\n        let tableData = [];\n        if (res && res.data) {\n          // 如果接口返回包裹对象，优先取 data 里的数组；否则直接用 res.data\n          tableData = Array.isArray(res.data) ? res.data : res.data.data || [];\n        }\n\n        // 最终兜底：确保是数组\n        this.recognition = Array.isArray(tableData) ? tableData : [];\n      } catch (error) {\n        console.error('加载识别数据失败：', error);\n        this.recognition = []; // 失败时重置为空数组，避免表格报错\n        this.$message.error('数据加载失败，请刷新页面重试');\n      } finally {\n        this.loading = false; // 关闭加载状态\n      }\n    },\n    // 编辑行数据（深拷贝避免联动表格）\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row)); // 深度拷贝，避免修改表单联动表格\n      this.dialogFormVisible = true;\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","recognition","form","dialogFormVisible","loading","formRules","time","required","message","trigger","content","url","created","load","methods","resetForm","$refs","formRef","resetFields","save","validate","res","post","code","success","$message","error","msg","console","get","tableData","Array","isArray","handleEdit","row","JSON","parse","stringify"],"sources":["src/views/recognition.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 编辑弹窗 -->\r\n    <el-dialog\r\n        title=\"设备信息\"\r\n        v-model=\"dialogFormVisible\"\r\n        width=\"500px\"\r\n        @close=\"resetForm\"\r\n    >\r\n      <el-form\r\n          ref=\"formRef\"\r\n          :model=\"form\"\r\n          label-width=\"100px\"\r\n          size=\"small\"\r\n          :rules=\"formRules\"\r\n      >\r\n        <el-form-item label=\"识别时间\" prop=\"time\">\r\n          <el-input v-model=\"form.time\" autocomplete=\"off\" placeholder=\"请输入识别时间\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"识别结果详情\" prop=\"content\">\r\n          <el-input v-model=\"form.content\" autocomplete=\"off\" placeholder=\"请输入识别结果详情\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"存储路径\" prop=\"url\">\r\n          <el-input v-model=\"form.url\" autocomplete=\"off\" placeholder=\"请输入存储路径\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 数据表格 -->\r\n    <el-table\r\n        :data=\"recognition\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column\r\n          prop=\"id\"\r\n          label=\"识别记录标识\"\r\n          width=\"120\"\r\n      />\r\n      <el-table-column\r\n          prop=\"time\"\r\n          label=\"识别时间\"\r\n          width=\"180\"\r\n      />\r\n      <el-table-column\r\n          prop=\"deviceId\"\r\n          label=\"采集设备\"\r\n          width=\"120\"\r\n      />\r\n      <el-table-column\r\n          prop=\"taskId\"\r\n          label=\"所属任务\"\r\n          width=\"120\"\r\n      />\r\n      <el-table-column\r\n          prop=\"content\"\r\n          label=\"识别结果详情\"\r\n          min-width=\"200\"\r\n      />\r\n      <el-table-column\r\n          prop=\"url\"\r\n          label=\"存储路径\"\r\n          min-width=\"200\"\r\n      />\r\n      <el-table-column label=\"操作\" width=\"120\">\r\n        <template #default=\"scope\">\r\n          <el-button\r\n              type=\"primary\"\r\n              size=\"small\"\r\n              @click=\"handleEdit(scope.row)\"\r\n          >\r\n            编辑 <i class=\"el-icon-edit\"></i>\r\n          </el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\n// 请确保引入你的请求工具\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"recognition\",\r\n  data() {\r\n    return {\r\n      recognition: [], // 表格数据源（初始为空数组）\r\n      form: {}, // 编辑表单数据\r\n      dialogFormVisible: false, // 弹窗显示状态\r\n      loading: false, // 加载状态\r\n      // 表单校验规则\r\n      formRules: {\r\n        time: [{ required: true, message: '请输入识别时间', trigger: 'blur' }],\r\n        content: [{ required: true, message: '请输入识别结果详情', trigger: 'blur' }],\r\n        url: [{ required: true, message: '请输入存储路径', trigger: 'blur' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.load() // 页面创建时加载数据\r\n  },\r\n  methods: {\r\n    // 重置表单（弹窗关闭时调用）\r\n    resetForm() {\r\n      this.form = {}\r\n      if (this.$refs.formRef) {\r\n        this.$refs.formRef.resetFields()\r\n      }\r\n    },\r\n\r\n    // 保存编辑数据\r\n    async save() {\r\n      try {\r\n        // 表单校验\r\n        await this.$refs.formRef.validate()\r\n\r\n        // 调用保存接口\r\n        const res = await request.post(\"/recognition/save\", this.form)\r\n\r\n        // 接口返回判断（适配常见的后端返回格式）\r\n        if (res && (res.code === 200 || res.success)) {\r\n          this.$message.success(\"保存成功!\")\r\n          this.dialogFormVisible = false\r\n          this.load() // 重新加载表格数据\r\n        } else {\r\n          this.$message.error(res?.msg || '保存失败，请重试')\r\n        }\r\n      } catch (error) {\r\n        console.error('保存识别数据失败：', error)\r\n        this.$message.error('保存失败，请检查数据格式或网络状态')\r\n      }\r\n    },\r\n\r\n    // 加载表格数据（核心修复：确保数据是数组）\r\n    async load() {\r\n      try {\r\n        this.loading = true // 显示加载状态\r\n\r\n        // 调用获取数据接口\r\n        const res = await request.get(\"/recognition/getAllData\", {})\r\n\r\n        // 核心逻辑：兼容不同接口返回格式，确保最终是数组\r\n        // 适配场景1：{code:200, data: [...]}  场景2：直接返回数组  场景3：其他格式兜底为空数组\r\n        let tableData = []\r\n        if (res && res.data) {\r\n          // 如果接口返回包裹对象，优先取 data 里的数组；否则直接用 res.data\r\n          tableData = Array.isArray(res.data) ? res.data : (res.data.data || [])\r\n        }\r\n\r\n        // 最终兜底：确保是数组\r\n        this.recognition = Array.isArray(tableData) ? tableData : []\r\n      } catch (error) {\r\n        console.error('加载识别数据失败：', error)\r\n        this.recognition = [] // 失败时重置为空数组，避免表格报错\r\n        this.$message.error('数据加载失败，请刷新页面重试')\r\n      } finally {\r\n        this.loading = false // 关闭加载状态\r\n      }\r\n    },\r\n\r\n    // 编辑行数据（深拷贝避免联动表格）\r\n    handleEdit(row) {\r\n      this.form = JSON.parse(JSON.stringify(row)) // 深度拷贝，避免修改表单联动表格\r\n      this.dialogFormVisible = true\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 优化按钮样式 */\r\n:deep(.el-button) {\r\n  margin: 0 2px;\r\n}\r\n\r\n/* 弹窗表单间距优化 */\r\n:deep(.el-form-item) {\r\n  margin-bottom: 15px;\r\n}\r\n\r\n/* 表格加载状态样式优化 */\r\n:deep(.el-loading-mask) {\r\n  background-color: rgba(255, 255, 255, 0.8);\r\n}\r\n</style>"],"mappings":";;AAsFA;AACA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,WAAA;MAAA;MACAC,IAAA;MAAA;MACAC,iBAAA;MAAA;MACAC,OAAA;MAAA;MACA;MACAC,SAAA;QACAC,IAAA;UAAAC,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,OAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAE,GAAA;UAAAJ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAG,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACA;IACAC,UAAA;MACA,KAAAb,IAAA;MACA,SAAAc,KAAA,CAAAC,OAAA;QACA,KAAAD,KAAA,CAAAC,OAAA,CAAAC,WAAA;MACA;IACA;IAEA;IACA,MAAAC,KAAA;MACA;QACA;QACA,WAAAH,KAAA,CAAAC,OAAA,CAAAG,QAAA;;QAEA;QACA,MAAAC,GAAA,SAAAvB,OAAA,CAAAwB,IAAA,2BAAApB,IAAA;;QAEA;QACA,IAAAmB,GAAA,KAAAA,GAAA,CAAAE,IAAA,YAAAF,GAAA,CAAAG,OAAA;UACA,KAAAC,QAAA,CAAAD,OAAA;UACA,KAAArB,iBAAA;UACA,KAAAU,IAAA;QACA;UACA,KAAAY,QAAA,CAAAC,KAAA,CAAAL,GAAA,EAAAM,GAAA;QACA;MACA,SAAAD,KAAA;QACAE,OAAA,CAAAF,KAAA,cAAAA,KAAA;QACA,KAAAD,QAAA,CAAAC,KAAA;MACA;IACA;IAEA;IACA,MAAAb,KAAA;MACA;QACA,KAAAT,OAAA;;QAEA;QACA,MAAAiB,GAAA,SAAAvB,OAAA,CAAA+B,GAAA;;QAEA;QACA;QACA,IAAAC,SAAA;QACA,IAAAT,GAAA,IAAAA,GAAA,CAAArB,IAAA;UACA;UACA8B,SAAA,GAAAC,KAAA,CAAAC,OAAA,CAAAX,GAAA,CAAArB,IAAA,IAAAqB,GAAA,CAAArB,IAAA,GAAAqB,GAAA,CAAArB,IAAA,CAAAA,IAAA;QACA;;QAEA;QACA,KAAAC,WAAA,GAAA8B,KAAA,CAAAC,OAAA,CAAAF,SAAA,IAAAA,SAAA;MACA,SAAAJ,KAAA;QACAE,OAAA,CAAAF,KAAA,cAAAA,KAAA;QACA,KAAAzB,WAAA;QACA,KAAAwB,QAAA,CAAAC,KAAA;MACA;QACA,KAAAtB,OAAA;MACA;IACA;IAEA;IACA6B,WAAAC,GAAA;MACA,KAAAhC,IAAA,GAAAiC,IAAA,CAAAC,KAAA,CAAAD,IAAA,CAAAE,SAAA,CAAAH,GAAA;MACA,KAAA/B,iBAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}