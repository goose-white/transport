{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\nimport request from '@/utils/request';\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      // 初始值为空数组\n      loading: false,\n      dialogFormVisible: false,\n      form: {},\n      formRules: {\n        name: [{\n          required: true,\n          message: '请输入任务名称',\n          trigger: 'blur'\n        }],\n        type: [{\n          required: true,\n          message: '请输入任务类型',\n          trigger: 'blur'\n        }],\n        device_id: [{\n          required: true,\n          message: '请输入无人机ID',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.loadTaskData(); // 页面加载时获取数据\n  },\n  methods: {\n    // 重置表单\n    resetForm() {\n      this.form = {};\n      this.$refs.formRef?.resetFields();\n    },\n    // 获取任务列表（直接使用数据库原始数据）\n    async loadTaskData() {\n      try {\n        this.loading = true;\n        const res = await request.get(\"/task/getAllData\", {});\n        // 直接提取后端返回的原始数组，不做任何字段映射/转换\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : [];\n      } catch (error) {\n        console.error('数据加载失败：', error);\n        this.taskList = [];\n        this.$message.error('数据加载失败，请重试');\n      } finally {\n        this.loading = false;\n      }\n    },\n    // 新增任务\n    handleAdd() {\n      this.form = {};\n      this.dialogFormVisible = true;\n    },\n    // 编辑任务\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row)); // 深拷贝避免原数据被修改\n      this.dialogFormVisible = true;\n    },\n    // 保存任务（新增/编辑）\n    async saveTask() {\n      try {\n        await this.$refs.formRef.validate(); // 表单校验\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\";\n        const res = await request.post(apiUrl, this.form);\n        if (res?.code === 200) {\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功');\n          this.dialogFormVisible = false;\n          this.loadTaskData(); // 保存后刷新数据\n        } else {\n          this.$message.error(res?.msg || '保存失败');\n        }\n      } catch (error) {\n        this.$message.error('保存失败，请检查输入内容');\n      }\n    },\n    // 删除任务\n    async handleDelete(row) {\n      try {\n        await this.$confirm('确定删除该任务？', '提示', {\n          type: 'warning'\n        });\n        const res = await request.post(\"/task/delete\", {\n          id: row.id\n        });\n        if (res?.code === 200) {\n          this.$message.success('删除成功');\n          this.loadTaskData(); // 删除后刷新数据\n        } else {\n          this.$message.error(res?.msg || '删除失败');\n        }\n      } catch (error) {\n        if (error !== 'cancel') {\n          this.$message.error('删除操作取消');\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","formRules","required","message","trigger","type","device_id","created","loadTaskData","methods","resetForm","$refs","formRef","resetFields","res","get","Array","isArray","error","console","$message","handleAdd","handleEdit","row","JSON","parse","stringify","saveTask","validate","apiUrl","id","post","code","success","msg","handleDelete","$confirm"],"sources":["src/views/task.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 新增/编辑弹窗 -->\r\n    <el-dialog title=\"任务信息\" v-model=\"dialogFormVisible\" width=\"500px\" @close=\"resetForm\">\r\n      <el-form ref=\"formRef\" :model=\"form\" label-width=\"100px\" size=\"small\" :rules=\"formRules\">\r\n        <el-form-item label=\"任务名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"type\">\r\n          <el-input v-model=\"form.type\" placeholder=\"请输入任务类型（数据库原始值）\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"device_id\">\r\n          <el-input v-model=\"form.device_id\" placeholder=\"请输入无人机ID\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTask\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 新增按钮 -->\r\n    <el-button type=\"primary\" style=\"margin-bottom: 20px;\" @click=\"handleAdd\">新增任务</el-button>\r\n\r\n    <!-- 任务表格：显示数据库原始值 -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column prop=\"id\" label=\"任务ID\" width=\"120\" />\r\n      <el-table-column prop=\"name\" label=\"任务名称\" width=\"180\" />\r\n      <!-- 任务类型：显示数据库原始值 -->\r\n      <el-table-column prop=\"type\" label=\"任务类型\" width=\"120\" />\r\n      <el-table-column prop=\"device_id\" label=\"执行无人机\" width=\"120\" />\r\n      <el-table-column prop=\"start_time\" label=\"创建时间\" width=\"180\" />\r\n      <el-table-column prop=\"end_time\" label=\"任务结束时间\" width=\"180\" />\r\n      <!-- 任务状态：显示数据库原始值 -->\r\n      <el-table-column prop=\"status\" label=\"任务状态\" width=\"120\" />\r\n      <el-table-column label=\"操作\" width=\"150\">\r\n        <template #default=\"scope\">\r\n          <el-button type=\"primary\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click=\"handleDelete(scope.row)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [], // 初始值为空数组\r\n      loading: false,\r\n      dialogFormVisible: false,\r\n      form: {},\r\n      formRules: {\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请输入任务类型', trigger: 'blur' }],\r\n        device_id: [{ required: true, message: '请输入无人机ID', trigger: 'blur' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData() // 页面加载时获取数据\r\n  },\r\n  methods: {\r\n    // 重置表单\r\n    resetForm() {\r\n      this.form = {}\r\n      this.$refs.formRef?.resetFields()\r\n    },\r\n\r\n    // 获取任务列表（直接使用数据库原始数据）\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true\r\n        const res = await request.get(\"/task/getAllData\", {})\r\n        // 直接提取后端返回的原始数组，不做任何字段映射/转换\r\n        this.taskList = res.data.data && Array.isArray(res.data.data) ? res.data.data : []\r\n      } catch (error) {\r\n        console.error('数据加载失败：', error)\r\n        this.taskList = []\r\n        this.$message.error('数据加载失败，请重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    // 新增任务\r\n    handleAdd() {\r\n      this.form = {}\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    // 编辑任务\r\n    handleEdit(row) {\r\n      this.form = JSON.parse(JSON.stringify(row)) // 深拷贝避免原数据被修改\r\n      this.dialogFormVisible = true\r\n    },\r\n\r\n    // 保存任务（新增/编辑）\r\n    async saveTask() {\r\n      try {\r\n        await this.$refs.formRef.validate() // 表单校验\r\n        const apiUrl = this.form.id ? \"/task/update\" : \"/task/save\"\r\n        const res = await request.post(apiUrl, this.form)\r\n\r\n        if (res?.code === 200) {\r\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功')\r\n          this.dialogFormVisible = false\r\n          this.loadTaskData() // 保存后刷新数据\r\n        } else {\r\n          this.$message.error(res?.msg || '保存失败')\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('保存失败，请检查输入内容')\r\n      }\r\n    },\r\n\r\n    // 删除任务\r\n    async handleDelete(row) {\r\n      try {\r\n        await this.$confirm('确定删除该任务？', '提示', { type: 'warning' })\r\n        const res = await request.post(\"/task/delete\", { id: row.id })\r\n\r\n        if (res?.code === 200) {\r\n          this.$message.success('删除成功')\r\n          this.loadTaskData() // 删除后刷新数据\r\n        } else {\r\n          this.$message.error(res?.msg || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') {\r\n          this.$message.error('删除操作取消')\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 样式微调 */\r\n:deep(.el-button) { margin: 0 4px; }\r\n:deep(.el-form-item) { margin-bottom: 15px; }\r\n</style>"],"mappings":";;AAoDA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MAAA;MACAC,OAAA;MACAC,iBAAA;MACAC,IAAA;MACAC,SAAA;QACAN,IAAA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,IAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAE,SAAA;UAAAJ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAG,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACA;IACAC,UAAA;MACA,KAAAV,IAAA;MACA,KAAAW,KAAA,CAAAC,OAAA,EAAAC,WAAA;IACA;IAEA;IACA,MAAAL,aAAA;MACA;QACA,KAAAV,OAAA;QACA,MAAAgB,GAAA,SAAApB,OAAA,CAAAqB,GAAA;QACA;QACA,KAAAlB,QAAA,GAAAiB,GAAA,CAAAlB,IAAA,CAAAA,IAAA,IAAAoB,KAAA,CAAAC,OAAA,CAAAH,GAAA,CAAAlB,IAAA,CAAAA,IAAA,IAAAkB,GAAA,CAAAlB,IAAA,CAAAA,IAAA;MACA,SAAAsB,KAAA;QACAC,OAAA,CAAAD,KAAA,YAAAA,KAAA;QACA,KAAArB,QAAA;QACA,KAAAuB,QAAA,CAAAF,KAAA;MACA;QACA,KAAApB,OAAA;MACA;IACA;IAEA;IACAuB,UAAA;MACA,KAAArB,IAAA;MACA,KAAAD,iBAAA;IACA;IAEA;IACAuB,WAAAC,GAAA;MACA,KAAAvB,IAAA,GAAAwB,IAAA,CAAAC,KAAA,CAAAD,IAAA,CAAAE,SAAA,CAAAH,GAAA;MACA,KAAAxB,iBAAA;IACA;IAEA;IACA,MAAA4B,SAAA;MACA;QACA,WAAAhB,KAAA,CAAAC,OAAA,CAAAgB,QAAA;QACA,MAAAC,MAAA,QAAA7B,IAAA,CAAA8B,EAAA;QACA,MAAAhB,GAAA,SAAApB,OAAA,CAAAqC,IAAA,CAAAF,MAAA,OAAA7B,IAAA;QAEA,IAAAc,GAAA,EAAAkB,IAAA;UACA,KAAAZ,QAAA,CAAAa,OAAA,MAAAjC,IAAA,CAAA8B,EAAA;UACA,KAAA/B,iBAAA;UACA,KAAAS,YAAA;QACA;UACA,KAAAY,QAAA,CAAAF,KAAA,CAAAJ,GAAA,EAAAoB,GAAA;QACA;MACA,SAAAhB,KAAA;QACA,KAAAE,QAAA,CAAAF,KAAA;MACA;IACA;IAEA;IACA,MAAAiB,aAAAZ,GAAA;MACA;QACA,WAAAa,QAAA;UAAA/B,IAAA;QAAA;QACA,MAAAS,GAAA,SAAApB,OAAA,C