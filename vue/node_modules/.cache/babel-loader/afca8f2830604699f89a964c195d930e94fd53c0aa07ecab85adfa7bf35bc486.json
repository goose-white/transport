ption label=\"执行中(1)\" value=\"1\" />\r\n            <el-option label=\"已完成(2)\" value=\"2\" />\r\n          </el-select>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"addDialogVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"submitAddForm\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 任务表格 -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n        empty-text=\"当前条件下无匹配数据，请调整查询条件\"\r\n    >\r\n      <el-table-column prop=\"id\" label=\"任务ID\" width=\"120\" />\r\n      <el-table-column prop=\"name\" label=\"任务名称\" width=\"180\" />\r\n      <el-table-column prop=\"type\" label=\"任务类型\" width=\"120\" />\r\n      <el-table-column prop=\"deviceId\" label=\"执行无人机\" width=\"120\" />\r\n      <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"200\" />\r\n      <el-table-column prop=\"endTime\" label=\"任务结束时间\" width=\"200\" />\r\n      <el-table-column prop=\"status\" label=\"任务状态\" width=\"120\" />\r\n      <el-table-column label=\"操作\" width=\"120\">\r\n        <template #default=\"scope\">\r\n          <el-button type=\"primary\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click=\"handleDelete(scope.row.id)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n\r\n    <!-- 编辑弹窗（保留原有） -->\r\n    <el-dialog title=\"编辑任务\" v-model=\"editDialogVisible\" width=\"500px\">\r\n      <el-form ref=\"editFormRef\" :model=\"editForm\" label-width=\"100px\" size=\"small\" :rules=\"editFormRules\">\r\n        <el-form-item label=\"任务名称\" prop=\"name\">\r\n          <el-input v-model=\"editForm.name\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"type\">\r\n          <el-select v-model=\"editForm.type\" placeholder=\"请选择任务类型\">\r\n            <el-option label=\"道路巡航(0)\" value=\"0\" />\r\n            <el-option label=\"水域巡逻(1)\" value=\"1\" />\r\n            <el-option label=\"事故取证(2)\" value=\"2\" />\r\n            <el-option label=\"隐患排查(3)\" value=\"3\" />\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"deviceId\">\r\n          <el-input v-model.number=\"editForm.deviceId\" placeholder=\"请输入执行无人机ID\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"创建时间\" prop=\"createTime\">\r\n          <el-date-picker\r\n              v-model=\"editForm.createTime\"\r\n              type=\"datetime\"\r\n              placeholder=\"选择创建时间\"\r\n              value-format=\"yyyy-MM-dd HH:mm:ss\"\r\n          />\r\n        </el-form-item>\r\n        <el-form-item label=\"任务结束时间\" prop=\"endTime\">\r\n          <el-date-picker\r\n              v-model=\"editForm.endTime\"\r\n              type=\"datetime\"\r\n              placeholder=\"选择结束时间\"\r\n              value-format=\"yyyy-MM-dd HH:mm:ss\"\r\n          />\r\n        </el-form-item>\r\n        <el-form-item label=\"任务状态\" prop=\"status\">\r\n          <el-select v-model=\"editForm.status\" placeholder=\"请选择任务状态\">\r\n            <el-option label=\"未开始(0)\" value=\"0\" />\r\n            <el-option label=\"执行中(1)\" value=\"1\" />\r\n            <el-option label=\"已完成(2)\" value=\"2\" />\r\n          </el-select>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"editDialogVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"submitEditForm\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"DroneTaskManagement\",\r\n  data() {\r\n    return {\r\n      taskList: [], // 任务列表\r\n      loading: false, // 加载状态\r\n      // 新增任务相关\r\n      addDialogVisible: false,\r\n      addForm: {},\r\n      addFormRules: {\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请选择任务类型', trigger: 'change' }],\r\n        deviceId: [{ required: true, message: '请输入执行无人机ID', trigger: 'blur' }, { type: 'number', message: '请输入数字', trigger: 'blur' }],\r\n        createTime: [{ required: true, message: '请选择创建时间', trigger: 'change' }],\r\n        endTime: [{ required: true, message: '请选择结束时间', trigger: 'change' }],\r\n        status: [{ required: true, message: '请选择任务状态', trigger: 'change' }]\r\n      },\r\n      // 编辑任务相关\r\n      editDialogVisible: false,\r\n      editForm: {},\r\n      editFormRules: {\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请选择任务类型', trigger: 'change' }],\r\n        deviceId: [{ required: true, message: '请输入执行无人机ID', trigger: 'blur' }, { type: 'number', message: '请输入数字', trigger: 'blur' }],\r\n        createTime: [{ required: true, message: '请选择创建时间', trigger: 'change' }],\r\n        endTime: [{ required: true, message: '请选择结束时间', trigger: 'change' }],\r\n        status: [{ required: true, message: '请选择任务状态', trigger: 'change' }]\r\n      },\r\n      // 查询表单\r\n      queryForm: {\r\n        id: \"\",\r\n        name: \"\",\r\n        type: \"\",\r\n        deviceId: \"\"\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData()\r\n  },\r\n  methods: {\r\n    // 加载任务数据\r\n    loadTaskData() {\r\n      this.loading = true\r\n      request.get(\"/task/getAllData\")\r\n          .then(res => {\r\n            this.taskList = Array.isArray(res.data) ? res.data : res.data?.data || []\r\n          })\r\n          .catch(err => {\r\n            console.error(\"加载任务失败：\", err)\r\n            this.$message.error(\"数据加载失败，请重试\")\r\n            this.taskList = []\r\n          })\r\n          .finally(() => {\r\n            this.loading = false\r\n          })\r\n    },\r\n\r\n    // 打开新增任务弹窗\r\n    openAddDialog() {\r\n      this.addForm = {} // 重置表单\r\n      this.addDialogVisible = true\r\n    },\r\n\r\n    // 提交新增任务表单\r\n    async submitAddForm() {\r\n      try {\r\n        await this.$refs.addFormRef.validate()\r\n        // 转换类型（确保后端接收数值）\r\n        const submitData = {\r\n          ...this.addForm,\r\n          type: Number(this.addForm.type),\r\n          deviceId: Number(this.addForm.deviceId),\r\n          status: Number(this.addForm.status)\r\n        }\r\n        const res = await request.post(\"/task/add\", submitData)\r\n        if (res.data?.code === 200 || res.data) {\r\n          this.$message.success(\"新增任务成功!\")\r\n          this.addDialogVisible = false\r\n          this.loadTaskData() // 刷新数据\r\n        } else {\r\n          this.$message.error(\"新增失败，请重试\")\r\n        }\r\n      } catch (error) {\r\n        console.error(\"新增任务失败：\", error)\r\n        this.$message.error(\"新增失败，请检查数据格式\")\r\n      }\r\n    },\r\n\r\n    // 打开编辑弹窗\r\n    handleEdit(row) {\r\n      this.editForm = { ...row }\r\n      this.editDialogVisible = true\r\n    },\r\n\r\n    // 提交编辑表单\r\n    async submitEditForm() {\r\n      try {\r\n        await this.$refs.editFormRef.validate()\r\n        const submitData = {\r\n          ...this.editForm,\r\n          type: Number(this.editForm.type),\r\n          deviceId: Number(this.editForm.deviceId),\r\n          status: Number(this.editForm.status)\r\n        }\r\n        const res = await request.post(\"/task/update\", submitData)\r\n        if (res.data?.code === 200 || res.data) {\r\n          this.$message.success(\"编辑任务成功!\")\r\n          this.editDialogVisible = false\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(\"编辑失败，请重试\")\r\n        }\r\n      } catch (error) {\r\n        console.error(\"编辑任务失败：\", error)\r\n        this.$message.error(\"编辑失败，请检查数据格式\")\r\n      }\r\n    },\r\n\r\n    // 删除任务\r\n    handleDelete(id) {\r\n      this.$confirm('此操作将永久删除该任务，是否继续？', '提示', { type: 'warning' })\r\n          .then(async () => {\r\n            const res = await request.post(\"/task/delete\", { id: Number(id) })\r\n            if (res.data?.code === 200 || res.data) {\r\n              this.$message.success('删除成功!')\r\n              this.loadTaskData()\r\n            } else {\r\n              this.$message.error('删除失败，请重试')\r\n            }\r\n          })\r\n          .catch(() => {\r\n            this.$message.info('已取消删除')\r\n          })\r\n    },\r\n\r\n    // 查询功能\r\n    loadByColumn() {\r\n      this.loading = true\r\n      request.get(\"/task/getAllData\")\r\n          .then(res => {\r\n            let list = Array.isArray(res.data) ? res.data : res.data?.data || []\r\n            if (this.queryForm.id) list = list.filter(item => item.id === Number(this.queryForm.id))\r\n            if (this.queryForm.name) list = list.filter(item => item.name.includes(this.queryForm.name))\r\n            if (this.queryForm.type) list = list.filter(item => item.type === Number(this.queryForm.type))\r\n            if (this.queryForm.deviceId) list = list.filter(item => item.deviceId === Number(this.queryForm.deviceId))\r\n            this.taskList = list\r\n          })\r\n          .catch(err => {\r\n            this.$message.error(\"查询失败，请重试\")\r\n            this.taskList = []\r\n          })\r\n          .finally(() => {\r\n            this.loading = false\r\n          })\r\n    },\r\n\r\n    // 重置查询\r\n    resetQuery() {\r\n      this.queryForm = { id: \"\", name: \"\", type: \"\", deviceId: \"\" }\r\n      this.loadTaskData()\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n:deep(.el-form-item) {\r\n  margin-bottom: 15px;\r\n}\r\n:deep(.el-form-inline .el-form-item) {\r\n  margin-bottom: 0 !important;\r\n  margin-right: 15px;\r\n}\r\n</style>"],"mappings":";;AAqJA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MAAA;MACAC,OAAA;MAAA;MACA;MA