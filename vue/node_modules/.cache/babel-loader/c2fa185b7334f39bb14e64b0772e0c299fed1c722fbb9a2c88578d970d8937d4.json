{"ast":null,"code":"export default {\n  name: \"recognition\",\n  created() {\n    this.load();\n  },\n  methods: {\n    save() {\n      this.request.post(\"/recognition/save\", this.form).then(res => {\n        if (res.data) {\n          this.$message.success(\"保存成功!\");\n          this.dialogFormVisible = false;\n          this.load();\n        }\n      });\n    },\n    load() {\n      this.request.get(\"/recognition/getAllData\", {}).then(res => {\n        this.recognition = res.data;\n      });\n    }\n  },\n  data() {\n    return {\n      recognition: [],\n      form: {},\n      dialogFormVisible: false\n    };\n  },\n  handleEdit(row) {\n    this.form = row;\n    this.dialogFormVisible = true;\n  }\n};","map":{"version":3,"names":["name","created","load","methods","save","request","post","form","then","res","data","$message","success","dialogFormVisible","get","recognition","handleEdit","row"],"sources":["src/views/recognition.vue"],"sourcesContent":["<script>\r\nexport default {\r\n  name: \"recognition\",\r\n  created() {\r\n    this.load()\r\n  },\r\n  methods:{\r\n    save(){\r\n      this.request.post(\"/recognition/save\", this.form).then(res=>{\r\n        if (res.data){\r\n          this.$message.success(\"保存成功!\")\r\n          this.dialogFormVisible = false\r\n          this.load()\r\n        }\r\n      })\r\n    },\r\n    load(){\r\n      this.request.get(\"/recognition/getAllData\",\r\n          {}).then(res=>{\r\n        this.recognition = res.data\r\n      })\r\n    }\r\n  },\r\n  data() {\r\n    return {\r\n      recognition: [],\r\n      form:{},\r\n      dialogFormVisible:false,\r\n    }\r\n  },\r\n  handleEdit(row){\r\n    this.form = row\r\n    this.dialogFormVisible = true\r\n  }\r\n}\r\n\r\n</script>\r\n\r\n<template>\r\n  <div>\r\n    <el-dialog title=\"设备信息\" :visible.sync=\"dialogFormVisible\" width=\"30%\">\r\n      <el-form label-width=\"80px\" size=\"small\">\r\n        <el-form-item label=\"识别时间\" >\r\n          <el-input v-model=\"form.recTime\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"识别结果详情\" >\r\n          <el-input v-model=\"form.rec_content\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"存储路径\" >\r\n          <el-input v-model=\"form.ic_url\" autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <el-table\r\n        :data=\"recognition\"\r\n        stripe\r\n        style=\"width: 100%\">\r\n      <el-table-column\r\n          prop=\"id\"\r\n          label=\"识别记录标识\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"recTime\"\r\n          label=\"识别时间\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"deviceId\"\r\n          label=\"采集设备\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"taskId\"\r\n          label=\"所属任务\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"recContent\"\r\n          label=\"识别结果详情\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column\r\n          prop=\"picUrl\"\r\n          label=\"存储路径\"\r\n          width=\"180\">\r\n      </el-table-column>\r\n      <el-table-column label = \"操作\">\r\n        <template v-slot = \"scope\">\r\n          <el-button type = \"success\" @click = \"handleEdit(scope.row)\"> 编辑 <i class = \"el-icon-edit\"></i></el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":"AACA;EACAA,IAAA;EACAC,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;