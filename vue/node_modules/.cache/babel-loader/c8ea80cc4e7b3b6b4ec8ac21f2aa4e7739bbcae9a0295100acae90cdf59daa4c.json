{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      config: {\n        systemName: \"无人机管理系统V1.0\",\n        inspectFreq: 30,\n        logRetention: 90,\n        maxHeight: 120,\n        maxBattery: 45,\n        alertThreshold: 5\n      },\n      currentTime: \"\",\n      timer: null\n    };\n  },\n  methods: {\n    updateTime() {\n      const date = new Date();\n      const year = date.getFullYear();\n      const month = String(date.getMonth() + 1).padStart(2, '0');\n      const day = String(date.getDate()).padStart(2, '0');\n      const hour = String(date.getHours()).padStart(2, '0');\n      const minute = String(date.getMinutes()).padStart(2, '0');\n      const second = String(date.getSeconds()).padStart(2, '0');\n      const weekArr = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];\n      const week = weekArr[date.getDay()];\n      this.currentTime = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\n    },\n    initCharts() {\n      const taskData = [30, 37, 33, 42];\n      const errorData = [3, 2, 4, 1];\n      const weeks = ['12月第1周', '12月第2周', '12月第3周', '12月第4周'];\n\n      // 柱状图\n      const barChart = echarts.init(document.getElementById('bar'));\n      barChart.setOption({\n        title: {\n          text: '12月各周无人机执行任务数',\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis'\n        },\n        xAxis: {\n          type: 'category',\n          data: weeks,\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: '任务数（次）',\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              type: 'dashed',\n              color: '#eee'\n            }\n          }\n        },\n        series: [{\n          name: '执行任务数',\n          data: taskData,\n          type: 'bar',\n          itemStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n              offset: 0,\n              color: '#4299E1'\n            }, {\n              offset: 1,\n              color: '#2B6CB0'\n            }])\n          }\n        }]\n      });\n\n      // 折线图\n      const lineChart = echarts.init(document.getElementById('line'));\n      lineChart.setOption({\n        title: {\n          text: '12月各周无人机异常次数',\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis'\n        },\n        xAxis: {\n          type: 'category',\n          data: weeks,\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: '次数（次）',\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              type: 'dashed',\n              color: '#eee'\n            }\n          },\n          markLine: {\n            data: [{\n              name: '预警阈值',\n              yAxis: this.config.alertThreshold,\n              lineStyle: {\n                type: 'dashed',\n                color: '#F56C6C'\n              }\n            }]\n          }\n        },\n        series: [{\n          name: '异常次数',\n          data: errorData,\n          type: 'line',\n          smooth: true,\n          lineStyle: {\n            width: 3,\n            color: '#4299E1'\n          },\n          areaStyle: {\n            color: 'rgba(66, 153, 225, 0.1)'\n          }\n        }]\n      });\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n      });\n    },\n    logout() {\n      localStorage.removeItem('token');\n      alert('已退出登录');\n    }\n  },\n  mounted() {\n    this.updateTime();\n    this.timer = setInterval(() => this.updateTime(), 1000);\n    this.initCharts();\n  },\n  beforeDestroy() {\n    clearInterval(this.timer);\n  }\n};","map":{"version":3,"names":["echarts","name","data","config","systemName","inspectFreq","logRetention","maxHeight","maxBattery","alertThreshold","currentTime","timer","methods","updateTime","date","Date","year","getFullYear","month","String","getMonth","padStart","day","getDate","hour","getHours","minute","getMinutes","second","getSeconds","weekArr","week","getDay","initCharts","taskData","errorData","weeks","barChart","init","document","getElementById","setOption","title","text","textStyle","fontSize","tooltip","trigger","xAxis","type","axisLine","lineStyle","color","yAxis","splitLine","series","itemStyle","graphic","LinearGradient","offset","lineChart","markLine","smooth","width","areaStyle","window","addEventListener","resize","logout","localStorage","removeItem","alert","mounted","setInterval","beforeDestroy","clearInterval"],"sources":["src/views/Home.vue"],"sourcesContent":["<template>\n  <!-- 页面最顶部导航栏（仅保留此处的系统名、搜索、时间、用户） -->\n  <div style=\"background: #2D2D2D; color: #fff; padding: 0 20px; height: 60px; line-height: 60px; display: flex; justify-content: space-between; align-items: center;\">\n    <div>\n      <span style=\"font-size: 18px; font-weight: 800;\">无人机管理系统</span>\n      <span style=\"font-size: 12px; margin-left: 10px; color: #90CDF4;\">Drone Management System</span>\n    </div>\n    <div style=\"display: flex; align-items: center; gap: 20px;\">\n      <!-- 通知框 -->\n      <el-dropdown placement=\"bottom-end\">\n        <span class=\"el-dropdown-link\" style=\"position: relative; cursor: pointer;\">\n          <<i class=\"el-icon-bell\" style=\"font-size: 18px;\"></</i>\n          <span style=\"position: absolute; top: -5px; right: -8px; background: #F56C6C; color: #fff; font-size: 12px; width: 18px; height: 18px; line-height: 18px; text-align: center; border-radius: 50%;\">3</span>\n        </span>\n        <el-dropdown-menu slot=\"dropdown\" style=\"width: 300px; padding: 10px;\">\n          <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;\">\n            <span style=\"font-weight: bold;\">今日待办</span>\n            <el-button type=\"text\" size=\"mini\" style=\"color: #4299E1;\">更多</el-button>\n          </div>\n          <el-dropdown-item style=\"padding: 10px 0; border-bottom: 1px solid #eee;\">\n            <div style=\"display: flex; align-items: center; gap: 10px;\">\n              <span style=\"background: #4299E1; color: #fff; font-size: 12px; padding: 2px 6px; border-radius: 4px;\">待办</span>\n              <div>\n                <div style=\"font-size: 14px;\">检查无人机设备状态</div>\n                <div style=\"font-size: 12px; color: #999;\">{{ currentTime }}</div>\n              </div>\n            </div>\n          </el-dropdown-item>\n        </el-dropdown-menu>\n      </el-dropdown>\n\n      <!-- 搜索框 -->\n      <el-input placeholder=\"请输入搜索内容\" style=\"width: 200px; background: rgba(255,255,255,0.1); border: none; color: #fff;\" prefix-icon=\"el-icon-search\"></el-input>\n\n      <!-- 实时时间 -->\n      <span style=\"font-size: 14px;\">{{ currentTime }}</span>\n\n      <!-- 退出登录 -->\n      <el-button type=\"text\" icon=\"el-icon-switch-button\" style=\"color: #fff; font-size: 16px;\" @click=\"logout\">退出登录</el-button>\n\n      <!-- 用户悬浮框 -->\n      <el-tooltip\n          effect=\"dark\"\n          placement=\"bottom\"\n          :content=\"`工号：20230001\n性别：男`\"\n          class=\"user-tooltip\"\n      >\n        <div style=\"display: flex; align-items: center; gap: 8px; cursor: pointer;\">\n          <el-avatar icon=\"el-icon-user\" size=\"medium\" style=\"background: #4299E1; color: #fff;\"></el-avatar>\n          <span>贾舒凯</span>\n        </div>\n      </el-tooltip>\n    </div>\n  </div>\n\n  <!-- 主内容区（移除表上方的重复导航） -->\n  <div style=\"display: flex;\">\n    <!-- 侧边栏 -->\n    <div style=\"width: 180px; background: #33393B; color: #fff; min-height: calc(100vh - 60px); padding-top: 20px;\">\n      <div style=\"padding: 10px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px;\">\n        <<i class=\"el-icon-menu\"></</i>\n        <span>主页</span>\n      </div>\n      <div style=\"padding: 10px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px;\">\n        <<i class=\"el-icon-setting\"></</i>\n        <span>系统管理</span>\n      </div>\n      <div style=\"padding: 10px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px;\">\n        <<i class=\"el-icon-airplane\"></</i>\n        <span>无人机管理</span>\n      </div>\n      <div style=\"padding: 10px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px;\">\n        <<i class=\"el-icon-list\"></</i>\n        <span>无人机任务管理</span>\n      </div>\n      <div style=\"padding: 10px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px;\">\n        <<i class=\"el-icon-document\"></</i>\n        <span>记录管理</span>\n      </div>\n    </div>\n\n    <!-- 内容区 -->\n    <div style=\"flex: 1; padding: 20px; background: #fff; min-height: calc(100vh - 60px);\">\n      <!-- 数据卡片 -->\n      <el-row :gutter=\"10\" style=\"margin-bottom: 20px;\">\n        <el-col :span=\"6\">\n          <el-card style=\"color: #fff; height: 100px;\" class=\"card-container1\">\n            <div><<i class=\"el-icon-s-data\" /> 执勤无人机</div>\n            <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">5</div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card style=\"color: #fff; height: 100px;\" class=\"card-container2\">\n            <div><<i class=\"el-icon-success\" /> 待办任务</div>\n            <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">57</div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card style=\"color: #fff; height: 100px;\" class=\"card-container4\">\n            <div><<i class=\"el-icon-remove\" /> 日志记录</div>\n            <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">1000</div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card style=\"color: #fff; height: 100px;\" class=\"card-container3\">\n            <div><<i class=\"el-icon-warning\" /> 异常运行无人机</div>\n            <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">2</div>\n          </el-card>\n        </el-col>\n      </el-row>\n\n      <!-- 图表 -->\n      <el-row :gutter=\"20\" style=\"margin-bottom: 20px;\">\n        <el-col :span=\"12\">\n          <div id=\"bar\" style=\"width: 100%; height: 300px;\"></div>\n        </el-col>\n        <el-col :span=\"12\">\n          <div id=\"line\" style=\"width: 100%; height: 300px;\"></div>\n        </el-col>\n      </el-row>\n\n      <!-- 系统配置 -->\n      <el-row>\n        <el-col :span=\"24\">\n          <el-card style=\"border-radius: 8px;\">\n            <div style=\"font-size: 16px; font-weight: bold; margin-bottom: 15px;\">无人机系统配置</div>\n            <el-form label-width=\"120px\" size=\"small\">\n              <el-form-item label=\"系统名称\">\n                <el-input v-model=\"config.systemName\" style=\"width: 300px;\" />\n              </el-form-item>\n              <el-form-item label=\"巡检频率\">\n                <el-input v-model=\"config.inspectFreq\" suffix=\"分钟\" style=\"width: 300px;\" />\n              </el-form-item>\n              <el-form-item label=\"日志保留天数\">\n                <el-input v-model=\"config.logRetention\" suffix=\"天\" style=\"width: 300px;\" />\n              </el-form-item>\n              <el-form-item label=\"最大飞行高度\">\n                <el-input v-model=\"config.maxHeight\" suffix=\"米\" style=\"width: 300px;\" />\n              </el-form-item>\n              <el-form-item label=\"单次续航时长\">\n                <el-input v-model=\"config.maxBattery\" suffix=\"分钟\" style=\"width: 300px;\" />\n              </el-form-item>\n              <el-form-item label=\"异常预警阈值\">\n                <el-input v-model=\"config.alertThreshold\" suffix=\"次/小时\" style=\"width: 300px;\" />\n              </el-form-item>\n            </el-form>\n            <div style=\"margin-top: 20px;\">\n              <el-button type=\"primary\" icon=\"el-icon-check\">保存配置</el-button>\n              <el-button type=\"default\" icon=\"el-icon-refresh\" style=\"margin-left: 10px;\">重置</el-button>\n              <el-button type=\"default\" icon=\"el-icon-upload\" style=\"margin-left: 10px;\">导入配置</el-button>\n              <el-button type=\"default\" icon=\"el-icon-download\" style=\"margin-left: 10px;\">导出配置</el-button>\n            </div>\n          </el-card>\n        </el-col>\n      </el-row>\n    </div>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\n\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      config: {\n        systemName: \"无人机管理系统V1.0\",\n        inspectFreq: 30,\n        logRetention: 90,\n        maxHeight: 120,\n        maxBattery: 45,\n        alertThreshold: 5\n      },\n      currentTime: \"\",\n      timer: null\n    }\n  },\n  methods: {\n    updateTime() {\n      const date = new Date()\n      const year = date.getFullYear()\n      const month = String(date.getMonth() + 1).padStart(2, '0')\n      const day = String(date.getDate()).padStart(2, '0')\n      const hour = String(date.getHours()).padStart(2, '0')\n      const minute = String(date.getMinutes()).padStart(2, '0')\n      const second = String(date.getSeconds()).padStart(2, '0')\n      const weekArr = ['周日', '周一', '周二', '周三', '周四', '周五', '周六']\n      const week = weekArr[date.getDay()]\n      this.currentTime = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`\n    },\n    initCharts() {\n      const taskData = [30, 37, 33, 42];\n      const errorData = [3, 2, 4, 1];\n      const weeks = ['12月第1周', '12月第2周', '12月第3周', '12月第4周'];\n\n      // 柱状图\n      const barChart = echarts.init(document.getElementById('bar'));\n      barChart.setOption({\n        title: { text: '12月各周无人机执行任务数', textStyle: { fontSize: 16 } },\n        tooltip: { trigger: 'axis' },\n        xAxis: { type: 'category', data: weeks, axisLine: { lineStyle: { color: '#999' } } },\n        yAxis: { type: 'value', name: '任务数（次）', axisLine: { lineStyle: { color: '#999' } }, splitLine: { lineStyle: { type: 'dashed', color: '#eee' } } },\n        series: [{\n          name: '执行任务数',\n          data: taskData,\n          type: 'bar',\n          itemStyle: { color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{ offset: 0, color: '#4299E1' }, { offset: 1, color: '#2B6CB0' }]) }\n        }]\n      });\n\n      // 折线图\n      const lineChart = echarts.init(document.getElementById('line'));\n      lineChart.setOption({\n        title: { text: '12月各周无人机异常次数', textStyle: { fontSize: 16 } },\n        tooltip: { trigger: 'axis' },\n        xAxis: { type: 'category', data: weeks, axisLine: { lineStyle: { color: '#999' } } },\n        yAxis: { type: 'value', name: '次数（次）', axisLine: { lineStyle: { color: '#999' } }, splitLine: { lineStyle: { type: 'dashed', color: '#eee' } },\n          markLine: { data: [{ name: '预警阈值', yAxis: this.config.alertThreshold, lineStyle: { type: 'dashed', color: '#F56C6C' } }] }\n        },\n        series: [\n          {\n            name: '异常次数',\n            data: errorData,\n            type: 'line',\n            smooth: true,\n            lineStyle: { width: 3, color: '#4299E1' },\n            areaStyle: { color: 'rgba(66, 153, 225, 0.1)' }\n          }\n        ]\n      });\n\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n      });\n    },\n    logout() {\n      localStorage.removeItem('token');\n      alert('已退出登录');\n    }\n  },\n  mounted() {\n    this.updateTime();\n    this.timer = setInterval(() => this.updateTime(), 1000);\n    this.initCharts();\n  },\n  beforeDestroy() {\n    clearInterval(this.timer);\n  }\n}\n</script>\n\n<style scoped>\n.card-container1 { background-image: linear-gradient(to bottom right,#401EFF,#2c44bd); border-radius: 8px; overflow: hidden; }\n.card-container2 { background-image: linear-gradient(to bottom right,#67C21A,#204e09); border-radius: 8px; overflow: hidden; }\n.card-container4 { background-image: linear-gradient(to bottom right,#901669,#424997); border-radius: 8px; overflow: hidden; }\n.card-container3 { background-image: linear-gradient(to bottom right,#F16C6C,#751111); border-radius: 8px; overflow: hidden; }\n\n#bar, #line { width: 100% !important; height: 300px !important; }\n\n::v-deep .user-tooltip .el-tooltip__popper {\n  white-space: pre-line !important;\n}\n</style>"],"mappings":"AAiKA,YAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,MAAA;QACAC,UAAA;QACAC,WAAA;QACAC,YAAA;QACAC,SAAA;QACAC,UAAA;QACAC,cAAA;MACA;MACAC,WAAA;MACAC,KAAA;IACA;EACA;EACAC,OAAA;IACAC,WAAA;MACA,MAAAC,IAAA,OAAAC,IAAA;MACA,MAAAC,IAAA,GAAAF,IAAA,CAAAG,WAAA;MACA,MAAAC,KAAA,GAAAC,MAAA,CAAAL,IAAA,CAAAM,QAAA,QAAAC,QAAA;MACA,MAAAC,GAAA,GAAAH,MAAA,CAAAL,IAAA,CAAAS,OAAA,IAAAF,QAAA;MACA,MAAAG,IAAA,GAAAL,MAAA,CAAAL,IAAA,CAAAW,QAAA,IAAAJ,QAAA;MACA,MAAAK,MAAA,GAAAP,MAAA,CAAAL,IAAA,CAAAa,UAAA,IAAAN,QAAA;MACA,MAAAO,MAAA,GAAAT,MAAA,CAAAL,IAAA,CAAAe,UAAA,IAAAR,QAAA;MACA,MAAAS,OAAA;MACA,MAAAC,IAAA,GAAAD,OAAA,CAAAhB,IAAA,CAAAkB,MAAA;MACA,KAAAtB,WAAA,MAAAM,IAAA,IAAAE,KAAA,IAAAI,GAAA,IAAAS,IAAA,IAAAP,IAAA,IAAAE,MAAA,IAAAE,MAAA;IACA;IACAK,WAAA;MACA,MAAAC,QAAA;MACA,MAAAC,SAAA;MACA,MAAAC,KAAA;;MAEA;MACA,MAAAC,QAAA,GAAArC,OAAA,CAAAsC,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACAH,QAAA,CAAAI,SAAA;QACAC,KAAA;UAAAC,IAAA;UAAAC,SAAA;YAAAC,QAAA;UAAA;QAAA;QACAC,OAAA;UAAAC,OAAA;QAAA;QACAC,KAAA;UAAAC,IAAA;UAAA/C,IAAA,EAAAkC,KAAA;UAAAc,QAAA;YAAAC,SAAA;cAAAC,KAAA;YAAA;UAAA;QAAA;QACAC,KAAA;UAAAJ,IAAA;UAAAhD,IAAA;UAAAiD,QAAA;YAAAC,SAAA;cAAAC,KAAA;YAAA;UAAA;UAAAE,SAAA;YAAAH,SAAA;cAAAF,IAAA;cAAAG,KAAA;YAAA;UAAA;QAAA;QACAG,MAAA;UACAtD,IAAA;UACAC,IAAA,EAAA