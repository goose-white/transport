{"ast":null,"code":"export default {\n  name: \"Aside\",\n  props: {\n    isCollapse: Boolean,\n    logoTextShow: Boolean\n  },\n  methods: {\n    //获取对应页面路由\n    handleSelect() {\n      this.$route.fullPath.split(\"/\");\n    }\n  }\n};","map":{"version":3,"names":["name","props","isCollapse","Boolean","logoTextShow","methods","handleSelect","$route","fullPath","split"],"sources":["src/components/Aside.vue"],"sourcesContent":["<template>\r\n  <!-- 核心修改：添加 mode=\"horizontal\" 改为水平菜单 -->\r\n  <el-menu\r\n      :default-openeds=\"['1', '3']\"\r\n      mode=\"horizontal\"  <!-- 关键：水平布局 -->\r\n  style=\"min-height: 60px; line-height: 60px; width: 100%; border-bottom: none;\"  <!-- 适配顶部高度，取消固定宽度 -->\r\n  background-color=\"#2D2D2D\"\r\n  text-color=\"#E2E8F0\"\r\n  active-text-color=\"#38BDF8\"\r\n  :collapse-transition=\"false\"\r\n  :collapse=\"isCollapse\"\r\n  router\r\n  @select=\"handleSelect\"\r\n  >\r\n  <!-- 标题+logo容器：从垂直改为水平排列 -->\r\n  <div style=\"\r\n      display: flex;\r\n      align-items: center;  /* 垂直居中 */\r\n      justify-content: flex-start; /* 靠左排列 */\r\n      height: 60px; /* 适配菜单高度 */\r\n      padding: 0 20px; /* 左右内边距 */\r\n      box-sizing: border-box;\r\n    \">\r\n    <img src=\"../assets/logo.png\" alt=\"无人机管理系统logo\" style=\"width: 40px; height: 40px; margin-right: 10px;\">\r\n    <!-- 配合折叠逻辑：logoTextShow为false时隐藏文字 -->\r\n    <span v-show=\"logoTextShow\" style=\"\r\n        font-size: 18px; /* 顶部菜单缩小字体，适配布局 */\r\n        font-weight: 800;\r\n        line-height: 1;\r\n        white-space: nowrap;\r\n        color: #FF0000 !important;\r\n      \">无人机管理系统</span>\r\n  </div>\r\n\r\n  <!-- 导航栏：自动水平排列 -->\r\n  <el-menu-item index=\"/home\">\r\n    <i class=\"el-icon-house\"></i>\r\n    <span slot=\"title\">主页</span>\r\n  </el-menu-item>\r\n\r\n  <!--系统管理，二级菜单自动变为下拉模式 -->\r\n  <el-submenu index=\"2\">\r\n    <template slot=\"title\">\r\n      <i class=\"el-icon-menu\"></i>\r\n      <span slot=\"title\">系统管理</span>\r\n    </template>\r\n\r\n    <!--无人机管理-->\r\n    <el-menu-item index=\"/drone\">\r\n      <template slot=\"title\">\r\n        <i class=\"el-icon-s-custom\"></i>\r\n        <span slot=\"title\">无人机管理</span>\r\n      </template>\r\n    </el-menu-item>\r\n    <!--无人机任务管理-->\r\n    <el-menu-item index=\"/task\">\r\n      <template slot=\"title\">\r\n        <i class=\"el-icon-s-custom\"></i>\r\n        <span slot=\"title\">无人机任务管理</span>\r\n      </template>\r\n    </el-menu-item>\r\n    <!-- 摄影管理 -->\r\n    <el-menu-item index=\"/photography\">\r\n      <template slot=\"title\">\r\n        <i class=\"el-icon-s-tools\"></i>\r\n        <span slot=\"title\">现场视频</span>\r\n      </template>\r\n    </el-menu-item>\r\n    <!-- 识别结果 -->\r\n    <el-menu-item index=\"/recognition\">\r\n      <template slot=\"title\">\r\n        <i class=\"el-icon-s-tools\"></i>\r\n        <span slot=\"title\">识别结果</span>\r\n      </template>\r\n    </el-menu-item>\r\n  </el-submenu>\r\n  </el-menu>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Aside\",\r\n  props: {\r\n    isCollapse: Boolean,\r\n    logoTextShow: Boolean\r\n  },\r\n  methods:{\r\n    //获取对应页面路由\r\n    handleSelect(){\r\n      this.$route.fullPath.split(\"/\")\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 可选：优化下拉菜单样式，和顶部菜单背景色统一 */\r\n:deep(.el-submenu__dropdown) {\r\n  background-color: #2D2D2D !important;\r\n  border: none;\r\n}\r\n/* 可选：优化下拉菜单项hover样式 */\r\n:deep(.el-menu-item:hover) {\r\n  background-color: #383838 !important;\r\n}\r\n</style>"],"mappings":"AAgFA;EACAA,IAAA;EACAC,KAAA;IACAC,UAAA,EAAAC,OAAA;IACAC,YAAA,EAAAD;EACA;EACAE,OAAA;IACA;IACAC,aAAA;MACA,KAAAC,MAAA,CAAAC,QAAA,CAAAC,KAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}