{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\nimport request from '@/utils/request';\n// 如需格式化时间，引入dayjs\n// import dayjs from 'dayjs'\n\nexport default {\n  name: \"Task\",\n  data() {\n    return {\n      taskList: [],\n      loading: false,\n      dialogFormVisible: false,\n      form: {},\n      formRules: {\n        name: [{\n          required: true,\n          message: '请输入任务名称',\n          trigger: 'blur'\n        }],\n        type: [{\n          required: true,\n          message: '请选择任务类型',\n          trigger: 'change'\n        }],\n        device_id: [{\n          required: true,\n          message: '请输入无人机ID',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.loadTaskData();\n  },\n  methods: {\n    resetForm() {\n      this.form = {};\n      this.$refs.formRef?.resetFields();\n    },\n    async loadTaskData() {\n      try {\n        this.loading = true;\n        const res = await request.get(\"/task/getAllData\", {});\n\n        // 精准提取数组\n        let tableData = res.data.data && Array.isArray(res.data.data) ? res.data.data : [];\n\n        // 映射字段：添加“任务结束时间”“任务状态（文本）”\n        this.taskList = tableData.map(item => ({\n          id: item.id || '-',\n          name: item.name || '未命名',\n          // 任务类型：数字转文本\n          type: item.type === 0 ? '巡逻任务' : item.type === 1 ? '巡检任务' : item.type === 2 ? '应急任务' : '未知类型',\n          device_id: item.device_id || '未指定',\n          // 创建时间：格式化（可选）\n          start_time: item.start_time || '未设置',\n          // 新增：任务结束时间\n          end_time: item.end_time || '未设置',\n          // 新增：任务状态（数字转文本）\n          status_text: item.status === 0 ? '待执行' : item.status === 1 ? '执行中' : item.status === 2 ? '已完成' : '未知状态'\n        }));\n      } catch (error) {\n        console.error('加载失败：', error);\n        this.taskList = [];\n        this.$message.error('数据加载失败，请重试');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleAdd() {\n      this.form = {};\n      this.dialogFormVisible = true;\n    },\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row));\n      this.dialogFormVisible = true;\n    },\n    async saveTask() {\n      try {\n        await this.$refs.formRef.validate();\n        const res = await request.post(this.form.id ? \"/task/update\" : \"/task/save\", this.form);\n        if (res?.code === 200) {\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功');\n          this.dialogFormVisible = false;\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '保存失败');\n        }\n      } catch (error) {\n        this.$message.error('保存失败，请检查数据');\n      }\n    },\n    async handleDelete(row) {\n      try {\n        await this.$confirm('确定删除该任务？', '提示', {\n          type: 'warning'\n        });\n        const res = await request.post(\"/task/delete\", {\n          id: row.id\n        });\n        if (res?.code === 200) {\n          this.$message.success('删除成功');\n          this.loadTaskData();\n        } else {\n          this.$message.error(res?.msg || '删除失败');\n        }\n      } catch (error) {\n        if (error !== 'cancel') this.$message.error('删除失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","name","data","taskList","loading","dialogFormVisible","form","formRules","required","message","trigger","type","device_id","created","loadTaskData","methods","resetForm","$refs","formRef","resetFields","res","get","tableData","Array","isArray","map","item","id","start_time","end_time","status_text","status","error","console","$message","handleAdd","handleEdit","row","JSON","parse","stringify","saveTask","validate","post","code","success","msg","handleDelete","$confirm"],"sources":["src/views/task.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 新增/编辑弹窗 -->\r\n    <el-dialog title=\"任务信息\" v-model=\"dialogFormVisible\" width=\"500px\" @close=\"resetForm\">\r\n      <el-form ref=\"formRef\" :model=\"form\" label-width=\"100px\" size=\"small\" :rules=\"formRules\">\r\n        <el-form-item label=\"任务名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\" placeholder=\"请输入任务名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"任务类型\" prop=\"type\">\r\n          <el-select v-model=\"form.type\" placeholder=\"请选择任务类型\">\r\n            <el-option label=\"巡逻任务\" value=\"0\"></el-option>\r\n            <el-option label=\"巡检任务\" value=\"1\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"执行无人机\" prop=\"device_id\">\r\n          <el-input v-model=\"form.device_id\" placeholder=\"请输入无人机ID\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\">\r\n        <el-button @click=\"dialogFormVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTask\">确定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 新增按钮 -->\r\n    <el-button type=\"primary\" style=\"margin-bottom: 20px;\" @click=\"handleAdd\">新增任务</el-button>\r\n\r\n    <!-- 任务表格：添加“任务结束时间”“任务状态”列 -->\r\n    <el-table\r\n        :data=\"taskList\"\r\n        stripe\r\n        border\r\n        style=\"width: 100%;\"\r\n        v-loading=\"loading\"\r\n    >\r\n      <el-table-column prop=\"id\" label=\"任务ID\" width=\"120\" />\r\n      <el-table-column prop=\"name\" label=\"任务名称\" width=\"180\" />\r\n      <el-table-column prop=\"type\" label=\"任务类型\" width=\"120\" />\r\n      <el-table-column prop=\"device_id\" label=\"执行无人机\" width=\"120\" />\r\n      <el-table-column prop=\"start_time\" label=\"创建时间\" width=\"180\" />\r\n      <!-- 新增：任务结束时间 -->\r\n      <el-table-column prop=\"end_time\" label=\"任务结束时间\" width=\"180\" />\r\n      <!-- 新增：任务状态（数字转文本） -->\r\n      <el-table-column prop=\"status_text\" label=\"任务状态\" width=\"120\" />\r\n      <el-table-column label=\"操作\" width=\"150\">\r\n        <template #default=\"scope\">\r\n          <el-button type=\"primary\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button type=\"danger\" size=\"small\" @click=\"handleDelete(scope.row)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from '@/utils/request'\r\n// 如需格式化时间，引入dayjs\r\n// import dayjs from 'dayjs'\r\n\r\nexport default {\r\n  name: \"Task\",\r\n  data() {\r\n    return {\r\n      taskList: [],\r\n      loading: false,\r\n      dialogFormVisible: false,\r\n      form: {},\r\n      formRules: {\r\n        name: [{ required: true, message: '请输入任务名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请选择任务类型', trigger: 'change' }],\r\n        device_id: [{ required: true, message: '请输入无人机ID', trigger: 'blur' }]\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.loadTaskData()\r\n  },\r\n  methods: {\r\n    resetForm() {\r\n      this.form = {}\r\n      this.$refs.formRef?.resetFields()\r\n    },\r\n\r\n    async loadTaskData() {\r\n      try {\r\n        this.loading = true\r\n        const res = await request.get(\"/task/getAllData\", {})\r\n\r\n        // 精准提取数组\r\n        let tableData = res.data.data && Array.isArray(res.data.data) ? res.data.data : []\r\n\r\n        // 映射字段：添加“任务结束时间”“任务状态（文本）”\r\n        this.taskList = tableData.map(item => ({\r\n          id: item.id || '-',\r\n          name: item.name || '未命名',\r\n          // 任务类型：数字转文本\r\n          type: item.type === 0 ? '巡逻任务' : item.type === 1 ? '巡检任务' : item.type === 2 ? '应急任务' : '未知类型',\r\n          device_id: item.device_id || '未指定',\r\n          // 创建时间：格式化（可选）\r\n          start_time: item.start_time || '未设置',\r\n          // 新增：任务结束时间\r\n          end_time: item.end_time || '未设置',\r\n          // 新增：任务状态（数字转文本）\r\n          status_text: item.status === 0 ? '待执行' : item.status === 1 ? '执行中' : item.status === 2 ? '已完成' : '未知状态'\r\n        }))\r\n      } catch (error) {\r\n        console.error('加载失败：', error)\r\n        this.taskList = []\r\n        this.$message.error('数据加载失败，请重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    handleAdd() {\r\n      this.form = {}\r\n      this.dialogFormVisible = true\r\n    },\r\n    handleEdit(row) {\r\n      this.form = JSON.parse(JSON.stringify(row))\r\n      this.dialogFormVisible = true\r\n    },\r\n    async saveTask() {\r\n      try {\r\n        await this.$refs.formRef.validate()\r\n        const res = await request.post(this.form.id ? \"/task/update\" : \"/task/save\", this.form)\r\n        if (res?.code === 200) {\r\n          this.$message.success(this.form.id ? '编辑成功' : '新增成功')\r\n          this.dialogFormVisible = false\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '保存失败')\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('保存失败，请检查数据')\r\n      }\r\n    },\r\n    async handleDelete(row) {\r\n      try {\r\n        await this.$confirm('确定删除该任务？', '提示', { type: 'warning' })\r\n        const res = await request.post(\"/task/delete\", { id: row.id })\r\n        if (res?.code === 200) {\r\n          this.$message.success('删除成功')\r\n          this.loadTaskData()\r\n        } else {\r\n          this.$message.error(res?.msg || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') this.$message.error('删除失败')\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n:deep(.el-button) { margin: 0 4px; }\r\n:deep(.el-form-item) { margin-bottom: 15px; }\r\n</style>"],"mappings":";;;;AAuDA,OAAAA,OAAA;AACA;AACA;;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,OAAA;MACAC,iBAAA;MACAC,IAAA;MACAC,SAAA;QACAN,IAAA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,IAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAE,SAAA;UAAAJ,Q