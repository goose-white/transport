{"ast":null,"code":"import * as echarts from 'echarts';\nimport request from '@/utils/request';\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      // 原有数据...\n      datetimeStr: \"\",\n      // 新增：日期时间\n      timer: null // 新增：定时器\n    };\n  },\n  methods: {\n    // 新增：格式化日期时间（含秒）\n    formatDateTime() {\n      const now = new Date();\n      const year = now.getFullYear();\n      const month = String(now.getMonth() + 1).padStart(2, \"0\");\n      const day = String(now.getDate()).padStart(2, \"0\");\n      const weekArr = [\"周日\", \"周一\", \"周二\", \"周三\", \"周四\", \"周五\", \"周六\"];\n      const week = weekArr[now.getDay()];\n      const hour = String(now.getHours()).padStart(2, \"0\"); // 24小时制\n      const minute = String(now.getMinutes()).padStart(2, \"0\");\n      const second = String(now.getSeconds()).padStart(2, \"0\");\n      this.datetimeStr = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\n    }\n\n    // 原有方法：initCharts、initDetailChart...\n  },\n  mounted() {\n    this.initCharts();\n    // 新增：初始化日期时间+每秒更新\n    this.formatDateTime();\n    this.timer = setInterval(() => this.formatDateTime(), 1000);\n  },\n  beforeDestroy() {\n    // 新增：清除定时器\n    clearInterval(this.timer);\n  }\n};","map":{"version":3,"names":["echarts","request","name","data","datetimeStr","timer","methods","formatDateTime","now","Date","year","getFullYear","month","String","getMonth","padStart","day","getDate","weekArr","week","getDay","hour","getHours","minute","getMinutes","second","getSeconds","mounted","initCharts","setInterval","beforeDestroy","clearInterval"],"sources":["src/views/Manage.vue"],"sourcesContent":["<template>\r\n  <!-- 顶部导航栏（加入日期时间） -->\r\n  <div style=\"display: flex; justify-content: space-between; padding: 10px 20px; background: #2f4050; color: #fff; margin-bottom: 20px;\">\r\n    <div>无人机管理系统</div>\r\n    <div style=\"display: flex; align-items: center; gap: 20px;\">\r\n      <el-input placeholder=\"请输入搜索内容\" style=\"width: 200px;\" />\r\n      <!-- 日期时间显示 -->\r\n      <span>{{ datetimeStr }}</span>\r\n      <el-button type=\"text\" style=\"color: #fff;\">退出登录</el-button>\r\n      <el-avatar>贾舒凯</el-avatar>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- 原有Home页面内容（数据卡片、图表等） -->\r\n  <div style=\"padding: 20px;\">\r\n    <!-- 顶部数据卡片（原有） -->\r\n    <el-row :gutter=\"10\" style=\"margin-bottom: 20px;\">\r\n      <!-- 卡片内容省略... -->\r\n    </el-row>\r\n    <!-- 其他内容省略... -->\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport * as echarts from 'echarts'\r\nimport request from '@/utils/request'\r\n\r\nexport default {\r\n  name: \"Home\",\r\n  data() {\r\n    return {\r\n      // 原有数据...\r\n      datetimeStr: \"\", // 新增：日期时间\r\n      timer: null // 新增：定时器\r\n    }\r\n  },\r\n  methods: {\r\n    // 新增：格式化日期时间（含秒）\r\n    formatDateTime() {\r\n      const now = new Date();\r\n      const year = now.getFullYear();\r\n      const month = String(now.getMonth() + 1).padStart(2, \"0\");\r\n      const day = String(now.getDate()).padStart(2, \"0\");\r\n      const weekArr = [\"周日\", \"周一\", \"周二\", \"周三\", \"周四\", \"周五\", \"周六\"];\r\n      const week = weekArr[now.getDay()];\r\n      const hour = String(now.getHours()).padStart(2, \"0\"); // 24小时制\r\n      const minute = String(now.getMinutes()).padStart(2, \"0\");\r\n      const second = String(now.getSeconds()).padStart(2, \"0\");\r\n      this.datetimeStr = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\r\n    },\r\n\r\n    // 原有方法：initCharts、initDetailChart...\r\n  },\r\n  mounted() {\r\n    this.initCharts();\r\n    // 新增：初始化日期时间+每秒更新\r\n    this.formatDateTime();\r\n    this.timer = setInterval(() => this.formatDateTime(), 1000);\r\n  },\r\n  beforeDestroy() {\r\n    // 新增：清除定时器\r\n    clearInterval(this.timer);\r\n  }\r\n}\r\n</script>\r\n\r\n<!-- 原有样式省略... -->"],"mappings":"AAwBA,YAAAA,OAAA;AACA,OAAAC,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACA;MACAC,WAAA;MAAA;MACAC,KAAA;IACA;EACA;EACAC,OAAA;IACA;IACAC,eAAA;MACA,MAAAC,GAAA,OAAAC,IAAA;MACA,MA