{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\n// 引入侧边栏组件\nimport Aside from \"@/components/Aside\";\nexport default {\n  name: \"Manage\",\n  components: {\n    Aside\n  },\n  data() {\n    return {\n      isCollapse: false,\n      // 侧边栏折叠状态\n      logoTextShow: true,\n      // logo文字显示状态\n      currentTitle: \"\",\n      // 当前页面标题\n      timeTimer: null // 时间定时器\n    };\n  },\n  methods: {\n    // 退出登录\n    logout() {\n      localStorage.removeItem(\"token\");\n      this.$router.push(\"/login\");\n    },\n    // 格式化并更新日期时间\n    updateDateTime() {\n      const now = new Date();\n      const year = now.getFullYear();\n      const month = String(now.getMonth() + 1).padStart(2, \"0\");\n      const day = String(now.getDate()).padStart(2, \"0\");\n      const hour = String(now.getHours()).padStart(2, \"0\");\n      const minute = String(now.getMinutes()).padStart(2, \"0\");\n      const second = String(now.getSeconds()).padStart(2, \"0\");\n      const weekArr = [\"周日\", \"周一\", \"周二\", \"周三\", \"周四\", \"周五\", \"周六\"];\n      const week = weekArr[now.getDay()];\n\n      // 更新顶部日期\n      const dateText = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\n      //document.getElementById(\"current-date\")?.innerText = dateText;\n\n      // 更新待办事项时间\n      //document.getElementById(\"todo-date\")?.innerText = dateText;\n      //document.getElementById(\"todo-date2\")?.innerText = dateText;\n    },\n    // 获取当前路由对应的标题\n    getPageTitle(path) {\n      const titleMap = {\n        \"/home\": \"主页\",\n        \"/drone\": \"无人机管理表格\",\n        \"/task\": \"无人机任务管理表格\",\n        \"/photography\": \"现场视频表格\",\n        \"/recognition\": \"识别结果表格\"\n      };\n      return titleMap[path] || \"\";\n    }\n  },\n  watch: {\n    // 监听路由变化，更新页面标题\n    $route: {\n      immediate: true,\n      // 初始化时立即执行\n      handler(to) {\n        this.currentTitle = this.getPageTitle(to.path);\n      }\n    },\n    // 监听侧边栏折叠状态变化\n    isCollapse(val) {\n      this.logoTextShow = !val;\n    }\n  },\n  mounted() {\n    // 初始化日期时间\n    this.updateDateTime();\n    // 每秒更新一次时间\n    this.timeTimer = setInterval(() => {\n      this.updateDateTime();\n    }, 1000);\n  },\n  beforeDestroy() {\n    // 清除定时器，防止内存泄漏\n    if (this.timeTimer) {\n      clearInterval(this.timeTimer);\n    }\n  }\n};","map":{"version":3,"names":["Aside","name","components","data","isCollapse","logoTextShow","currentTitle","timeTimer","methods","logout","localStorage","removeItem","$router","push","updateDateTime","now","Date","year","getFullYear","month","String","getMonth","padStart","day","getDate","hour","getHours","minute","getMinutes","second","getSeconds","weekArr","week","getDay","dateText","getPageTitle","path","titleMap","watch","$route","immediate","handler","to","val","mounted","setInterval","beforeDestroy","clearInterval"],"sources":["src/views/Manage.vue"],"sourcesContent":["<template>\r\n  <el-container style=\"min-height: 100vh;\">\r\n    <!-- 顶部导航栏 -->\r\n    <el-header style=\"\r\n      background-color: #2D2D2D;\r\n      padding: 0 20px;\r\n      height: auto;\r\n      min-height: 70px;\r\n      display: flex;\r\n      justify-content: space-between;\r\n      align-items: center;\r\n      border-bottom: 1px solid #444;\r\n    \">\r\n      <!-- 左侧标题 -->\r\n      <div>\r\n        <div style=\"font-size: 22px; font-weight: 800; color: #4299E1;\">无人机管理系统</div>\r\n        <div style=\"font-size: 16px; font-weight: 500; margin-top: 4px; color: #90CDF4;\">Drone Management System</div>\r\n      </div>\r\n\r\n      <!-- 右侧功能区 -->\r\n      <div style=\"display: flex; align-items: center; gap: 20px; color: #E2E8F0;\">\r\n        <!-- 通知铃铛 -->\r\n        <el-dropdown placement=\"bottom-end\">\r\n          <span class=\"el-dropdown-link\" style=\"position: relative; cursor: pointer;\">\r\n            <i class=\"el-icon-bell\" style=\"font-size: 18px;\"></i>\r\n            <span style=\"\r\n              position: absolute;\r\n              top: -5px;\r\n              right: -8px;\r\n              background: #F56C6C;\r\n              color: #fff;\r\n              font-size: 12px;\r\n              width: 18px;\r\n              height: 18px;\r\n              line-height: 18px;\r\n              text-align: center;\r\n              border-radius: 50%;\r\n            \">3</span>\r\n          </span>\r\n          <el-dropdown-menu slot=\"dropdown\" style=\"width: 300px; padding: 10px;\">\r\n            <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;\">\r\n              <span style=\"font-weight: bold;\">今日待办</span>\r\n              <el-button type=\"text\" size=\"mini\" style=\"color: #4299E1;\">更多</el-button>\r\n            </div>\r\n            <el-dropdown-item style=\"padding: 10px 0; border-bottom: 1px solid #eee;\">\r\n              <div style=\"display: flex; align-items: center; gap: 10px;\">\r\n                <span style=\"background: #4299E1; color: #fff; font-size: 12px; padding: 2px 6px; border-radius: 4px;\">待办</span>\r\n                <div>\r\n                  <div style=\"font-size: 14px;\">检查无人机设备状态</div>\r\n                  <div style=\"font-size: 12px; color: #999;\" id=\"todo-date\"></div>\r\n                </div>\r\n              </div>\r\n            </el-dropdown-item>\r\n            <el-dropdown-item style=\"padding: 10px 0;\">\r\n              <div style=\"display: flex; align-items: center; gap: 10px;\">\r\n                <span style=\"background: #4299E1; color: #fff; font-size: 12px; padding: 2px 6px; border-radius: 4px;\">待办</span>\r\n                <div>\r\n                  <div style=\"font-size: 14px;\">完成无人机任务上报</div>\r\n                  <div style=\"font-size: 12px; color: #999;\" id=\"todo-date2\"></div>\r\n                </div>\r\n              </div>\r\n            </el-dropdown-item>\r\n          </el-dropdown-menu>\r\n        </el-dropdown>\r\n\r\n        <!-- 搜索框 -->\r\n        <el-input\r\n            placeholder=\"请输入搜索内容\"\r\n            style=\"width: 200px;\"\r\n            prefix-icon=\"el-icon-search\"\r\n        >\r\n          <template slot=\"prepend\"></template>\r\n        </el-input>\r\n\r\n        <!-- 实时日期时间 -->\r\n        <span style=\"font-size: 14px;\" id=\"current-date\"></span>\r\n\r\n        <!-- 退出登录 -->\r\n        <el-button\r\n            type=\"text\"\r\n            icon=\"el-icon-switch-button\"\r\n            style=\"color: #E2E8F0; font-size: 16px;\"\r\n            @click=\"logout\"\r\n        >\r\n          退出登录\r\n        </el-button>\r\n\r\n        <!-- 用户信息 -->\r\n        <div style=\"display: flex; align-items: center; gap: 8px; cursor: pointer;\">\r\n          <el-avatar icon=\"el-icon-user\" size=\"medium\" style=\"background: #4299E1; color: #fff;\"></el-avatar>\r\n          <div style=\"text-align: left;\">\r\n            <span style=\"font-size: 14px; display: block;\">贾舒凯</span>\r\n            <span style=\"font-size: 12px; color: #90CDF4; display: block;\">工号：JSK2025 | 性别：男</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </el-header>\r\n\r\n    <!-- 主体区域 -->\r\n    <el-container>\r\n      <!-- 侧边栏 -->\r\n      <el-aside\r\n          :width=\"isCollapse ? '64px' : '300px'\"\r\n          style=\"background-color: #33393B; border-right: 1px solid #ccc;\"\r\n      >\r\n        <Aside\r\n            :is-collapse=\"isCollapse\"\r\n            :logo-text-show=\"logoTextShow\"\r\n            :current-title=\"currentTitle\"\r\n        />\r\n      </el-aside>\r\n\r\n      <!-- 主内容区 -->\r\n      <el-container>\r\n        <el-main style=\"padding: 20px; background-color: #f5f5f5;\">\r\n          <router-view />\r\n        </el-main>\r\n      </el-container>\r\n    </el-container>\r\n  </el-container>\r\n</template>\r\n\r\n<script>\r\n// 引入侧边栏组件\r\nimport Aside from \"@/components/Aside\";\r\n\r\nexport default {\r\n  name: \"Manage\",\r\n  components: {\r\n    Aside\r\n  },\r\n  data() {\r\n    return {\r\n      isCollapse: false,       // 侧边栏折叠状态\r\n      logoTextShow: true,      // logo文字显示状态\r\n      currentTitle: \"\",        // 当前页面标题\r\n      timeTimer: null          // 时间定时器\r\n    };\r\n  },\r\n  methods: {\r\n    // 退出登录\r\n    logout() {\r\n      localStorage.removeItem(\"token\");\r\n      this.$router.push(\"/login\");\r\n    },\r\n\r\n    // 格式化并更新日期时间\r\n    updateDateTime() {\r\n      const now = new Date();\r\n      const year = now.getFullYear();\r\n      const month = String(now.getMonth() + 1).padStart(2, \"0\");\r\n      const day = String(now.getDate()).padStart(2, \"0\");\r\n      const hour = String(now.getHours()).padStart(2, \"0\");\r\n      const minute = String(now.getMinutes()).padStart(2, \"0\");\r\n      const second = String(now.getSeconds()).padStart(2, \"0\");\r\n      const weekArr = [\"周日\", \"周一\", \"周二\", \"周三\", \"周四\", \"周五\", \"周六\"];\r\n      const week = weekArr[now.getDay()];\r\n\r\n      // 更新顶部日期\r\n      const dateText = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\r\n      //document.getElementById(\"current-date\")?.innerText = dateText;\r\n\r\n      // 更新待办事项时间\r\n      //document.getElementById(\"todo-date\")?.innerText = dateText;\r\n      //document.getElementById(\"todo-date2\")?.innerText = dateText;\r\n    },\r\n\r\n    // 获取当前路由对应的标题\r\n    getPageTitle(path) {\r\n      const titleMap = {\r\n        \"/home\": \"主页\",\r\n        \"/drone\": \"无人机管理表格\",\r\n        \"/task\": \"无人机任务管理表格\",\r\n        \"/photography\": \"现场视频表格\",\r\n        \"/recognition\": \"识别结果表格\"\r\n      };\r\n      return titleMap[path] || \"\";\r\n    }\r\n  },\r\n  watch: {\r\n    // 监听路由变化，更新页面标题\r\n    $route: {\r\n      immediate: true, // 初始化时立即执行\r\n      handler(to) {\r\n        this.currentTitle = this.getPageTitle(to.path);\r\n      }\r\n    },\r\n\r\n    // 监听侧边栏折叠状态变化\r\n    isCollapse(val) {\r\n      this.logoTextShow = !val;\r\n    }\r\n  },\r\n  mounted() {\r\n    // 初始化日期时间\r\n    this.updateDateTime();\r\n    // 每秒更新一次时间\r\n    this.timeTimer = setInterval(() => {\r\n      this.updateDateTime();\r\n    }, 1000);\r\n  },\r\n  beforeDestroy() {\r\n    // 清除定时器，防止内存泄漏\r\n    if (this.timeTimer) {\r\n      clearInterval(this.timeTimer);\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* 覆盖Element UI默认样式 */\r\n:deep(.el-header) {\r\n  padding: 0;\r\n}\r\n\r\n:deep(.el-input__inner) {\r\n  background: rgba(255, 255, 255, 0.1) !important;\r\n  color: #E2E8F0 !important;\r\n  border: none !important;\r\n}\r\n\r\n:deep(.el-dropdown-link) {\r\n  color: #E2E8F0;\r\n}\r\n</style>"],"mappings":";AA2HA;AACA,OAAAA,KAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,KAAA;IACA;MACAC,UAAA;MAAA;MACAC,YAAA;MAAA;MACAC,YAAA;MAAA;MACAC,SAAA;IACA;EACA;EACAC,OAAA;IACA;IACAC,OAAA;MACAC,YAAA,CAAAC,UAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;IAEA;IACAC,eAAA;MACA,MAAAC,GAAA,OAAAC,IAAA;MACA,MAAAC,IAAA,GAAAF,GAAA,CAAAG,WAAA;MACA,MAAAC,KAAA,GAAAC,MAAA,CAAAL,GAAA,CAAAM,QAAA,QAAAC,QAAA;MACA,MAAAC,GAAA,GAAAH,MAAA,CAAAL,GAAA,CAAAS,OAAA,IAAAF,QAAA;MACA,MAAAG,IAAA,GAAAL,MAAA,CAAAL,GAAA,CAAAW,QAAA,IAAAJ,QAAA;MACA,MAAAK,MAAA,GAAAP,MAAA,CAAAL,GAAA,CAAAa,UAAA,IAAAN,QAAA;MACA,MAAAO,MAAA,GAAAT,MAAA,CAAAL,GAAA,CAAAe,UAAA,IAAAR,QAAA;MACA,MAAAS,OAAA;MACA,MAAAC,IAAA,GAAAD,OAAA,CAAAhB,GAAA,CAAAkB,MAAA;;MAEA;MACA,MAAAC,QAAA,MAAAjB,IAAA,IAAAE,KAAA,IAAAI,GAAA,IAAAS,IAAA,IAAAP,IAAA,IAAAE,MAAA,IAAAE,MAAA;MACA;;MAEA;MACA;MACA;IACA;IAEA;IACAM,aAAAC,IAAA;MACA,MAAAC,QAAA;QACA;QACA;QACA;QACA;QACA;MACA;MACA,OAAAA,QAAA,CAAAD,IAAA;IACA;EACA;EACAE,KAAA;IACA;IACAC,MAAA;MACAC,SAAA;MAAA;MACAC,QAAAC,EAAA;QACA,KAAApC,YAAA,QAAA6B,YAAA,CAAAO,EAAA,CAAAN,IAAA;MACA;IACA;IAEA;IACAhC,WAAAuC,GAAA;MACA,KAAAtC,YAAA,IAAAsC,GAAA;IACA;EACA;EACAC,QAAA;IACA;IACA,KAAA9B,cAAA;IACA;IACA,KAAAP,SAAA,GAAAsC,WAAA;MACA,KAAA/B,cAAA;IACA;EACA;EACAgC,cAAA;IACA;IACA,SAAAvC,SAAA;MACAwC,aAAA,MAAAxC,SAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}