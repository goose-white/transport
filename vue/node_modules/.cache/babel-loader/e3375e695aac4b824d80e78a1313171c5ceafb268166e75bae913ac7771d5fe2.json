{"ast":null,"code":"import * as echarts from 'echarts';\nimport request from '@/utils/request';\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      config: {\n        systemName: \"无人机管理系统V1.0\",\n        inspectFreq: 30,\n        logRetention: 90,\n        maxHeight: 120,\n        maxBattery: 45,\n        alertThreshold: 5\n      },\n      detailDialogVisible: false,\n      currentWeek: \"\",\n      weekDetailData: {\n        \"12月第1周\": [8, 10, 12],\n        \"12月第2周\": [10, 12, 15],\n        \"12月第3周\": [9, 11, 13],\n        \"12月第4周\": [12, 14, 16]\n      },\n      dateTimeStr: '',\n      timeTimer: null\n    };\n  },\n  methods: {\n    formatDateTime() {\n      const now = new Date();\n      const year = now.getFullYear();\n      const month = String(now.getMonth() + 1).padStart(2, '0');\n      const day = String(now.getDate()).padStart(2, '0');\n      const weekArr = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];\n      const week = weekArr[now.getDay()];\n      const hour = String(now.getHours()).padStart(2, '0');\n      const minute = String(now.getMinutes()).padStart(2, '0');\n      const second = String(now.getSeconds()).padStart(2, '0');\n      this.dateTimeStr = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\n    },\n    async initCharts() {\n      const taskData = [30, 37, 33, 42];\n      const errorData = [3, 2, 4, 1];\n      const weeks = ['12月第1周', '12月第2周', '12月第3周', '12月第4周'];\n      const barChart = echarts.init(document.getElementById('bar'));\n      const barOption = {\n        title: {\n          text: '12月各周无人机执行任务数',\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis',\n          formatter: params => {\n            const item = params[0];\n            return `\n              <div style=\"padding: 5px;\">\n                <div>${item.name}</div>\n                <div style=\"color: ${item.color};\">执行任务数：${item.value} 次</div>\n                <div>环比增长：${Math.round(Math.random() * 10)}%</div>\n              </div>\n            `;\n          }\n        },\n        legend: {\n          data: ['执行任务数'],\n          right: 20\n        },\n        xAxis: {\n          type: 'category',\n          data: weeks,\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          axisLabel: {\n            rotate: 0\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: '任务数（次）',\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              type: 'dashed',\n              color: '#eee'\n            }\n          }\n        },\n        series: [{\n          name: '执行任务数',\n          data: taskData,\n          type: 'bar',\n          itemStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n              offset: 0,\n              color: '#4299E1'\n            }, {\n              offset: 1,\n              color: '#2B6CB0'\n            }])\n          },\n          emphasis: {\n            itemStyle: {\n              color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n                offset: 0,\n                color: '#66B1FF'\n              }, {\n                offset: 1,\n                color: '#337ECC'\n              }]),\n              shadowBlur: 10,\n              shadowColor: 'rgba(0,0,0,0.3)'\n            }\n          }\n        }]\n      };\n      barChart.setOption(barOption);\n      barChart.on('click', params => {\n        this.currentWeek = params.name;\n        this.detailDialogVisible = true;\n        this.initDetailChart();\n      });\n      const lineChart = echarts.init(document.getElementById('line'));\n      const lineOption = {\n        title: {\n          text: '12月各周无人机异常次数',\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: {\n            type: 'shadow'\n          }\n        },\n        legend: {\n          data: ['异常次数', '预警阈值'],\n          right: 20\n        },\n        xAxis: {\n          type: 'category',\n          data: weeks,\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: '次数（次）',\n          axisLine: {\n            lineStyle: {\n              color: '#999'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              type: 'dashed',\n              color: '#eee'\n            }\n          },\n          markLine: {\n            data: [{\n              name: '预警阈值',\n              yAxis: this.config.alertThreshold,\n              lineStyle: {\n                type: 'dashed',\n                color: '#F56C6C'\n              }\n            }]\n          }\n        },\n        series: [{\n          name: '异常次数',\n          data: errorData,\n          type: 'line',\n          smooth: true,\n          lineStyle: {\n            width: 3,\n            color: '#4299E1'\n          },\n          itemStyle: {\n            color: '#2B6CB0',\n            borderWidth: 2,\n            borderColor: '#fff'\n          },\n          areaStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n              offset: 0,\n              color: 'rgba(66, 153, 225, 0.5)'\n            }, {\n              offset: 1,\n              color: 'rgba(66, 153, 225, 0.1)'\n            }])\n          },\n          emphasis: {\n            lineStyle: {\n              width: 4\n            },\n            itemStyle: {\n              color: '#66B1FF',\n              shadowBlur: 10\n            }\n          }\n        }, {\n          name: '预警阈值',\n          type: 'line',\n          data: [this.config.alertThreshold, this.config.alertThreshold, this.config.alertThreshold, this.config.alertThreshold],\n          lineStyle: {\n            type: 'dashed',\n            color: '#F56C6C'\n          },\n          symbol: 'none'\n        }]\n      };\n      lineChart.setOption(lineOption);\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n        if (this.detailDialogVisible) this.initDetailChart();\n      });\n    },\n    initDetailChart() {\n      const detailChart = echarts.init(document.getElementById('detailChart'));\n      const detailOption = {\n        title: {\n          text: `${this.currentWeek} 任务类型分布`,\n          textStyle: {\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'item',\n          formatter: '{b}: {c} 次 ({d}%)'\n        },\n        legend: {\n          orient: 'vertical',\n          left: 10,\n          data: ['巡逻任务', '巡检任务', '应急任务']\n        },\n        series: [{\n          type: 'pie',\n          radius: ['40%', '70%'],\n          center: ['50%', '50%'],\n          data: [{\n            name: '巡逻任务',\n            value: this.weekDetailData[this.currentWeek][0]\n          }, {\n            name: '巡检任务',\n            value: this.weekDetailData[this.currentWeek][1]\n          }, {\n            name: '应急任务',\n            value: this.weekDetailData[this.currentWeek][2]\n          }],\n          itemStyle: {\n            color: params => {\n              const colors = ['#4299E1', '#67C21A', '#F56C6C'];\n              return colors[params.dataIndex];\n            },\n            emphasis: {\n              shadowBlur: 10,\n              shadowColor: 'rgba(0,0,0,0.3)'\n            }\n          },\n          label: {\n            show: false\n          },\n          labelLine: {\n            show: false\n          }\n        }]\n      };\n      detailChart.setOption(detailOption);\n    }\n  },\n  mounted() {\n    this.initCharts();\n    this.formatDateTime();\n    this.timeTimer = setInterval(() => {\n      this.formatDateTime();\n    }, 1000);\n  },\n  beforeDestroy() {\n    if (this.timeTimer) {\n      clearInterval(this.timeTimer);\n    }\n  }\n};","map":{"version":3,"names":["echarts","request","name","data","config","systemName","inspectFreq","logRetention","maxHeight","maxBattery","alertThreshold","detailDialogVisible","currentWeek","weekDetailData","dateTimeStr","timeTimer","methods","formatDateTime","now","Date","year","getFullYear","month","String","getMonth","padStart","day","getDate","weekArr","week","getDay","hour","getHours","minute","getMinutes","second","getSeconds","initCharts","taskData","errorData","weeks","barChart","init","document","getElementById","barOption","title","text","textStyle","fontSize","tooltip","trigger","formatter","params","item","color","value","Math","round","random","legend","right","xAxis","type","axisLine","lineStyle","axisLabel","rotate","yAxis","splitLine","series","itemStyle","graphic","LinearGradient","offset","emphasis","shadowBlur","shadowColor","setOption","on","initDetailChart","lineChart","lineOption","axisPointer","markLine","smooth","width","borderWidth","borderColor","areaStyle","symbol","window","addEventListener","resize","detailChart","detailOption","orient","left","radius","center","colors","dataIndex","label","show","labelLine","mounted","setInterval","beforeDestroy","clearInterval"],"sources":["src/views/Home.vue"],"sourcesContent":["<template>\n  <div style=\"padding: 20px;\">\n    <!-- 1. 日期时间行：设置sticky固定 -->\n    <div class=\"sticky-date\">\n      {{ dateTimeStr }}\n    </div>\n\n    <!-- 2. 数据卡片行：设置sticky固定 -->\n    <el-row :gutter=\"10\" class=\"sticky-card\" style=\"margin-bottom: 20px;\">\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container1\">\n          <div><<i class=\"el-icon-s-data\" /> 执勤无人机</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">5</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container2\">\n          <div><<i class=\"el-icon-success\" /> 待办任务</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">57</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container4\">\n          <div><<i class=\"el-icon-remove\" /> 日志记录</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">1000</div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #fff; height: 100px;\" class=\"card-container3\">\n          <div><<i class=\"el-icon-warning\" /> 异常运行无人机</div>\n          <div style=\"padding: 10px 0; text-align: center; font-weight: bold;\">2</div>\n        </el-card>\n      </el-col>\n    </el-row>\n\n    <!-- 图表：改回左右布局（1:1分栏） -->\n    <el-row :gutter=\"20\" style=\"margin-bottom: 20px;\">\n      <el-col :span=\"12\">\n        <div id=\"bar\" style=\"width: 100%; height: 300px;\"></div>\n      </el-col>\n      <el-col :span=\"12\">\n        <div id=\"line\" style=\"width: 100%; height: 300px;\"></div>\n      </el-col>\n    </el-row>\n\n    <!-- 数据下钻弹窗（周维度） -->\n    <el-dialog\n        title=\"周任务详情\"\n        :visible.sync=\"detailDialogVisible\"\n        width=\"50%\"\n    >\n      <div id=\"detailChart\" style=\"width: 100%; height: 300px;\"></div>\n    </el-dialog>\n\n    <!-- 无人机系统配置模块（原有） -->\n    <el-row>\n      <el-col :span=\"24\">\n        <el-card style=\"border-radius: 8px;\">\n          <div style=\"font-size: 16px; font-weight: bold; margin-bottom: 15px;\">无人机系统配置</div>\n          <el-form label-width=\"120px\" size=\"small\">\n            <el-form-item label=\"系统名称\">\n              <el-input v-model=\"config.systemName\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"巡检频率\">\n              <el-input v-model=\"config.inspectFreq\" suffix=\"分钟\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"日志保留天数\">\n              <el-input v-model=\"config.logRetention\" suffix=\"天\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"最大飞行高度\">\n              <el-input v-model=\"config.maxHeight\" suffix=\"米\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"单次续航时长\">\n              <el-input v-model=\"config.maxBattery\" suffix=\"分钟\" style=\"width: 300px;\" />\n            </el-form-item>\n            <el-form-item label=\"异常预警阈值\">\n              <el-input v-model=\"config.alertThreshold\" suffix=\"次/小时\" style=\"width: 300px;\" />\n            </el-form-item>\n          </el-form>\n          <div style=\"margin-top: 20px;\">\n            <el-button type=\"primary\" icon=\"el-icon-check\">保存配置</el-button>\n            <el-button type=\"default\" icon=\"el-icon-refresh\" style=\"margin-left: 10px;\">重置</el-button>\n            <el-button type=\"default\" icon=\"el-icon-upload\" style=\"margin-left: 10px;\">导入配置</el-button>\n            <el-button type=\"default\" icon=\"el-icon-download\" style=\"margin-left: 10px;\">导出配置</el-button>\n          </div>\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\nimport request from '@/utils/request'\n\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      config: {\n        systemName: \"无人机管理系统V1.0\",\n        inspectFreq: 30,\n        logRetention: 90,\n        maxHeight: 120,\n        maxBattery: 45,\n        alertThreshold: 5\n      },\n      detailDialogVisible: false,\n      currentWeek: \"\",\n      weekDetailData: {\n        \"12月第1周\": [8, 10, 12],\n        \"12月第2周\": [10, 12, 15],\n        \"12月第3周\": [9, 11, 13],\n        \"12月第4周\": [12, 14, 16]\n      },\n      dateTimeStr: '',\n      timeTimer: null\n    }\n  },\n  methods: {\n    formatDateTime() {\n      const now = new Date();\n      const year = now.getFullYear();\n      const month = String(now.getMonth() + 1).padStart(2, '0');\n      const day = String(now.getDate()).padStart(2, '0');\n      const weekArr = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];\n      const week = weekArr[now.getDay()];\n      const hour = String(now.getHours()).padStart(2, '0');\n      const minute = String(now.getMinutes()).padStart(2, '0');\n      const second = String(now.getSeconds()).padStart(2, '0');\n      this.dateTimeStr = `${year}-${month}-${day} ${week} ${hour}:${minute}:${second}`;\n    },\n\n    async initCharts() {\n      const taskData = [30, 37, 33, 42];\n      const errorData = [3, 2, 4, 1];\n      const weeks = ['12月第1周', '12月第2周', '12月第3周', '12月第4周'];\n\n      const barChart = echarts.init(document.getElementById('bar'));\n      const barOption = {\n        title: { text: '12月各周无人机执行任务数', textStyle: { fontSize: 16 } },\n        tooltip: {\n          trigger: 'axis',\n          formatter: (params) => {\n            const item = params[0];\n            return `\n              <div style=\"padding: 5px;\">\n                <div>${item.name}</div>\n                <div style=\"color: ${item.color};\">执行任务数：${item.value} 次</div>\n                <div>环比增长：${Math.round(Math.random()*10)}%</div>\n              </div>\n            `;\n          }\n        },\n        legend: { data: ['执行任务数'], right: 20 },\n        xAxis: {\n          type: 'category',\n          data: weeks,\n          axisLine: { lineStyle: { color: '#999' } },\n          axisLabel: { rotate: 0 }\n        },\n        yAxis: {\n          type: 'value',\n          name: '任务数（次）',\n          axisLine: { lineStyle: { color: '#999' } },\n          splitLine: { lineStyle: { type: 'dashed', color: '#eee' } }\n        },\n        series: [{\n          name: '执行任务数',\n          data: taskData,\n          type: 'bar',\n          itemStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n              { offset: 0, color: '#4299E1' },\n              { offset: 1, color: '#2B6CB0' }\n            ])\n          },\n          emphasis: {\n            itemStyle: {\n              color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n                { offset: 0, color: '#66B1FF' },\n                { offset: 1, color: '#337ECC' }\n              ]),\n              shadowBlur: 10,\n              shadowColor: 'rgba(0,0,0,0.3)'\n            }\n          }\n        }]\n      };\n      barChart.setOption(barOption);\n\n      barChart.on('click', (params) => {\n        this.currentWeek = params.name;\n        this.detailDialogVisible = true;\n        this.initDetailChart();\n      });\n\n      const lineChart = echarts.init(document.getElementById('line'));\n      const lineOption = {\n        title: { text: '12月各周无人机异常次数', textStyle: { fontSize: 16 } },\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: { type: 'shadow' }\n        },\n        legend: { data: ['异常次数', '预警阈值'], right: 20 },\n        xAxis: {\n          type: 'category',\n          data: weeks,\n          axisLine: { lineStyle: { color: '#999' } }\n        },\n        yAxis: {\n          type: 'value',\n          name: '次数（次）',\n          axisLine: { lineStyle: { color: '#999' } },\n          splitLine: { lineStyle: { type: 'dashed', color: '#eee' } },\n          markLine: {\n            data: [{\n              name: '预警阈值',\n              yAxis: this.config.alertThreshold,\n              lineStyle: { type: 'dashed', color: '#F56C6C' }\n            }]\n          }\n        },\n        series: [\n          {\n            name: '异常次数',\n            data: errorData,\n            type: 'line',\n            smooth: true,\n            lineStyle: { width: 3, color: '#4299E1' },\n            itemStyle: {\n              color: '#2B6CB0',\n              borderWidth: 2,\n              borderColor: '#fff'\n            },\n            areaStyle: {\n              color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n                { offset: 0, color: 'rgba(66, 153, 225, 0.5)' },\n                { offset: 1, color: 'rgba(66, 153, 225, 0.1)' }\n              ])\n            },\n            emphasis: {\n              lineStyle: { width: 4 },\n              itemStyle: {\n                color: '#66B1FF',\n                shadowBlur: 10\n              }\n            }\n          },\n          {\n            name: '预警阈值',\n            type: 'line',\n            data: [this.config.alertThreshold, this.config.alertThreshold, this.config.alertThreshold, this.config.alertThreshold],\n            lineStyle: { type: 'dashed', color: '#F56C6C' },\n            symbol: 'none'\n          }\n        ]\n      };\n      lineChart.setOption(lineOption);\n\n      window.addEventListener('resize', () => {\n        barChart.resize();\n        lineChart.resize();\n        if (this.detailDialogVisible) this.initDetailChart();\n      });\n    },\n\n    initDetailChart() {\n      const detailChart = echarts.init(document.getElementById('detailChart'));\n      const detailOption = {\n        title: { text: `${this.currentWeek} 任务类型分布`, textStyle: { fontSize: 16 } },\n        tooltip: { trigger: 'item', formatter: '{b}: {c} 次 ({d}%)' },\n        legend: { orient: 'vertical', left: 10, data: ['巡逻任务', '巡检任务', '应急任务'] },\n        series: [{\n          type: 'pie',\n          radius: ['40%', '70%'],\n          center: ['50%', '50%'],\n          data: [\n            { name: '巡逻任务', value: this.weekDetailData[this.currentWeek][0] },\n            { name: '巡检任务', value: this.weekDetailData[this.currentWeek][1] },\n            { name: '应急任务', value: this.weekDetailData[this.currentWeek][2] }\n          ],\n          itemStyle: {\n            color: (params) => {\n              const colors = ['#4299E1', '#67C21A', '#F56C6C'];\n              return colors[params.dataIndex];\n            },\n            emphasis: {\n              shadowBlur: 10,\n              shadowColor: 'rgba(0,0,0,0.3)'\n            }\n          },\n          label: { show: false },\n          labelLine: { show: false }\n        }]\n      };\n      detailChart.setOption(detailOption);\n    }\n  },\n  mounted() {\n    this.initCharts();\n    this.formatDateTime();\n    this.timeTimer = setInterval(() => {\n      this.formatDateTime();\n    }, 1000);\n  },\n  beforeDestroy() {\n    if (this.timeTimer) {\n      clearInterval(this.timeTimer);\n    }\n  }\n}\n</script>\n\n<style scoped>\n/* 关键新增：sticky固定样式 */\n.sticky-date {\n  position: sticky;\n  top: 0; /* 距离顶部0px时固定 */\n  z-index: 10; /* 保证层级在上方，不被遮挡 */\n  padding: 10px 0;\n  font-size: 16px;\n  font-weight: bold;\n  color: #333;\n  background: #fff; /* 背景色，避免滚动时穿透 */\n  margin-bottom: 10px;\n}\n.sticky-card {\n  position: sticky;\n  top: 40px; /* 日期行高度约40px，所以卡片行固定在日期行下方 */\n  z-index: 10;\n  background: #fff;\n  padding: 10px 0;\n  margin-bottom: 20px !important;\n}\n\n/* 原有样式 */\n.card-container1 {\n  background-image: linear-gradient(to bottom right,#401EFF,#2c44bd);\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container2 {\n  background-image: linear-gradient(to bottom right,#67C21A,#204e09);\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container4 {\n  background-image: linear-gradient(to bottom right,#901669,#424997);\n  border-radius: 8px;\n  overflow: hidden;\n}\n.card-container3 {\n  background-image: linear-gradient(to bottom right,#F16C6C,#751111);\n  border-radius: 8px;\n  overflow: hidden;\n}\n#bar, #line {\n  width: 100% !important;\n  height: 300px !important;\n}\n#detailChart {\n  width: 100% !important;\n  height: 300px !important;\n}\n</style>"],"mappings":"AA4FA,YAAAA,OAAA;AACA,OAAAC,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,MAAA;QACAC,UAAA;QACAC,WAAA;QACAC,YAAA;QACAC,SAAA;QACAC,UAAA;QACAC,cAAA;MACA;MACAC,mBAAA;MACAC,WAAA;MACAC,cAAA;QACA;QACA;QACA;QACA;MACA;MACAC,WAAA;MACAC,SAAA;IACA;EACA;EACAC,OAAA;IACAC,eAAA;MACA,MAAAC,GAAA,OAAAC,IAAA;MACA,MAAAC,IAAA,GAAAF,GAAA,CAAAG,WAAA;MACA,MAAAC,KAAA,GAAAC,MAAA,CAAAL,GAAA,CAAAM,QAAA,